<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pequenos Exploradores — Entrar</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Fredoka:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/aluno-redesign.css">
<style>
  :root {
    --green: #3aaa50;
    --green-dark: #1f7a34;
    --green-light: #a8f0c0;
    --blue: #1a7fc4;
    --blue-dark: #0d5a8e;
    --blue-light: #7dd3f8;
    --cyan: #00c8d7;
    --yellow: #f5c518;
    --yellow-dark: #c99500;
    --purple: #7c3aed;
    --purple-light: #c4b5fd;
    --navy: #0f2044;
    --navy-mid: #1a3560;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Fredoka', sans-serif;
    min-height: 100vh;
    overflow: hidden;
    position: relative;
    background: #87CEEB;
    margin-top: 72px;
  }

  /* SKY BACKGROUND */
  html::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 0;
    background: linear-gradient(180deg,
      #87CEEB 0%,
      #B0E0FF 50%,
      #E0F6FF 100%
    );
    pointer-events: none;
  }

  /* Clouds */
  .cloud {
    position: fixed;
    background: white;
    border-radius: 50px;
    opacity: 0.9;
    animation: drift linear infinite;
    z-index: 1;
    pointer-events: none;
  }
  .cloud::before, .cloud::after {
    content: '';
    position: absolute;
    background: white;
    border-radius: 50%;
  }
  .cloud-1 { width: 100px; height: 40px; top: 15%; left: -120px; animation-duration: 30s; animation-delay: 0s; }
  .cloud-1::before { width: 60px; height: 60px; top: -30px; left: 10px; }
  .cloud-1::after { width: 45px; height: 45px; top: -20px; left: 40px; }
  .cloud-2 { width: 140px; height: 50px; top: 25%; left: -160px; animation-duration: 45s; animation-delay: -15s; }
  .cloud-2::before { width: 70px; height: 70px; top: -40px; left: 20px; }
  .cloud-2::after { width: 55px; height: 55px; top: -28px; left: 60px; }
  .cloud-3 { width: 80px; height: 35px; top: 12%; left: -100px; animation-duration: 35s; animation-delay: -8s; }
  .cloud-3::before { width: 50px; height: 50px; top: -28px; left: 8px; }
  .cloud-3::after { width: 40px; height: 40px; top: -18px; left: 35px; }
  .cloud-4 { width: 110px; height: 45px; top: 32%; left: -130px; animation-duration: 40s; animation-delay: -5s; }
  .cloud-4::before { width: 65px; height: 65px; top: -35px; left: 15px; }
  .cloud-4::after { width: 50px; height: 50px; top: -22px; left: 45px; }
  .cloud-5 { width: 90px; height: 38px; top: 20%; left: -110px; animation-duration: 32s; animation-delay: -20s; }
  .cloud-5::before { width: 55px; height: 55px; top: -30px; left: 12px; }
  .cloud-5::after { width: 42px; height: 42px; top: -20px; left: 38px; }
  .cloud-6 { width: 130px; height: 48px; top: 38%; left: -150px; animation-duration: 50s; animation-delay: -25s; }
  .cloud-6::before { width: 72px; height: 72px; top: -38px; left: 25px; }
  .cloud-6::after { width: 58px; height: 58px; top: -30px; left: 65px; }

  @keyframes drift {
    from { transform: translateX(-200px); }
    to { transform: translateX(110vw); }
  }

  /* ============ SCREENS ============ */
  .screen {
    position: fixed;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 54px 0 40px;
    transition: opacity 0.45s ease, transform 0.45s ease;
  }

  .screen.hidden {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.96);
  }

  .screen.slide-out-left {
    transform: translateX(-60px) scale(0.95);
    opacity: 0;
    pointer-events: none;
  }

  /* ===== SCREEN 1: HOME ===== */
  #screen-home .welcome-title {
    font-family: 'Fredoka One', sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    color: white;
    text-align: center;
    text-shadow: 0 0 15px rgba(0,0,0,0.9), 0 4px 10px rgba(0,0,0,0.8), 0 -1px 2px rgba(0,0,0,0.7);
    margin-bottom: 10px;
    animation: popIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    line-height: 1.2;
  }

  #screen-home .welcome-sub {
    font-size: 17px;
    color: white;
    text-align: center;
    margin-bottom: 44px;
    animation: popIn 0.6s 0.1s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    text-shadow: 0 0 12px rgba(0,0,0,0.85), 0 3px 8px rgba(0,0,0,0.7);
  }

  @keyframes popIn {
    from { opacity: 0; transform: translateY(20px) scale(0.9); }
    to   { opacity: 1; transform: none; }
  }

  .role-cards {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    animation: popIn 0.6s 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .role-card {
    cursor: pointer;
    width: 180px;
    background: rgba(255,255,255,0.08);
    border: 2px solid rgba(255,255,255,0.2);
    border-radius: 28px;
    padding: 32px 20px 28px;
    text-align: center;
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.25s, border-color 0.25s, box-shadow 0.25s;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(8px);
  }

  .role-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--card-color);
    opacity: 0;
    transition: opacity 0.25s;
    border-radius: 26px;
  }

  .role-card:hover::before { opacity: 0.15; }

  .role-card:hover {
    transform: translateY(-10px) scale(1.04);
    border-color: var(--card-color);
    box-shadow: 0 16px 40px rgba(0,0,0,0.3), 0 0 0 1px var(--card-color);
  }

  .role-card:active { transform: translateY(-4px) scale(0.98); }

  .role-card .card-emoji {
    font-size: 52px;
    display: block;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .role-card:hover .card-emoji { transform: scale(1.2) rotate(-5deg); }

  .role-card .card-label {
    font-family: 'Fredoka One', sans-serif;
    font-size: 22px;
    color: white;
    position: relative;
    z-index: 1;
    text-shadow: 0 0 10px rgba(0,0,0,0.9), 0 3px 8px rgba(0,0,0,0.8);
  }

  .role-card .card-desc {
    font-size: 12px;
    color: rgba(255,255,255,0.95);
    margin-top: 6px;
    position: relative;
    z-index: 1;
    font-weight: 400;
    line-height: 1.4;
    text-shadow: 0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);
  }

  .role-card .card-badge {
    position: absolute;
    top: -6px; right: -6px;
    background: var(--card-color);
    color: white;
    font-size: 10px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 50px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    animation: bounceBadge 2s ease-in-out infinite;
    animation-delay: var(--badge-delay, 0s);
    text-shadow: 0 0 6px rgba(0,0,0,0.8), 0 2px 4px rgba(0,0,0,0.7);
  }

  @keyframes bounceBadge {
    0%, 100% { transform: rotate(-3deg) scale(1); }
    50%       { transform: rotate(3deg) scale(1.1); }
  }

  .card-aluno    { --card-color: #00c8d7; }
  .card-professor { --card-color: #f5c518; }
  .card-gestao   { --card-color: #a855f7; }

  /* Floating particles on cards */
  .card-particle {
    position: absolute;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--card-color);
    opacity: 0;
    pointer-events: none;
    animation: particleFloat 3s ease-in-out infinite;
    animation-delay: var(--pd);
  }

  @keyframes particleFloat {
    0%   { opacity: 0; transform: translateY(0) scale(0); }
    20%  { opacity: 0.8; transform: translateY(-10px) scale(1); }
    100% { opacity: 0; transform: translateY(-60px) scale(0.5); }
  }

  /* ===== SCREEN 2: LOGIN FORM ===== */
  .login-card {
    background: rgba(15, 32, 68, 0.88);
    border: 2px solid var(--accent-color, #00c8d7);
    border-radius: 32px;
    padding: 40px 44px;
    width: min(420px, 90vw);
    backdrop-filter: blur(20px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05), inset 0 1px 0 rgba(255,255,255,0.1);
    animation: cardIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    position: relative;
  }

  @keyframes cardIn {
    from { opacity: 0; transform: translateY(30px) scale(0.92); }
    to   { opacity: 1; transform: none; }
  }

  .login-card::before {
    content: '';
    position: absolute;
    top: -1px; left: 20px; right: 20px;
    height: 3px;
    background: var(--accent-color, #00c8d7);
    border-radius: 0 0 4px 4px;
    filter: blur(6px);
    opacity: 0.6;
  }

  .login-icon {
    font-size: 52px;
    text-align: center;
    display: block;
    margin: 0 auto 8px;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));
    animation: iconWiggle 3s ease-in-out infinite;
  }

  @keyframes iconWiggle {
    0%, 100% { transform: rotate(-3deg) scale(1); }
    50%       { transform: rotate(3deg) scale(1.05); }
  }

  .login-title {
    font-family: 'Fredoka One', sans-serif;
    font-size: 34px;
    color: var(--accent-color, #00c8d7);
    text-align: center;
    margin-bottom: 4px;
    text-shadow: 0 0 15px rgba(0,0,0,0.9), 0 4px 10px rgba(0,0,0,0.8);
  }

  .login-subtitle {
    font-size: 14px;
    color: white;
    text-align: center;
    margin-bottom: 28px;
    font-weight: 400;
    text-shadow: 0 0 12px rgba(0,0,0,0.85), 0 3px 8px rgba(0,0,0,0.7);
  }

  .input-group {
    margin-bottom: 14px;
    position: relative;
  }

  .input-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,0.95);
    margin-bottom: 6px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    text-shadow: 0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);
  }

  .input-group input {
    width: 100%;
    padding: 14px 18px;
    background: rgba(255,255,255,0.08);
    border: 1.5px solid rgba(255,255,255,0.12);
    border-radius: 14px;
    color: white;
    font-family: 'Fredoka', sans-serif;
    font-size: 17px;
    font-weight: 400;
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    text-shadow: 0 0 6px rgba(0,0,0,0.7), 0 2px 4px rgba(0,0,0,0.6);
  }

  .input-group input::placeholder { color: rgba(255,255,255,0.5); text-shadow: 0 0 6px rgba(0,0,0,0.6); }

  .input-group input:focus {
    border-color: var(--accent-color, #00c8d7);
    background: rgba(255,255,255,0.12);
    box-shadow: 0 0 0 3px rgba(0,200,215,0.15);
  }

  .btn-entrar {
    width: 100%;
    padding: 16px;
    border: none;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--accent-color, #00c8d7), var(--accent-dark, #009aaa));
    color: white;
    font-family: 'Fredoka One', sans-serif;
    font-size: 20px;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s;
    box-shadow: 0 6px 20px rgba(0,200,215,0.35);
    margin-top: 8px;
    letter-spacing: 0.5px;
    position: relative;
    overflow: hidden;
    text-shadow: 0 0 8px rgba(0,0,0,0.6), 0 2px 6px rgba(0,0,0,0.5);
  }

  .btn-entrar::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.12);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .btn-entrar:hover::after { opacity: 1; }
  .btn-entrar:hover  { transform: translateY(-3px) scale(1.02); box-shadow: 0 10px 28px rgba(0,200,215,0.45); }
  .btn-entrar:active { transform: scale(0.97); }

  /* Confetti burst */
  .confetti-burst {
    position: absolute;
    pointer-events: none;
    font-size: 20px;
    animation: burstOut 0.8s ease-out forwards;
  }

  @keyframes burstOut {
    from { opacity: 1; transform: scale(0); }
    to   { opacity: 0; transform: scale(2) translateY(-30px); }
  }

  /* Register box */
  .register-box {
    margin-top: 18px;
    background: rgba(255,255,255,0.05);
    border: 1.5px dashed rgba(255,255,255,0.15);
    border-radius: 18px;
    padding: 16px 18px;
    text-align: center;
  }

  .register-box p {
    font-size: 14px;
    color: rgba(255,255,255,0.9);
    margin-bottom: 10px;
    font-weight: 400;
    text-shadow: 0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);
  }

  .btn-cadastrar {
    padding: 10px 24px;
    border: none;
    border-radius: 50px;
    background: var(--accent-color, #00c8d7);
    color: white;
    font-family: 'Fredoka One', sans-serif;
    font-size: 16px;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s;
    box-shadow: 0 4px 14px rgba(0,200,215,0.3);
    text-shadow: 0 0 8px rgba(0,0,0,0.6), 0 2px 6px rgba(0,0,0,0.5);
  }

  .btn-cadastrar:hover  { transform: scale(1.06); box-shadow: 0 6px 20px rgba(0,200,215,0.45); }
  .btn-cadastrar:active { transform: scale(0.97); }

  .register-tagline {
    display: block;
    font-size: 12px;
    color: rgba(255,255,255,0.85);
    margin-top: 8px;
    font-weight: 400;
    text-shadow: 0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);
  }

  .btn-voltar {
    display: block;
    text-align: center;
    margin-top: 16px;
    color: rgba(255,255,255,0.85);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    background: none;
    border: none;
    font-family: 'Fredoka', sans-serif;
    transition: color 0.2s;
    text-shadow: 0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);
  }

  .btn-voltar:hover { color: rgba(255,255,255,0.8); }

  .auto-save {
    text-align: center;
    font-size: 13px;
    color: var(--accent-color, #00c8d7);
    margin-top: 10px;
    font-weight: 400;
    text-shadow: 0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);
  }

  /* ACCENT COLORS PER ROLE */
  .accent-aluno {
    --accent-color: #00c8d7;
    --accent-dark: #009aaa;
  }

  .accent-professor {
    --accent-color: #f5c518;
    --accent-dark: #c99500;
  }

  .accent-gestao {
    --accent-color: #a855f7;
    --accent-dark: #7c3aed;
  }

  /* Stars & floating elements */
  .floating-emoji {
    position: fixed;
    font-size: var(--size, 24px);
    animation: floatRound var(--dur, 6s) ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    pointer-events: none;
    opacity: 0.25;
    z-index: 1;
  }

  @keyframes floatRound {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33%       { transform: translateY(-20px) rotate(10deg); }
    66%       { transform: translateY(10px) rotate(-8deg); }
  }

  /* RESPONSIVE */
  @media (max-width: 600px) {
    body { margin-top: 64px; }
    .role-cards { gap: 14px; }
    .role-card { width: 140px; padding: 24px 14px 20px; }
    .role-card .card-emoji { font-size: 38px; }
    .role-card .card-label { font-size: 18px; }
    .login-card { padding: 30px 24px; }
  }
</style>
</head>
<body>

<!-- CLOUDS -->
<section class="cloud cloud-1"></section>
<section class="cloud cloud-2"></section>
<section class="cloud cloud-3"></section>
<section class="cloud cloud-4"></section>
<section class="cloud cloud-5"></section>
<section class="cloud cloud-6"></section>

<!-- NAVBAR -->
<nav class="navbar-redesign">
  <section class="logo-redesign">
    <img src="/img/log.png" alt="Logo Pequenos Exploradores">
  </section>
  <section class="nav-links-redesign">
    <a class="nav-link-redesign" href="/">Início</a>
    <a class="nav-link-redesign" href="/sobre">Sobre</a>
    <a class="nav-link-redesign" href="https://www.instagram.com/pequenos_.exploradores_?igsh=MWthZnZ6eG1xeDlxdw==" target="_blank" rel="noopener">Contato</a>
  </section>
  <section class="nav-right-redesign">
    <a href="/aluno-login" style="background: linear-gradient(90deg,#7c3aed 100%, #7c3aed 100%); color: #fff; text-decoration: none; font-weight: 700; padding: 0.6em 1.5em; border-radius: 8px; border: none; cursor: pointer; font-size: 0.95em;">Seja uma escola parceira </a>
  </section>
</nav>

<!-- ===== BACKGROUND SCENE ===== -->
<section class="bg-scene">
  <section class="sky-gradient"></section>
</section>

<!-- ===== SCREEN 1: ESCOLHA O PERFIL ===== -->
<section class="screen" id="screen-home">
  <h1 class="welcome-title">Bem-vindo ao mundo dos<br>Pequenos Exploradores! 🌎</h1>
  <p class="welcome-sub">Escolha como você quer entrar na aventura:</p>

  <section class="role-cards">
    <!-- ALUNO -->
    <section class="role-card card-aluno" onclick="goToLogin('aluno')" style="--card-color: #00c8d7;">
      <span class="card-badge" style="background:#00c8d7;--badge-delay:0s;">Novo!</span>
      <section class="card-particle" style="top:80%;left:20%;--pd:0s;"></section>
      <section class="card-particle" style="top:70%;left:70%;--pd:1s;"></section>
      <section class="card-particle" style="top:85%;left:50%;--pd:2s;"></section>
      <span class="card-emoji">🎒</span>
      <article class="card-label">Aluno</article>
      <article class="card-desc">Explore, jogue e ganhe recompensas!</article>
    </section>

    <!-- PROFESSOR -->
    <section class="role-card card-professor" onclick="goToLogin('professor')" style="--card-color: #f5c518;">
      <span class="card-emoji">🧑‍🏫</span>
      <article class="card-label">Professor</article>
      <article class="card-desc">Gerencie turmas e acompanhe alunos!</article>
    </section>

    <!-- GESTÃO -->
    <section class="role-card card-gestao" onclick="goToLogin('gestao')" style="--card-color: #a855f7;">
      <span class="card-badge" style="background:#a855f7;--badge-delay:0.4s;">Escola</span>
      <section class="card-particle" style="top:80%;left:30%;--pd:0.5s;"></section>
      <section class="card-particle" style="top:75%;left:65%;--pd:1.5s;"></section>
      <span class="card-emoji">🏫</span>
      <article class="card-label">Gestão</article>
      <article class="card-desc">Painel completo da escola cadastrada!</article>
    </section>
  </section>
</section>

<!-- ===== SCREEN 2: LOGIN ALUNO ===== -->
<section class="screen hidden" id="screen-aluno">
  <section class="login-card accent-aluno">
    <span class="login-icon">🎒</span>
    <h2 class="login-title">Área do Aluno</h2>
    <p class="login-subtitle">Entre e comece sua aventura! 🌿</p>

    <section class="input-group">
      <label>E-mail</label>
      <input type="email" placeholder="seu@email.com" id="aluno-email">
    </section>
    <section class="input-group">
      <label>Senha</label>
      <input type="password" placeholder="••••••••" id="aluno-senha">
    </section>

    <button class="btn-entrar" onclick="handleLogin('aluno', this)">Entrar na Aventura! 🚀</button>

    <section class="register-box">
      <p>Ainda não tem uma conta?</p>
      <button class="btn-cadastrar">Quero me cadastrar!</button>
      <span class="register-tagline">🎮 Ganhe acesso a jogos, ranking, avatares e muito mais!</span>
    </section>

    <button class="btn-voltar" onclick="goBack()">← Voltar para o início</button>
    <p class="auto-save">☀️ Seu progresso é salvo automaticamente!</p>
  </section>
</section>

<!-- ===== SCREEN 3: LOGIN PROFESSOR ===== -->
<section class="screen hidden" id="screen-professor">
  <section class="login-card accent-professor">
    <span class="login-icon">🧑‍🏫</span>
    <h2 class="login-title" style="color:#f5c518;text-shadow:0 2px 16px rgba(245,197,24,0.4);">Área do Professor</h2>
    <p class="login-subtitle">Bem-vindo de volta, educador! 📚</p>

    <section class="input-group">
      <label>E-mail institucional</label>
      <input type="email" placeholder="professor@escola.com.br" id="prof-email">
    </section>
    <section class="input-group">
      <label>Senha</label>
      <input type="password" placeholder="••••••••" id="prof-senha">
    </section>

    <button class="btn-entrar" style="background:linear-gradient(135deg,#f5c518,#c99500);box-shadow:0 6px 20px rgba(245,197,24,0.35);" onclick="handleLogin('professor', this)">Entrar 🎓</button>

    <section class="register-box" style="border-color:rgba(245,197,24,0.25);">
      <p>Ainda não tem uma conta?</p>
      <button class="btn-cadastrar" style="background:#f5c518;color:#1a3c2a;">Quero me cadastrar!</button>
      <span class="register-tagline">📊 Acesse recursos exclusivos para professores!</span>
    </section>

    <button class="btn-voltar" onclick="goBack()">← Voltar para o início</button>
    <p class="auto-save" style="color:#f5c518;">☀️ Seu progresso é salvo automaticamente!</p>
  </section>
</section>

<!-- ===== SCREEN 4: LOGIN GESTÃO ===== -->
<section class="screen hidden" id="screen-gestao">
  <section class="login-card accent-gestao">
    <span class="login-icon">🏫</span>
    <h2 class="login-title" style="color:#c084fc;text-shadow:0 2px 16px rgba(168,85,247,0.4);">Área da Gestão</h2>
    <p class="login-subtitle">Painel da escola cadastrada! 🏆</p>

    <section class="input-group">
      <label>E-mail da escola</label>
      <input type="email" placeholder="gestao@minhaescola.com.br" id="gest-email">
    </section>
    <section class="input-group">
      <label>Senha</label>
      <input type="password" placeholder="••••••••" id="gest-senha">
    </section>

    <button class="btn-entrar" style="background:linear-gradient(135deg,#a855f7,#7c3aed);box-shadow:0 6px 20px rgba(168,85,247,0.35);" onclick="handleLogin('gestao', this)">Acessar Painel 🏫</button>

    <section class="register-box" style="border-color:rgba(168,85,247,0.25);">
      <p>Escola ainda não cadastrada?</p>
      <button class="btn-cadastrar" style="background:#a855f7;">Cadastrar minha escola!</button>
      <span class="register-tagline">🌱 Ofereça educação ambiental de qualidade para seus alunos!</span>
    </section>

    <button class="btn-voltar" onclick="goBack()">← Voltar para o início</button>
    <p class="auto-save" style="color:#c084fc;">🔒 Acesso seguro e criptografado!</p>
  </section>
</section>

<!-- ===== BOTTOM BAR ===== -->
<footer style="position:fixed;bottom:0;left:0;right:0;z-index:50;height:40px;background:#3aaa50;display:flex;align-items:center;justify-content:center;font-size:13px;color:rgba(255,255,255,0.9);font-weight:500;text-shadow:0 0 8px rgba(0,0,0,0.8), 0 2px 6px rgba(0,0,0,0.7);">
  © 2025 Pequenos Exploradores
</footer>

<script>
  // ======= NAVIGATION =======
  let currentScreen = 'home';

  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(s => {
      s.classList.add('hidden');
      s.classList.remove('slide-out-left');
    });
    const target = document.getElementById('screen-' + id);
    if (target) {
      target.classList.remove('hidden');
    }
    currentScreen = id;
  }

  function goToLogin(role) {
    const home = document.getElementById('screen-home');
    home.classList.add('slide-out-left');
    setTimeout(() => {
      home.classList.add('hidden');
      home.classList.remove('slide-out-left');
      showScreen(role);
    }, 300);
  }

  function goBack() {
    showScreen('home');
  }

  // ======= LOGIN =======
  function handleLogin(role, btn) {
    const originalText = btn.textContent;
    btn.textContent = '⏳ Entrando...';
    btn.style.opacity = '0.8';
    btn.disabled = true;

    for (let i = 0; i < 6; i++) {
      const c = document.createElement('span');
      c.className = 'confetti-burst';
      
      c.textContent = emojis[Math.floor(Math.random()*emojis.length)];
      c.style.left = (40 + Math.random()*80) + 'px';
      c.style.top = (40 + Math.random()*40) + 'px';
      btn.parentElement.style.position = 'relative';
      btn.parentElement.appendChild(c);
      setTimeout(() => c.remove(), 900);
    }

    setTimeout(() => {
      btn.textContent = '✅ Bem-vindo!';
      setTimeout(() => {
        btn.textContent = originalText;
        btn.style.opacity = '';
        btn.disabled = false;
      }, 2000);
    }, 1200);
  }

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') goBack();
  });
</script>
</body>
</html>
