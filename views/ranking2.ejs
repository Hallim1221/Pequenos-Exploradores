<script>
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));

    document.getElementById('page-' + id).classList.add('active');
    const btn = document.getElementById('btn-' + id);
    if (btn) btn.classList.add('active');

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function setTab(el, page) {
    console.log('setTab called with:', el.textContent);
    
    const container = el.closest('.filter-tabs') || el.parentElement;
    container.querySelectorAll('.filter-tab').forEach(t => t.classList.remove('active'));
    el.classList.add('active');

    // Get the selected filter (map common names to data-type values)
    let filterType = el.textContent.trim().toLowerCase();
    
    // Handle common variations
    if (filterType === 'geral') filterType = 'geral';
    else if (filterType === 'escola') filterType = 'escola';
    else if (filterType === 'sala') filterType = 'sala';

    console.log('Filter type:', filterType);

    // Hide all leaderboards and podiums
    document.querySelectorAll('.leaderboard').forEach(lb => {
      lb.style.display = 'none';
    });
    document.querySelectorAll('.podium-row').forEach(p => {
      p.style.display = 'none';
    });

    // Show the selected leaderboard and podium
    const selectedLb = document.querySelector(`.leaderboard[data-type="${filterType}"]`);
    const selectedPodium = document.querySelector(`.podium-row[data-type="${filterType}"]`);
    
    console.log('Selected leaderboard:', selectedLb);
    console.log('Selected podium:', selectedPodium);
    
    if (selectedLb) {
      selectedLb.style.display = 'block';
    }
    if (selectedPodium) {
      selectedPodium.style.display = 'flex';
    }

    // Re-render avatars for the visible podium and leaderboard
    setTimeout(() => {
      updateVisibleAvatars();
    }, 0);
  }

  // Update only visible podium and leaderboard avatars
  function updateVisibleAvatars() {
    // Find visible podium
    const visiblePodium = document.querySelector('.podium-row[style*="flex"]') || document.querySelector('.podium-row:not([style*="none"])');
    if (visiblePodium) {
      visiblePodium.querySelectorAll('.podium-avatar').forEach(avatar => {
        if (avatar.textContent.trim() && !avatar.querySelector('img')) {
          const posSpan = avatar.querySelector('.podium-pos');
          const img = document.createElement('img');
          img.src = getRandomAvatar();
          img.style.width = '100%';
          img.style.height = '100%';
          img.style.objectFit = 'contain';
          img.style.borderRadius = '50%';
          avatar.textContent = '';
          avatar.appendChild(img);
          if (posSpan) avatar.appendChild(posSpan);
        }
      });
    }

    // Find visible leaderboard
    const visibleLeaderboard = document.querySelector('.leaderboard[style*="block"]') || document.querySelector('.leaderboard:not([style*="none"])');
    if (visibleLeaderboard) {
      visibleLeaderboard.querySelectorAll('.lb-avatar').forEach(avatar => {
        if (avatar.textContent.trim() && !avatar.querySelector('img')) {
          const img = document.createElement('img');
          img.src = getRandomAvatar();
          img.style.width = '100%';
          img.style.height = '100%';
          img.style.objectFit = 'contain';
          img.style.borderRadius = '50%';
          avatar.textContent = '';
          avatar.appendChild(img);
        }
      });
    }
  }

  // Random avatar images
  const avatarImages = [
    '/img/tcc.img/animal2.png',
    '/img/tcc.img/animal3.png',
    '/img/tcc.img/animal4.png',
    '/img/tcc.img/animal5.png',
    '/img/tcc.img/animal6.png',
    '/img/tcc.img/animal7.png',
    '/img/tcc.img/animal8.png'
  ];

  function getRandomAvatar() {
    return avatarImages[Math.floor(Math.random() * avatarImages.length)];
  }

  // Replace emojis with random avatar images on load
  window.addEventListener('DOMContentLoaded', function() {
    // Podium avatars
    document.querySelectorAll('.podium-avatar').forEach(avatar => {
      const posSpan = avatar.querySelector('.podium-pos');
      const img = document.createElement('img');
      img.src = getRandomAvatar();
      img.style.width = '100%';
      img.style.height = '100%';
      img.style.objectFit = 'contain';
      img.style.borderRadius = '50%';
      avatar.textContent = '';
      avatar.appendChild(img);
      if (posSpan) avatar.appendChild(posSpan);
    });

    // Leaderboard avatars
    document.querySelectorAll('.lb-avatar').forEach(avatar => {
      const img = document.createElement('img');
      img.src = getRandomAvatar();
      img.style.width = '100%';
      img.style.height = '100%';
      img.style.objectFit = 'contain';
      img.style.borderRadius = '50%';
      avatar.textContent = '';
      avatar.appendChild(img);
    });

    // Load user avatar from localStorage
    loadUserAvatar();
  });

  // Load user avatar from localStorage
  function loadUserAvatar() {
    const avatarContainer = document.getElementById('user-avatar-ranking');
    if (!avatarContainer) return;
    const savedAvatar = localStorage.getItem('avatar_usuario');
    if (savedAvatar) {
      const img = document.createElement('img');
      img.src = savedAvatar;
      img.style.width = '100%';
      img.style.height = '100%';
      img.style.objectFit = 'cover';
      img.style.borderRadius = '50%';
      avatarContainer.textContent = '';
      avatarContainer.appendChild(img);
    }
  }

  // Listen for changes from other tabs (aluno-novo.ejs)
  window.addEventListener('storage', function(event) {
    if (event.key === 'avatar_usuario') {
      loadUserAvatar();
    }
  });

  // Periodic check every 1 second (fallback for storage events)
  setInterval(function() {
    const avatarContainer = document.getElementById('user-avatar-ranking');
    if (avatarContainer && !avatarContainer.querySelector('img')) {
      loadUserAvatar();
    }
  }, 1000);
</script>
</body>
</html>
