}

const PAGES = {
  'page-inicio':'🏠 Início',
  'page-turmas':'🌱 Minhas Turmas',
  'page-turma-detalhe':'🌱 Detalhe da Turma',
  'page-atividades':'📋 Atividades',
  'page-alunos':'👦 Alunos',
  'page-progresso':'📊 Progresso'
};

function goto(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pageId)?.classList.add('active');
  document.getElementById('topbar-title').textContent = PAGES[pageId] || '';
  document.querySelectorAll('.nav-item').forEach(b => {
    const map = { 'page-inicio':'Início','page-turmas':'Turmas','page-atividades':'Atividades','page-alunos':'Alunos','page-progresso':'Progresso' };
    b.classList.toggle('active', b.textContent.trim().includes(map[pageId]||'__'));
  });
  window.scrollTo(0,0);
}

function openModal(id) { document.getElementById(id)?.classList.add('open'); }
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }

function confirmarLogout() {
  fetch('/logout', { method: 'POST', credentials: 'include' })
    .then(() => { window.location.href = '/'; })
    .catch(err => { console.error('Erro ao fazer logout:', err); });
}

document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target===m) m.classList.remove('open'); });
});

function copiarCodigo(codigo, btn) {
  navigator.clipboard?.writeText(codigo).catch(()=>{});
  const orig = btn.innerHTML;
  btn.innerHTML = '✅ Copiado!';
  btn.classList.add('copied');
  setTimeout(()=>{ btn.innerHTML=orig; btn.classList.remove('copied'); }, 2000);
  showToast(`✅ Código ${codigo} copiado!`);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2800);
}

