});

// Função para atualizar contadores de alunos em cada turma
async function atualizarContadoresAlunos() {
  for (const turma of TURMAS) {
    try {
      const response = await fetch(`/professor/api/turmas/${turma.id}/alunos`, { credentials: 'include' });
      if (!response.ok) continue;
      
      const data = await response.json();
      const count = data.alunos ? data.alunos.length : 0;
      
      // Atualizar o objeto turma
      turma.alunos = count;
      
      // Atualizar a exibição nos cards
      const cards = document.querySelectorAll('.turma-card');
      for (const card of cards) {
        // Verificar se este card é da turma atual
        const verTurmaBtn = card.querySelector('[onclick*="abrirDetalhe"]');
        if (verTurmaBtn) {
          const cardTurmaId = verTurmaBtn.onclick?.toString().match(/\('(\d+)'\)/)?.[1];
          if (parseInt(cardTurmaId) === turma.id) {
            // Encontrar e atualizar o stat de alunos
            const statElements = card.querySelectorAll('.turma-stat');
            if (statElements.length > 0) {
              statElements[0].querySelector('.turma-stat-num').textContent = count;
              statElements[0].querySelector('.turma-stat-label').textContent = count === 1 ? 'Aluno' : 'Alunos';
            }
          }
        }
      }
    } catch (erro) {
      console.error(`Erro ao atualizar contador da turma ${turma.id}:`, erro);
    }
  }
}
</script>
</body>
</html>
