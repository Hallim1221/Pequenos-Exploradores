<script>
// 📊 Dados do servidor passados como JSON
let TURMAS_REAIS = <%- JSON.stringify(turmas || []) %>;
const PROFESSOR_INFO = <%- JSON.stringify(professor || {}) %>;
const STATS_INFO = <%- JSON.stringify(stats || {}) %>;
const INSTITUICAO_ID = <%= typeof instituicao_id !== 'undefined' ? instituicao_id : 1 %>;

console.log('📊 Turmas carregadas:', TURMAS_REAIS.length, 'turmas');
console.log('👤 Professor:', PROFESSOR_INFO.nome);
console.log('📈 Stats:', STATS_INFO);
console.log('🏫 Instituição ID:', INSTITUICAO_ID);

// Cores aleatórias para turmas
const CORES = [
  'linear-gradient(135deg,#3d9e4f,#2a7338)',
  'linear-gradient(135deg,#3aafdb,#1a7fa5)',
  'linear-gradient(135deg,#f0872a,#c05a10)',
  'linear-gradient(135deg,#9b72cf,#7c3aed)',
  'linear-gradient(135deg,#f5c842,#d97706)',
];

const EMOJIS = ['🦋', '🐸', '🦜', '🦁', '🐢', '🦅', '🦩', '🦎', '🐛', '🦗'];

// Função para gerar código aleatório de 4 caracteres alfanuméricos
function gerarCodigoAcesso() {
  return Math.random().toString(36).substring(2, 6).toUpperCase();
}

// Converter turmas do servidor para formato esperado
const TURMAS = (TURMAS_REAIS || []).map((turma, idx) => ({
  id: turma.id || `turma-${idx}`,
  emoji: turma.emoji || EMOJIS[idx % EMOJIS.length],
  nome: turma.nome || `Turma ${idx + 1}`,
  ano: turma.ano_escolar || turma.ano || 'N/A',
  serie: turma.serie || 'Ensino Fundamental',
  codigo: turma.codigo_acesso || gerarCodigoAcesso(),
  alunos: turma.total_alunos || 0,
  atividades: turma.atividades || 0,
  engajamento: turma.engajamento || Math.floor(Math.random() * 40 + 60),
  cor: CORES[idx % CORES.length],
  listaAlunos: [] // Será preenchido dinamicamente
}));

// Variável para rastrear a turma atualmente sendo visualizada
let TURMA_ATUAL_ID = null;

// ══════ FUNÇÃO PARA CRIAR TURMA ══════
async function criarTurmaProfessor() {
  const nome = document.querySelector('#turma-nome-input')?.value;
  const ano_escolar = document.querySelector('#turma-ano-input')?.value;
  
  if (!nome || !ano_escolar) {
    alert('❌ Nome e série são obrigatórios!');
    return;
  }
  
  try {
    const response = await fetch('/professor/api/turmas/criar', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nome, ano_escolar })
    });
    
    const data = await response.json();
    
    if (data.success) {
      showToast(`✅ Turma "${nome}" criada! Código: ${data.codigo_acesso}`);
      closeModal('modal-nova-turma');
      
      // Limpar formulário
      document.querySelector('#turma-nome-input').value = '';
      document.querySelector('#turma-ano-input').value = ''; // Reset para opção vazia
      
      // Recarregar turmas sem fazer reload completo da página
      setTimeout(() => {
        fetch('/professor/api/turmas', { credentials: 'include' })
          .then(res => {
            if (res.status === 401) {
              console.warn('⚠️ Sessão expirada - redirecionando para login');
              window.location.href = '/login';
              return null;
            }
            return res.json();
          })
          .then(data => {
            if (data && data.success && data.turmas) {
              TURMAS_REAIS = data.turmas;
              renderTurmasGrid();
              // Atualizar contador
              const countEl = document.querySelector('#turmas-count');
              if (countEl) countEl.textContent = TURMAS_REAIS.length;
            } else if (data && !data.success) {
              console.error('❌ Erro ao recarregar turmas:', data.message);
              alert(`⚠️ Erro ao recarregar turmas: ${data.message}`);
            }
          })
          .catch(err => {
            console.error('Erro ao recarregar turmas:', err);
            alert('⚠️ Erro ao recarregar turmas. Tente novamente.');
          });
      }, 1500);
    } else {
      alert(`❌ Erro: ${data.message}`);
    }
  } catch (erro) {
    console.error('Erro ao criar turma:', erro);
    alert('❌ Erro ao criar turma. Tente novamente!');
  }
}

// ══════ FUNÇÃO PARA ADICIONAR ALUNO ══════
async function adicionarAlunoProfessor() {
  const nome = document.querySelector('#aluno-nome-input')?.value?.trim();
  const email = document.querySelector('#aluno-email-input')?.value?.trim();
  const senha = document.querySelector('#aluno-senha-input')?.value?.trim();
  const confirmarSenha = document.querySelector('#aluno-confirmar-senha-input')?.value?.trim();

  // Validação
  if (!nome || !email || !senha || !confirmarSenha) {
    alert('❌ Todos os campos são obrigatórios!');
    return;
  }

  // Validar email
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email)) {
    alert('❌ Por favor, digite um e-mail válido!');
    return;
  }

  // Validar senha
  if (senha.length < 6) {
    alert('❌ A senha deve ter pelo menos 6 caracteres!');
    return;
  }

  // Validar se as senhas são iguais
  if (senha !== confirmarSenha) {
    alert('❌ As senhas não coincidem!');
    return;
  }

  // Validar turma
  if (!TURMA_ATUAL_ID) {
    alert('❌ Selecione uma turma!');
    return;
  }

  const turma = TURMAS.find(t => t.id === TURMA_ATUAL_ID);
  if (!turma) {
    alert('❌ Turma não encontrada!');
    return;
  }

  try {
    const response = await fetch('/api/instituicoes/criar-aluno-turma', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        nome: nome,
        email: email,
        password: senha,
        turma_id: TURMA_ATUAL_ID
      })
    });

    const data = await response.json();

    if (data.success) {
      console.log('✅ Aluno criado:', nome);
      
      // Limpar formulário
      document.querySelector('#aluno-nome-input').value = '';
      document.querySelector('#aluno-email-input').value = '';
      document.querySelector('#aluno-senha-input').value = '';
      document.querySelector('#aluno-confirmar-senha-input').value = '';
      
      // Fechar modal e mostrar mensagem
      closeModal('modal-add-aluno');
      showToast('👤 Aluno cadastrado com sucesso!');
      
      // Recarregar lista de alunos da turma atual
      if (turma) {
        fetch(`/professor/api/turmas/${turma.id}/alunos`, { credentials: 'include' })
          .then(res => {
            if (res.status === 401) return null;
            return res.json();
          })
          .then(data => {
            if (data && data.success && data.alunos) {
              turma.listaAlunos = data.alunos.map(aluno => ({
                nome: aluno.nome || 'Aluno',
                ini: (aluno.nome || 'A')[0].toUpperCase(),
                bg: ['#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A', '#98D8C8'][Math.floor(Math.random() * 5)],
                tc: 'white',
                ativ: aluno.atividades_completas || 0,
                pct: aluno.progresso || 0,
                pts: aluno.pontos || 0,
                status: aluno.status || 'Ativo'
              }));
              
              // Se estamos visualizando a turma, atualizar a tabela
              if (TURMA_ATUAL_ID === turma.id) {
                const tabelaAtualizados = turma.listaAlunos.length > 0 ? turma.listaAlunos.map(a => `
                  <tr>
                    <td><span class="aluno-row"><span class="aluno-avatar" style="background:${a.bg};color:${a.tc||'white'}">${a.ini}</span><span class="aluno-name">${a.nome}</span></span></td>
                    <td>${a.ativ}</td>
                    <td><span class="progress-bar"><span class="progress-fill-bar" style="width:${a.pct}%"></span></span></td>
                    <td><span class="xp-chip">⭐ ${a.pts}</span></td>
                    <td><span class="status-badge ${a.status==='Ativo'?'status-ativo':'status-andamento'}">${a.status}</span></td>
                    <td><button class="btn-ver">Ver perfil</button></td>
                  </tr>
                `).join('') : `
                  <tr>
                    <td colspan="6" style="text-align: center; padding: 40px 20px; color: var(--text-light);">
                      <span style="font-size: 1.5rem;">📚</span> Nenhum aluno ainda
                    </td>
                  </tr>
                `;
                
                // Atualizar contador
                const countElement = document.querySelector('[class*="table-title"]');
                if (countElement) {
                  countElement.textContent = `Alunos da turma (${turma.listaAlunos.length})`;
                }
                
                const tableBody = document.querySelector('#sub-pessoas tbody');
                if (tableBody) {
                  tableBody.innerHTML = tabelaAtualizados;
                }
              }
            }
          })
          .catch(err => console.error('Erro ao recarregar alunos:', err));
      }
    } else {
      alert(`❌ Erro: ${data.message}`);
    }
  } catch (erro) {
    console.error('Erro ao adicionar aluno:', erro);
    alert('❌ Erro ao cadastrar aluno. Tente novamente!');
  }
}

function renderTurmaCard(t, showDetalhe=false) {
  const engColor = t.engajamento >= 85 ? 'var(--green)' : t.engajamento >= 75 ? 'var(--blue)' : 'var(--yellow)';
  const btnClick = showDetalhe ? `abrirDetalhe('${t.id}')` : `abrirDetalhe('${t.id}')`;
  return `
    <article class="turma-card" onclick="${btnClick}">
      <header class="turma-card-header" style="background:${t.cor}">
        <section class="turma-emoji-row">
          <span class="turma-emoji">${t.emoji}</span>
        </section>
        <h3 class="turma-name">${t.nome}</h3>
        <p class="turma-sub">${t.ano}</p>
        <footer class="codigo-acesso" onclick="event.stopPropagation()">
          <section>
            <p class="codigo-label">🔑 Código de acesso</p>
            <p class="codigo-valor">${t.codigo}</p>
          </section>
          <button class="btn-copiar" onclick="copiarCodigo('${t.codigo}',this)">📋 Copiar</button>
        </footer>
      </header>
      <section class="turma-card-body">
        <section class="turma-stats-row">
          <article class="turma-stat"><span class="turma-stat-num">${t.alunos}</span><span class="turma-stat-label">Alunos</span></article>
          <article class="turma-stat"><span class="turma-stat-num">${t.atividades}</span><span class="turma-stat-label">Atividades</span></article>
          <article class="turma-stat"><span class="turma-stat-num" style="color:${engColor}">${t.engajamento}%</span><span class="turma-stat-label">Engajamento</span></article>
        </section>
        <span class="engajamento-bar"><span class="engajamento-fill" style="width:${t.engajamento}%;background:${engColor}"></span></span>
        <footer class="turma-card-actions">
          <button class="btn-turma-action primary" onclick="event.stopPropagation();abrirDetalhe('${t.id}')">👁 Ver turma</button>
          <button class="btn-turma-action" onclick="event.stopPropagation();abrirModalAdicionarAluno('${t.id}')">＋ Aluno</button>
        </footer>
      </section>
    </article>
  `;
}

function renderTurmasGrid(containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;
  
  if (TURMAS.length === 0) {
    el.innerHTML = `
      <article style="grid-column: 1 / -1; text-align: center; padding: 60px 20px; color: var(--text-light);">
        <span style="font-size: 3rem; display: block; margin-bottom: 16px;">📚</span>
        <p style="font-weight: 800; font-size: 1.1rem; margin-bottom: 8px;">Nenhuma turma ainda</p>
        <p style="font-size: 0.92rem; margin-bottom: 20px;">Crie sua primeira turma para começar!</p>
        <button class="btn-primary" onclick="openModal('modal-nova-turma')" style="margin: 0 auto;">➕ Criar turma agora</button>
      </article>
    `;
    return;
  }
  
  el.innerHTML = TURMAS.map(t => renderTurmaCard(t)).join('') +
    `<article class="add-turma-card" onclick="openModal('modal-nova-turma')">
