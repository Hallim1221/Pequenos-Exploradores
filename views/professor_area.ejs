          </tr>
        `).join('');
        
        const tableBody = document.querySelector('#sub-pessoas tbody');
        if (tableBody) {
          tableBody.innerHTML = tabelaAtualizados;
        }
      }
    })
    .catch(err => console.error('❌ Erro ao carregar alunos:', err));
}

function switchSub(id) {
  ['sub-atividades','sub-mural','sub-pessoas'].forEach(s => {
    document.getElementById(s).style.display = s===id ? (s==='sub-atividades'?'block':'block') : 'none';
  });
  document.querySelectorAll('.sub-tab').forEach((b,i) => {
    const ids = ['sub-atividades','sub-mural','sub-pessoas'];
    b.classList.toggle('active', ids[i]===id);
  });
}

// ══════ FUNÇÃO PARA ABRIR MODAL DE ADICIONAR ALUNO ══════
function abrirModalAdicionarAluno(turmaId) {
  // Converte string para número se necessário
  const numId = typeof turmaId === 'string' ? parseInt(turmaId, 10) : turmaId;
  const turma = TURMAS.find(t => t.id === numId);
  
  if (!turma) {
    console.warn('Turma não encontrada com ID:', turmaId);
