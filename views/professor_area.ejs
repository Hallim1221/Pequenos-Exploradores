          <article class="turma-stat"><span class="turma-stat-num" style="color:${engColor}">${t.engajamento}%</span><span class="turma-stat-label">Engajamento</span></article>
        </section>
        <span class="engajamento-bar"><span class="engajamento-fill" style="width:${t.engajamento}%;background:${engColor}"></span></span>
        <footer class="turma-card-actions">
          <button class="btn-turma-action primary" onclick="event.stopPropagation();abrirDetalhe('${t.id}')">👁 Ver turma</button>
          <button class="btn-turma-action" onclick="event.stopPropagation();openModal('modal-add-aluno')">＋ Aluno</button>
        </footer>
      </section>
    </article>
  `;
}

function renderTurmasGrid(containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;
  el.innerHTML = TURMAS.map(t => renderTurmaCard(t)).join('') +
    `<article class="add-turma-card" onclick="openModal('modal-nova-turma')">
      <span class="add-icon">➕</span>
      <p>Criar nova turma</p>
      <span>Adicione uma nova turma</span>
    </article>`;
}

function abrirDetalhe(id) {
  const t = TURMAS.find(x => x.id === id);
  if (!t) return;

  // Header
  document.getElementById('detalhe-header').innerHTML = `
    <header class="detalhe-emoji-box" style="background:${t.cor}">${t.emoji}</header>
    <section class="detalhe-info">
      <h2>${t.nome}</h2>
      <p>${t.ano} · ${t.serie} · ${t.alunos} alunos</p>
    </section>
    <aside class="detalhe-codigo">
      <p class="detalhe-codigo-label">🔑 Código de acesso</p>
      <p class="detalhe-codigo-value">${t.codigo}</p>
      <p class="detalhe-codigo-hint">Compartilhe com os alunos</p>
      <button class="btn-copiar" style="margin-top:8px;width:100%;justify-content:center" onclick="copiarCodigo('${t.codigo}',this)">📋 Copiar código</button>
    </aside>
  `;

  // Sub-atividades
  document.getElementById('sub-atividades').innerHTML = `
    <section class="atividades-list">
      <article class="atividade-item"><span class="atividade-icon">🌿</span><section><h4 class="atividade-title">Reciclagem na escola</h4><p class="atividade-meta">📅 10/04/2025 · 22/${t.alunos} completaram</p></section><span class="atividade-right"><span class="xp-chip">⭐ 20 pts</span><button class="btn-ver">Ver</button></span></article>
      <article class="atividade-item"><span class="atividade-icon">🌊</span><section><h4 class="atividade-title">Ciclo da água</h4><p class="atividade-meta">📅 05/04/2025 · 19/${t.alunos} completaram</p></section><span class="atividade-right"><span class="xp-chip">⭐ 15 pts</span><button class="btn-ver">Ver</button></span></article>
      <article class="atividade-item"><span class="atividade-icon">🦁</span><section><h4 class="atividade-title">Animais em extinção</h4><p class="atividade-meta">📅 01/04/2025 · ${t.alunos}/${t.alunos} completaram</p></section><span class="atividade-right"><span class="xp-chip">⭐ 25 pts</span><button class="btn-ver">Ver</button></span></article>
    </section>
  `;

  // Sub-pessoas
  document.getElementById('sub-pessoas').innerHTML = `
    <article class="table-card">
      <header class="table-header"><span class="table-title">Alunos da turma (${t.alunos})</span><button class="btn-primary" style="font-size:0.82rem;padding:7px 14px" onclick="openModal('modal-add-aluno')">＋ Adicionar</button></header>
      <table>
        <thead><tr><th>Aluno</th><th>Atividades</th><th>Progresso</th><th>Pontos</th><th>Status</th><th></th></tr></thead>
        <tbody>
          ${t.listaAlunos.map(a => `
            <tr>
              <td><span class="aluno-row"><span class="aluno-avatar" style="background:${a.bg};color:${a.tc||'white'}">${a.ini}</span><span class="aluno-name">${a.nome}</span></span></td>
              <td>${a.ativ}</td>
              <td><span class="progress-bar"><span class="progress-fill-bar" style="width:${a.pct}%"></span></span></td>
              <td><span class="xp-chip">⭐ ${a.pts}</span></td>
              <td><span class="status-badge ${a.status==='Ativo'?'status-ativo':'status-andamento'}">${a.status}</span></td>
              <td><button class="btn-ver">Ver perfil</button></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  `;

  // Reset sub-tabs
  document.querySelectorAll('.sub-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.sub-tab')[0].classList.add('active');
  document.getElementById('sub-atividades').style.display='block';
  document.getElementById('sub-mural').style.display='none';
  document.getElementById('sub-pessoas').style.display='none';

  goto('page-turma-detalhe');
}

function switchSub(id) {
  ['sub-atividades','sub-mural','sub-pessoas'].forEach(s => {
    document.getElementById(s).style.display = s===id ? (s==='sub-atividades'?'block':'block') : 'none';
  });
  document.querySelectorAll('.sub-tab').forEach((b,i) => {
    const ids = ['sub-atividades','sub-mural','sub-pessoas'];
    b.classList.toggle('active', ids[i]===id);
  });
}

const PAGES = {
  'page-inicio':'🏠 Início',
  'page-turmas':'🌱 Minhas Turmas',
  'page-turma-detalhe':'🌱 Detalhe da Turma',
  'page-atividades':'📋 Atividades',
  'page-alunos':'👦 Alunos',
  'page-progresso':'📊 Progresso'
};

function goto(pageId) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById(pageId)?.classList.add('active');
  document.getElementById('topbar-title').textContent = PAGES[pageId] || '';
  document.querySelectorAll('.nav-item').forEach(b => {
    const map = { 'page-inicio':'Início','page-turmas':'Turmas','page-atividades':'Atividades','page-alunos':'Alunos','page-progresso':'Progresso' };
    b.classList.toggle('active', b.textContent.trim().includes(map[pageId]||'__'));
  });
  window.scrollTo(0,0);
}

function openModal(id) { document.getElementById(id)?.classList.add('open'); }
function closeModal(id) { document.getElementById(id)?.classList.remove('open'); }

document.querySelectorAll('.modal-overlay').forEach(m => {
  m.addEventListener('click', e => { if (e.target===m) m.classList.remove('open'); });
});

function copiarCodigo(codigo, btn) {
  navigator.clipboard?.writeText(codigo).catch(()=>{});
  const orig = btn.innerHTML;
  btn.innerHTML = '✅ Copiado!';
  btn.classList.add('copied');
  setTimeout(()=>{ btn.innerHTML=orig; btn.classList.remove('copied'); }, 2000);
  showToast(`✅ Código ${codigo} copiado!`);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2800);
}

// Init
renderTurmasGrid('turmas-home');
renderTurmasGrid('turmas-lista');
</script>
</body>
</html>
