<script>
const titles={
dashboard:'🏠 Início',
turmas:'🌱 Minhas Turmas',
'turma-detalhe':'🦋 Turma das Borboletas',
atividades:'📋 Atividades',
alunos:'👦 Alunos',
'aluno-perfil':'👤 Perfil do Aluno',
progresso:'📊 Progresso'
};

function showPage(id){
document.querySelectorAll('article.page').forEach(p=>p.classList.remove('active'));
document.querySelectorAll('nav article').forEach(n=>n.classList.remove('active'));
const page=document.getElementById('page-'+id);
if(page)page.classList.add('active');
const navItem=document.getElementById('nav-'+id);
if(navItem)navItem.classList.add('active');
const titleEl=document.querySelector('main>header h1');
if(titleEl&&titles[id])titleEl.textContent=titles[id];
window.scrollTo(0,0);
}

function openModal(id){
document.getElementById(id).classList.add('open');
}

function closeModal(id){
document.getElementById(id).classList.remove('open');
}

document.querySelectorAll('dialog').forEach(modal=>{
modal.addEventListener('click',function(e){
if(e.target===modal)modal.classList.remove('open');
});
});

function switchTab(tab){
if(tab==='alunos'){
document.getElementById('tab-alunos').style.display='block';
document.getElementById('tab-atividades').style.display='none';
document.getElementById('tab-alunos-btn').className='btn btn-primary btn-sm';
document.getElementById('tab-ativs-btn').className='btn btn-ghost btn-sm';
}else{
document.getElementById('tab-alunos').style.display='none';
document.getElementById('tab-atividades').style.display='block';
document.getElementById('tab-alunos-btn').className='btn btn-ghost btn-sm';
document.getElementById('tab-ativs-btn').className='btn btn-primary btn-sm';
}
}
</script>
