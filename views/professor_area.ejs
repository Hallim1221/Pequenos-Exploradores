<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Área do Professor — Pequenos Exploradores</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600&family=Nunito:wght@400;600;700&display=swap');

*{box-sizing:border-box;margin:0;padding:0;}
:root{
--green-dark:#2d7a2d;
--green-main:#4caf50;
--green-light:#6ec96e;
--green-pale:#e8f5e9;
--green-mint:#c8e6c9;
--amber:#ff9800;
--amber-light:#fff3e0;
--blue:#1976d2;
--blue-light:#e3f2fd;
--bg:#f0f7f0;
--white:#ffffff;
--text:#1b3a1b;
--text-muted:#5a7a5a;
--radius:16px;
--radius-sm:10px;
--shadow:0 4px 20px rgba(76,175,80,0.15);
--shadow-card:0 2px 12px rgba(0,0,0,0.08);
}

body{
font-family:'Fredoka',sans-serif;
background:var(--bg);
min-height:100vh;
color:var(--text);
display:flex;
min-height:100vh;
}

/* ===== SIDEBAR ===== */
aside{
width:240px;
min-width:240px;
background:var(--green-dark);
display:flex;
flex-direction:column;
padding:0;
position:fixed;
top:0;left:0;
height:100vh;
z-index:100;
}

aside>header{
background:var(--green-main);
padding:20px 16px;
display:flex;
align-items:center;
gap:10px;
}

aside header span:first-child{
width:44px;height:44px;
background:white;
border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:22px;
}

aside header span:last-child{
color:white;
font-size:16px;
font-weight:600;
line-height:1.2;
}

aside>nav{
padding:16px 0;
flex:1;
}

nav section{
padding:6px 16px 4px;
font-size:11px;
color:rgba(255,255,255,0.45);
letter-spacing:0.08em;
text-transform:uppercase;
font-weight:500;
}

nav article{
display:flex;
align-items:center;
gap:10px;
padding:11px 20px;
color:rgba(255,255,255,0.75);
cursor:pointer;
font-size:15px;
font-weight:500;
border-left:3px solid transparent;
transition:all 0.18s;
margin:1px 0;
}

nav article:hover{background:rgba(255,255,255,0.1);color:white;}
nav article.active{
background:rgba(255,255,255,0.15);
color:white;
border-left-color:#a5d6a7;
}

nav article span:first-child{font-size:18px;width:22px;text-align:center;}

aside>footer{
padding:16px;
border-top:1px solid rgba(255,255,255,0.1);
}

footer article{
background:rgba(255,255,255,0.12);
border-radius:var(--radius-sm);
padding:12px;
display:flex;
align-items:center;
gap:10px;
}

footer article span{
width:36px;height:36px;
background:#a5d6a7;
border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:16px;color:var(--green-dark);font-weight:600;
}

footer article header{
flex:1;
}

footer article header p:first-child{color:white;font-size:14px;font-weight:600;}
footer article header p:last-child{color:rgba(255,255,255,0.55);font-size:12px;}

/* ===== MAIN CONTENT ===== */
main{
margin-left:240px;
flex:1;
display:flex;
flex-direction:column;
min-height:100vh;
}

/* ===== TOPBAR ===== */
main>header{
background:white;
border-bottom:1px solid #e8f5e9;
padding:0 32px;
height:64px;
display:flex;
align-items:center;
justify-content:space-between;
position:sticky;
top:0;
z-index:50;
}

main>header h1{
font-size:22px;
font-weight:600;
color:var(--green-dark);
display:flex;align-items:center;gap:8px;
margin:0;
}

main>header section{display:flex;align-items:center;gap:12px;}

button{
font-family:'Fredoka',sans-serif;
font-size:15px;
font-weight:500;
padding:9px 20px;
border-radius:50px;
border:none;
cursor:pointer;
display:inline-flex;
align-items:center;
gap:7px;
transition:all 0.18s;
}

.btn-primary{
background:var(--green-main);
color:white;
box-shadow:0 3px 10px rgba(76,175,80,0.35);
}
.btn-primary:hover{background:var(--green-dark);transform:translateY(-1px);}

.btn-ghost{
background:var(--green-pale);
color:var(--green-dark);
}
.btn-ghost:hover{background:var(--green-mint);}

.btn-amber{
background:var(--amber);
color:white;
box-shadow:0 3px 10px rgba(255,152,0,0.3);
}
.btn-amber:hover{background:#e65100;transform:translateY(-1px);}

.btn-sm{padding:6px 14px;font-size:13px;}

/* ===== PAGE CONTENT ===== */
main>section{
padding:28px 32px;
flex:1;
}

article.page{display:none;}
article.page.active{display:block;}

/* ===== STATS ROW ===== */
.stats-row{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:16px;
margin-bottom:28px;
}

.stat-card{
background:white;
border-radius:var(--radius);
padding:20px;
display:flex;
align-items:center;
gap:14px;
box-shadow:var(--shadow-card);
border:1.5px solid transparent;
transition:all 0.2s;
}
.stat-card:hover{border-color:var(--green-mint);transform:translateY(-2px);}

.stat-icon{
width:52px;height:52px;
border-radius:14px;
display:flex;align-items:center;justify-content:center;
font-size:24px;
flex-shrink:0;
}

.stat-icon.green{background:var(--green-pale);}
.stat-icon.amber{background:var(--amber-light);}
.stat-icon.blue{background:var(--blue-light);}
.stat-icon.pink{background:#fce4ec;}

.stat-card p:first-child{font-size:26px;font-weight:600;color:var(--green-dark);margin:0;}
.stat-card p:last-child{font-size:13px;color:var(--text-muted);margin:0;}

/* ===== SECTION HEADER ===== */
.section-header{
display:flex;align-items:center;justify-content:space-between;
margin-bottom:18px;
}

.section-title{
font-size:18px;font-weight:600;color:var(--green-dark);
display:flex;align-items:center;gap:8px;
}

/* ===== CLASS GRID ===== */
.classes-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
}

.class-card{
background:white;
border-radius:var(--radius);
padding:22px;
box-shadow:var(--shadow-card);
cursor:pointer;
border:2px solid transparent;
transition:all 0.2s;
position:relative;
overflow:hidden;
}

.class-card::before{
content:'';
position:absolute;
top:0;left:0;right:0;
height:5px;
background:var(--green-main);
}

.class-card:nth-child(2)::before{background:#ff9800;}
.class-card:nth-child(3)::before{background:#1976d2;}

.class-card:hover{
border-color:var(--green-light);
transform:translateY(-3px);
box-shadow:var(--shadow);
}

.class-card header{
display:flex;align-items:flex-start;justify-content:space-between;
margin-bottom:14px;
}

.class-card header span:first-child{font-size:36px;}

.class-card header span:last-child{
font-size:11px;
font-weight:600;
padding:3px 10px;
border-radius:50px;
background:var(--green-pale);
color:var(--green-dark);
}

.class-card h3{font-size:18px;font-weight:600;color:var(--text);margin-bottom:4px;}
.class-card p{font-size:13px;color:var(--text-muted);margin:0 0 14px 0;}

.class-card article{
display:flex;gap:16px;
padding-top:14px;
border-top:1px solid #f0f0f0;
}

.class-card article section{text-align:center;}
.class-card article p:first-child{font-size:18px;font-weight:600;color:var(--green-dark);margin:0;}
.class-card article p:last-child{font-size:12px;color:var(--text-muted);margin:0;}

.class-card footer{
margin-top:16px;
display:flex;gap:8px;
}

/* ===== STUDENTS TABLE ===== */
.students-table{
background:white;
border-radius:var(--radius);
box-shadow:var(--shadow-card);
overflow:hidden;
}

.students-table>header{
padding:18px 24px;
background:var(--green-pale);
display:flex;align-items:center;justify-content:space-between;
border-bottom:1px solid var(--green-mint);
}

.students-table h2{font-size:16px;font-weight:600;color:var(--green-dark);margin:0;}

.search-bar{
display:flex;align-items:center;gap:8px;
background:white;
border:1.5px solid var(--green-mint);
border-radius:50px;
padding:6px 14px;
font-family:'Fredoka',sans-serif;
font-size:14px;
color:var(--text);
width:220px;
}

.search-bar input{
border:none;outline:none;background:transparent;
font-family:'Fredoka',sans-serif;
font-size:14px;
color:var(--text);
width:100%;
}

table{width:100%;border-collapse:collapse;}

thead th{
padding:14px 24px;
text-align:left;
font-size:13px;
font-weight:600;
color:var(--text-muted);
background:#fafafa;
border-bottom:1px solid #f0f0f0;
}

tbody tr{
border-bottom:1px solid #f8f8f8;
cursor:pointer;
transition:background 0.15s;
}
tbody tr:hover{background:var(--green-pale);}
tbody tr:last-child{border-bottom:none;}

tbody td{padding:13px 24px;font-size:14px;}

/* ===== EMPTY STATE ===== */
.empty-state{
text-align:center;
padding:60px 32px;
background:white;
border-radius:var(--radius);
box-shadow:var(--shadow-card);
}

.empty-state h2{font-size:72px;margin:0 0 16px 0;}
.empty-state h3{font-size:22px;font-weight:600;color:var(--green-dark);margin-bottom:8px;}
.empty-state p{font-size:15px;color:var(--text-muted);margin-bottom:24px;}

/* ===== MODAL ===== */
dialog{
position:fixed;inset:0;
background:rgba(0,0,0,0.45);
z-index:999;
border:none;
padding:0;
max-width:500px;
display:none;
}

dialog.open{display:block;}

dialog::backdrop{background:rgba(0,0,0,0.45);}

dialog>article{
background:white;
border-radius:20px;
padding:32px;
width:100%;
box-shadow:0 20px 60px rgba(0,0,0,0.2);
animation:modalIn 0.22s ease;
}

@keyframes modalIn{
from{transform:translateY(30px);opacity:0;}
to{transform:translateY(0);opacity:1;}
}

dialog>article>header{
display:flex;align-items:center;justify-content:space-between;
margin-bottom:24px;
}

dialog h2{
font-size:20px;font-weight:600;color:var(--green-dark);
display:flex;align-items:center;gap:8px;
margin:0;
}

dialog button[type="button"]{
width:32px;height:32px;
border:none;background:#f5f5f5;
border-radius:50%;cursor:pointer;
font-size:16px;display:flex;align-items:center;justify-content:center;
transition:background 0.15s;
}
dialog button[type="button"]:hover{background:#e0e0e0;}

.form-group{margin-bottom:18px;}

label{
display:block;
font-size:13px;font-weight:600;
color:var(--text-muted);
margin-bottom:7px;
text-transform:uppercase;letter-spacing:0.05em;
}

input,select,textarea{
width:100%;
font-family:'Fredoka',sans-serif;
font-size:15px;
padding:11px 16px;
border:1.5px solid #e0e0e0;
border-radius:var(--radius-sm);
outline:none;
color:var(--text);
transition:border-color 0.15s;
background:#fafafa;
}
input:focus,select:focus,textarea:focus{border-color:var(--green-main);background:white;}

.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}

dialog footer{
display:flex;justify-content:flex-end;gap:10px;
margin-top:24px;padding-top:20px;
border-top:1px solid #f0f0f0;
}

/* ===== ATIVIDADES ===== */
.activities-list{display:flex;flex-direction:column;gap:14px;}

.activity-card{
background:white;
border-radius:var(--radius);
padding:20px 24px;
box-shadow:var(--shadow-card);
display:flex;align-items:center;gap:20px;
border-left:5px solid var(--green-main);
cursor:pointer;
transition:all 0.2s;
}
.activity-card:hover{box-shadow:var(--shadow);transform:translateX(3px);}
.activity-card.amber-border{border-left-color:var(--amber);}
.activity-card.blue-border{border-left-color:var(--blue);}

.activity-icon{
width:52px;height:52px;
border-radius:14px;
background:var(--green-pale);
display:flex;align-items:center;justify-content:center;
font-size:26px;
flex-shrink:0;
}

.activity-icon.amber{background:var(--amber-light);}
.activity-icon.blue{background:var(--blue-light);}

.activity-card>article{flex:1;}
.activity-card h3{font-size:16px;font-weight:600;color:var(--text);margin:0 0 4px 0;}
.activity-card p{font-size:13px;color:var(--text-muted);margin:0;}

.activity-points{
text-align:right;
}

.points-big{
font-size:24px;font-weight:700;color:var(--amber);
display:flex;align-items:center;gap:4px;
}

.points-label{font-size:12px;color:var(--text-muted);}

/* ===== ALUNO PERFIL ===== */
.profile-header{
background:linear-gradient(135deg,var(--green-dark),var(--green-main));
border-radius:var(--radius);
padding:28px;
color:white;
display:flex;align-items:center;gap:20px;
margin-bottom:24px;
}

.profile-avatar-big{
width:80px;height:80px;
background:rgba(255,255,255,0.25);
border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:36px;color:white;font-weight:700;
border:3px solid rgba(255,255,255,0.5);
flex-shrink:0;
}

.profile-header h2{font-size:24px;font-weight:700;margin:0 0 4px 0;}
.profile-header p{font-size:15px;opacity:0.8;margin:0;}

.profile-stats{
display:flex;gap:24px;
margin-left:auto;
text-align:center;
}

.profile-stat p:first-child{font-size:22px;font-weight:700;margin:0;}
.profile-stat p:last-child{font-size:12px;opacity:0.75;margin:0;}

.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;}

.detail-card{
background:white;
border-radius:var(--radius);
padding:22px;
box-shadow:var(--shadow-card);
}

.detail-card>header{
font-size:15px;font-weight:600;color:var(--text-muted);
margin-bottom:16px;text-transform:uppercase;letter-spacing:0.05em;
font-size:12px;
}

.activity-history-item{
display:flex;align-items:center;gap:12px;
padding:10px 0;
border-bottom:1px solid #f5f5f5;
}
.activity-history-item:last-child{border-bottom:none;}

.history-dot{
width:10px;height:10px;
border-radius:50%;
background:var(--green-main);
flex-shrink:0;
}
.history-dot.amber{background:var(--amber);}
.history-dot.blue{background:var(--blue);}

.activity-history-item p{
font-size:14px;font-weight:500;flex:1;margin:0;
}
.activity-history-item span{font-size:13px;color:var(--amber);font-weight:600;}

/* ===== PAGE HEADER ===== */
.page-hero{
background:white;
border-radius:var(--radius);
padding:24px 28px;
margin-bottom:24px;
box-shadow:var(--shadow-card);
display:flex;align-items:center;justify-content:space-between;
}

.page-hero article h2{font-size:20px;font-weight:600;color:var(--green-dark);margin:0;}
.page-hero article p{font-size:14px;color:var(--text-muted);margin-top:4px;}

.page-hero span{font-size:52px;}

/* ===== BREADCRUMB ===== */
.breadcrumb{
display:flex;align-items:center;gap:6px;
font-size:13px;color:var(--text-muted);
margin-bottom:20px;
}

.breadcrumb a{
color:var(--green-dark);text-decoration:none;cursor:pointer;font-weight:500;
}
.breadcrumb a:hover{text-decoration:underline;}
.breadcrumb span{color:#ccc;}

/* ===== BADGES & CHIPS ===== */
.badge{
display:inline-flex;align-items:center;gap:4px;
font-size:12px;font-weight:500;
padding:3px 10px;border-radius:50px;
}

.badge-green{background:var(--green-pale);color:var(--green-dark);}
.badge-amber{background:var(--amber-light);color:#e65100;}
.badge-blue{background:var(--blue-light);color:var(--blue);}

.points-chip{
display:inline-flex;align-items:center;gap:5px;
background:var(--amber-light);
color:#bf360c;
font-size:13px;font-weight:600;
padding:4px 12px;border-radius:50px;
}

.progress-bar{
width:100px;height:8px;
background:#f0f0f0;
border-radius:4px;
overflow:hidden;
display:inline-block;
}

.progress-fill{
height:100%;
background:var(--green-main);
border-radius:4px;
}

.progress-fill.amber{background:var(--amber);}
.progress-fill.low{background:#ef5350;}

/* ===== TURMA DETAIL ===== */
.turma-header{
background:white;
border-radius:var(--radius);
padding:24px 28px;
margin-bottom:24px;
box-shadow:var(--shadow-card);
display:flex;align-items:center;gap:20px;
}

.turma-emoji{
width:64px;height:64px;
background:var(--green-pale);
border-radius:16px;
display:flex;align-items:center;justify-content:center;
font-size:32px;
}

/* ===== RESPONSIVE ===== */
@media(max-width:1100px){
.classes-grid{grid-template-columns:repeat(2,1fr);}
.stats-row{grid-template-columns:repeat(2,1fr);}
}

/* ===== ANIMATIONS ===== */
article.page.active{animation:fadeIn 0.2s ease;}
@keyframes fadeIn{
from{opacity:0;transform:translateY(10px);}
to{opacity:1;transform:translateY(0);}
}

.fab{
position:fixed;
bottom:28px;right:28px;
width:56px;height:56px;
background:var(--green-main);
border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:26px;
box-shadow:0 6px 20px rgba(76,175,80,0.4);
cursor:pointer;
border:none;
color:white;
transition:all 0.2s;
z-index:90;
}
.fab:hover{background:var(--green-dark);transform:scale(1.1);}
</style>
</head>
<body>

<h2 style="position:absolute;left:-9999px;">Área do Professor — Pequenos Exploradores</h2>

<!-- SIDEBAR -->
<aside>
<header>
<img src="/img/log.png" alt="Logo Pequenos Exploradores" style="width:54px;height:54px;object-fit:contain;">
<span>Pequenos<br>Exploradores</span>
</header>
<nav>
<section>Principal</section>
<article class="active" onclick="showPage('dashboard')" id="nav-dashboard">
<span>🏠</span> Início
</article>
<article onclick="showPage('turmas')" id="nav-turmas">
<span>🌱</span> Minhas Turmas
</article>
<section>Gerenciar</section>
<article onclick="showPage('atividades')" id="nav-atividades">
<span>📋</span> Atividades
</article>
<article onclick="showPage('alunos')" id="nav-alunos">
<span>👦</span> Alunos
</article>
<section>Relatórios</section>
<article onclick="showPage('progresso')" id="nav-progresso">
<span>📊</span> Progresso
</article>
</nav>
<footer>
<article>
<span>MA</span>
<header>
<p>Profª Maria</p>
<p>Professora</p>
</header>
</article>
</footer>
</aside>

<!-- MAIN -->
<main>
<header id="page-title">
<h1>🏠 Início</h1>
<section>
<button class="btn btn-ghost btn-sm" onclick="openModal('modal-atividade')">＋ Nova Atividade</button>
<button class="btn btn-primary btn-sm" onclick="openModal('modal-turma')">＋ Nova Turma</button>
</section>
</header>

<section>

<!-- DASHBOARD -->
<article class="page active" id="page-dashboard">
<section class="page-hero">
<article>
<h2>Bom dia, Profª Maria! 🌤️</h2>
<p>Veja o resumo das suas turmas e atividades recentes.</p>
</article>
<span>🌳</span>
</section>

<section class="stats-row">
<article class="stat-card">
<span class="stat-icon green">🌱</span>
<p>3</p>
<p>Turmas ativas</p>
</article>
<article class="stat-card">
<span class="stat-icon amber">👦</span>
<p>72</p>
<p>Alunos no total</p>
</article>
<article class="stat-card">
<span class="stat-icon blue">📋</span>
<p>18</p>
<p>Atividades enviadas</p>
</article>
<article class="stat-card">
<span class="stat-icon pink">⭐</span>
<p>1.240</p>
<p>Pontos distribuídos</p>
</article>
</section>

<section class="section-header">
<h2 class="section-title">🌻 Minhas Turmas</h2>
<button class="btn btn-ghost btn-sm" onclick="showPage('turmas')">Ver todas →</button>
</section>

<section class="classes-grid">
<article class="class-card" onclick="showPage('turma-detalhe')">
<header>
<span>🦋</span>
<span>3° Ano A</span>
</header>
<h3>Turma das Borboletas</h3>
<p>Ensino Fundamental I</p>
<article>
<section><p>24</p><p>Alunos</p></section>
<section><p>7</p><p>Atividades</p></section>
<section><p>89%</p><p>Engajamento</p></section>
</article>
<footer>
<button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();showPage('turma-detalhe')">Ver turma</button>
<button class="btn btn-ghost btn-sm" onclick="event.stopPropagation();openModal('modal-aluno')">＋ Aluno</button>
</footer>
</article>

<article class="class-card" onclick="showPage('turma-detalhe')">
<header>
<span>🐸</span>
<span style="background:#fff3e0;color:#e65100;">2° Ano B</span>
</header>
<h3>Turma dos Sapos</h3>
