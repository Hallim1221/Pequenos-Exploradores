  // Atualiza o nome da turma no header do modal
  document.querySelector('#turma-nome-modal').textContent = `${turma.emoji} ${turma.nome}`;

  // Abre o modal
  openModal('modal-add-aluno');
  
  // Foca no primeiro campo de input
  setTimeout(() => {
    document.querySelector('#aluno-nome-input')?.focus();
