  }

  // Seta a turma atual
  TURMA_ATUAL_ID = numId;

  // Limpa os campos do formulário
  document.querySelector('#aluno-nome-input').value = '';
  document.querySelector('#aluno-email-input').value = '';
  document.querySelector('#aluno-senha-input').value = '';
