<script>
const LEVELS = {
  1: {
    emoji: '🌍',
    title: 'Descobrindo o Meio Ambiente',
    desc: 'Dê os primeiros passos no mundo natural! Aprenda o que é o meio ambiente e conheça a água, a terra, os animais e as florestas.',
    tier: '🥉 Bronze',
    pts: '⭐ 100 pts',
    heroColors: ['#4e342e', '#a1887f'],
    topics: [
      { icon: '🌍', name: 'O que é o Meio Ambiente' },
      { icon: '💧', name: 'Água' },
      { icon: '🪨', name: 'Terra (solo)' },
      { icon: '🐾', name: 'Animais' },
      { icon: '🌳', name: 'Florestas' },
    ]
  },
  2: {
    emoji: '💧',
    title: 'Elementos da Natureza',
    desc: 'Explore os elementos que formam a natureza: tipos de água, as partes das plantas, os habitats dos animais e muito mais!',
    tier: '🥉 Bronze',
    pts: '⭐ 150 pts',
    heroColors: ['#0d47a1', '#29b6f6'],
    topics: [
      { icon: '🌊', name: 'Tipos de água (doce e salgada)' },
      { icon: '🌱', name: 'Plantas (partes e funções)' },
      { icon: '🦒', name: 'Animais e seus habitats' },
      { icon: '🌤️', name: 'Clima (sol, chuva, vento)' },
      { icon: '🔄', name: 'Ciclo da água (básico)' },
    ]
  },
  3: {
    emoji: '🌿',
    title: 'Conexões da Natureza',
    desc: 'Descubra como todos os seres vivos estão conectados e o que podemos fazer para proteger essa rede incrível!',
    tier: '🥉 Bronze',
    pts: '⭐ 200 pts',
    heroColors: ['#1b5e20', '#43a047'],
    topics: [
      { icon: '🦁', name: 'Cadeia alimentar' },
      { icon: '🤝', name: 'Relação entre seres vivos' },
      { icon: '🌳', name: 'Importância das árvores' },
      { icon: '🏭', name: 'Poluição (introdução)' },
      { icon: '💚', name: 'Cuidados com o meio ambiente' },
    ]
  }
};

function showPage(id) {
  document.querySelectorAll('section.page').forEach(p => p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

function showLevel(num) {
  const data = LEVELS[num];
  if (!data) return;

  document.getElementById('detail-emoji').textContent = data.emoji;
  document.getElementById('detail-lvlnum').textContent = 'Nível ' + num + ' · ' + data.tier.replace(/[^\w\s·]/g,'').trim();
  document.getElementById('detail-title').textContent = data.title;
  document.getElementById('detail-desc').textContent = data.desc;
  document.getElementById('detail-topics-count').textContent = data.topics.length + ' tópicos';
  document.getElementById('detail-pts-chip').textContent = data.pts;
  document.getElementById('detail-tier-chip').textContent = data.tier;
  document.getElementById('detail-breadcrumb').textContent = 'Níveis / Nível ' + num;

  const hero = document.getElementById('detail-hero-bg');
  hero.style.background = 'linear-gradient(135deg, ' + data.heroColors[0] + ', ' + data.heroColors[1] + ')';

  const grid = document.getElementById('topics-grid');
  grid.innerHTML = '';
  data.topics.forEach(t => {
    const card = document.createElement('article');
    card.className = 'topic-card';
    card.innerHTML = '<span class="topic-icon">' + t.icon + '</span><p class="topic-name">' + t.name + '</p>';
    card.onclick = () => showPage('page-curiosidades');
    grid.appendChild(card);
  });

  showPage('page-level');
}

function showLocked() {
  alert('🔒 Este nível ainda está bloqueado! Continue avançando para desbloqueá-lo.');
}
</script>

