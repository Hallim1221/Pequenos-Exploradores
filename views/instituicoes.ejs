// Função para carregar turmas reais do banco de dados
async function carregarTurmasReais() {
  try {
    // Usar instituição_id em vez de professor_id
    let instituicaoId = document.body.dataset.instituicaoId || localStorage.getItem('instituicaoId') || '1';
    const hiddenInput = document.querySelector('[data-instituicao-id]');
    if (hiddenInput) instituicaoId = hiddenInput.dataset.instituicaoId;
    
    console.log('📚 Carregando turmas da instituição:', instituicaoId);
    const response = await fetch(`/api/instituicoes/${instituicaoId}/turmas`);
    const data = await response.json();
    const container = document.getElementById('turmas-reais');
    
    if (!container) return;
    if (!data.turmas || data.turmas.length === 0) {
      container.innerHTML = '<p style="text-align:center; color: #888; padding: 40px;">Nenhuma turma cadastrada. Clique em "Cadastrar turma ➕" para criar uma.</p>';
      return;
    }
    
    container.innerHTML = '';
    data.turmas.forEach(turma => {
      const turmaDom = document.createElement('section');
      turmaDom.className = 'turma-item';
      turmaDom.id = `turma-${turma.id}`;
      turmaDom.innerHTML = `
        <section class="turma-item-left" onclick="carregarAlunos(${turma.id}, '${turma.nome.replace(/'/g, "\\'")}')">
          <section class="turma-item-icon">📚</section>
          <section>
            <section class="turma-item-name">${turma.nome || 'Sem nome'}</section>
            <section class="turma-item-meta">${turma.total_alunos || 0} alunos · ${turma.ano_escolar || 'N/A'} · 2025</section>
          </section>
        </section>
        <section class="turma-item-actions">
          <button class="btn-icon" title="Adicionar Aluno" onclick="editarTurma(${turma.id}, '${turma.nome.replace(/'/g, "\\'")}')">➕</button>
          <button class="btn-icon danger" title="Remover" onclick="removerTurma(${turma.id})">🗑️</button>
        </section>
      `;
      container.appendChild(turmaDom);
    });
  } catch (erro) {
    console.error('Erro ao carregar turmas:', erro);
  }
}

// Função para carregar dados reais do painel da escola
async function carregarDadosPainel() {
  try {
    let instituicaoId = document.body.dataset.instituicaoId || localStorage.getItem('instituicaoId') || '1';
    const hiddenInput = document.querySelector('[data-instituicao-id]');
    if (hiddenInput) instituicaoId = hiddenInput.dataset.instituicaoId;
    
    console.log('📊 Carregando dados do painel para instituição:', instituicaoId);
    
    // Buscar alunos
    const resAlunos = await fetch(`/api/instituicoes/${instituicaoId}/alunos`);
    const dataAlunos = await resAlunos.json();
    const totalAlunos = dataAlunos.alunos ? dataAlunos.alunos.length : 0;
    
    // Buscar professores
    const resProfessores = await fetch(`/api/instituicoes/${instituicaoId}/professores`);
    const dataProfessores = await resProfessores.json();
    const totalProfessores = dataProfessores.professores ? dataProfessores.professores.length : 0;
    
    // Buscar turmas
    const resTurmas = await fetch(`/api/instituicoes/${instituicaoId}/turmas`);
    const dataTurmas = await resTurmas.json();
    const totalTurmas = dataTurmas.turmas ? dataTurmas.turmas.length : 0;
    
    // Calcular desempenho médio das turmas
    let desempenhoMedio = 0;
    if (dataTurmas.turmas && dataTurmas.turmas.length > 0) {
      const desempenhos = dataTurmas.turmas.map(t => t.desempenho || 75).reduce((a, b) => a + b, 0);
      desempenhoMedio = Math.round(desempenhos / dataTurmas.turmas.length);
    }
    
    // Atualizar elementos no DOM
    const statBoxes = document.querySelectorAll('.stat-box');
    if (statBoxes.length >= 4) {
      // Alunos Ativos
      const alunosBox = statBoxes[0].querySelector('.s-num');
      if (alunosBox) alunosBox.textContent = totalAlunos;
      
      // Professores
      const professoresBox = statBoxes[1].querySelector('.s-num');
      if (professoresBox) professoresBox.textContent = totalProfessores;
      
      // Turmas Cadastradas
      const turmasBox = statBoxes[2].querySelector('.s-num');
      if (turmasBox) turmasBox.textContent = totalTurmas;
      
      // Desempenho Geral
      const desempenhoBox = statBoxes[3].querySelector('.s-num');
      if (desempenhoBox) desempenhoBox.textContent = desempenhoMedio + '%';
    }
    
  } catch (erro) {
    console.error('Erro ao carregar dados do painel:', erro);
  }
}

// Variável para rastrear última mensagem
let ultimaMensagemId = null;
let intervaloChat = null;

// Função para carregar chat da gestão com o admin
async function carregarChatGestao() {
  try {
    let instituicaoId = document.body.dataset.instituicaoId || localStorage.getItem('instituicaoId') || '1';
    const hiddenInput = document.querySelector('[data-instituicao-id]');
    if (hiddenInput) instituicaoId = hiddenInput.dataset.instituicaoId;
    
    console.log('💬 Carregando chat da instituição:', instituicaoId);
    
    // Buscar mensagens do servidor
    const response = await fetch(`/api/parcerias/${instituicaoId}/mensagens`);
    const data = await response.json();
    
    const container = document.getElementById('chat-messages-container');
    if (!container) return;
    
    // Limpar container apenas na primeira carga
    if (container.innerHTML.includes('Nenhuma mensagem')) {
      container.innerHTML = '';
    }
    
    if (!data.mensagens || data.mensagens.length === 0) {
      if (container.innerHTML === '') {
        container.innerHTML = `
          <section style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;">
            <section style="font-size:48px;">💬</section>
            <section style="font-size:14px;color:#5a9a72;text-align:center;">
              Nenhuma mensagem ainda. Comece uma conversa com nosso especialista!
            </section>
          </section>
        `;
      }
      return;
    }
    
    // Se é a primeira carga, renderizar todas as mensagens
    if (ultimaMensagemId === null && container.innerHTML === '') {
      data.mensagens.forEach(msg => {
        renderizarMensagem(msg, container);
        ultimaMensagemId = msg.id;
      });
    } else {
      // Se não é a primeira carga, verificar novas mensagens
      const mensagensExistentes = container.querySelectorAll('section[style*="align-self"]').length;
      if (data.mensagens.length > mensagensExistentes) {
        // Novas mensagens chegaram
        const novasMensagens = data.mensagens.slice(mensagensExistentes);
        novasMensagens.forEach(msg => {
          renderizarMensagem(msg, container);
        });
      }
    }
    
    // Scroll para o final
    container.scrollTop = container.scrollHeight;
    
    // Iniciar polling se ainda não foi iniciado
    if (intervaloChat === null) {
      iniciarPollingChat(instituicaoId);
    }
    
  } catch (erro) {
    console.error('Erro ao carregar chat:', erro);
  }
}

// Função para renderizar uma mensagem
function renderizarMensagem(msg, container) {
  const isBot = msg.remetente === 'admin' || msg.remetente === 'bot';
  const msgEl = document.createElement('section');
  msgEl.style.cssText = isBot 
    ? 'align-self:flex-start;background:white;border:1.5px solid #d4f0de;border-bottom-left-radius:4px;border-radius:16px;padding:12px 16px;max-width:75%;font-size:14px;color:#333;line-height:1.5;'
    : 'align-self:flex-end;background:linear-gradient(135deg,#2d8a4e,#3aad60);border-radius:16px;border-bottom-right-radius:4px;padding:12px 16px;max-width:75%;font-size:14px;color:white;line-height:1.5;';
  
  msgEl.innerHTML = msg.conteudo;
  msgEl.dataset.msgId = msg.id;
  container.appendChild(msgEl);
}

// Função para iniciar polling
function iniciarPollingChat(instituicaoId) {
  intervaloChat = setInterval(async () => {
    try {
      const response = await fetch(`/api/parcerias/${instituicaoId}/mensagens`);
      const data = await response.json();
      
      const container = document.getElementById('chat-messages-container');
      if (!container) return;
      
      if (data.mensagens && data.mensagens.length > 0) {
        // Verificar se existem mensagens novas
        const mensagensExistentes = container.querySelectorAll('section[style*="align-self"]');
        if (data.mensagens.length > mensagensExistentes.length) {
          // Novas mensagens chegaram
          const novasMensagens = data.mensagens.slice(mensagensExistentes.length);
          novasMensagens.forEach(msg => {
            renderizarMensagem(msg, container);
          });
          
          // Scroll para o final
          container.scrollTop = container.scrollHeight;
          
          console.log('✅ Nova mensagem recebida!');
        }
      }
    } catch (erro) {
      console.error('Erro ao verificar mensagens:', erro);
    }
  }, 2000); // Verificar a cada 2 segundos
}

// Função para parar o polling
function pararPollingChat() {
  if (intervaloChat !== null) {
    clearInterval(intervaloChat);
    intervaloChat = null;
  }
}

// Função para enviar mensagem
async function enviarMensagemChat() {
  const input = document.getElementById('chat-input');
  const mensagem = input.value.trim();
  
  if (!mensagem) return;
  
  try {
    let instituicaoId = document.body.dataset.instituicaoId || localStorage.getItem('instituicaoId') || '1';
    const hiddenInput = document.querySelector('[data-instituicao-id]');
    if (hiddenInput) instituicaoId = hiddenInput.dataset.instituicaoId;
    
    // Adicionar mensagem do usuário ao chat imediatamente
    const container = document.getElementById('chat-messages-container');
    if (container && container.innerHTML.includes('Nenhuma mensagem')) {
      container.innerHTML = '';
    }
    
    if (container) {
      const msgEl = document.createElement('section');
      msgEl.style.cssText = 'align-self:flex-end;background:linear-gradient(135deg,#2d8a4e,#3aad60);border-radius:16px;border-bottom-right-radius:4px;padding:12px 16px;max-width:75%;font-size:14px;color:white;line-height:1.5;';
      msgEl.innerHTML = mensagem;
      container.appendChild(msgEl);
      container.scrollTop = container.scrollHeight;
    }
    
    // Enviar mensagem ao servidor
    const response = await fetch(`/api/parcerias/${instituicaoId}/mensagens`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        conteudo: mensagem,
        remetente: 'usuario'
      })
    });
    
    if (!response.ok) {
      console.error('Erro ao enviar mensagem:', response.statusText);
      return;
    }
    
    // Limpar input
    input.value = '';
    
  } catch (erro) {
    console.error('Erro ao enviar mensagem:', erro);
  }
}

</script>

