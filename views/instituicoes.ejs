<script>
// Funções básicas definidas no início para uso nos onclick handlers
function goTo(id){
  // Parar polling ao sair do chat
  if (id !== 'instituicoes-alunos') {
    pararPollingChat();
  }
  
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
  if (id === 'cadastrar' && typeof carregarTurmasReais === 'function') {
    setTimeout(() => carregarTurmasReais(), 100);
  }
  if (id === 'instituicoes-alunos' && typeof carregarChatGestao === 'function') {
    setTimeout(() => carregarChatGestao(), 100);
  }
  if (id === 'painel' && typeof carregarDadosPainel === 'function') {
    setTimeout(() => carregarDadosPainel(), 100);
  }
}
function openModal(){document.getElementById('modalTurma').classList.add('open');}
function closeModal(){document.getElementById('modalTurma').classList.remove('open');}
function abrirModalExclusao(turmaId){document.getElementById('modalConfirmarExclusao').classList.add('open');window.turmaIdParaExcluir=turmaId;}
function fecharModalExclusao(){document.getElementById('modalConfirmarExclusao').classList.remove('open');window.turmaIdParaExcluir=null;}
function confirmarExclusao(){const turmaId=window.turmaIdParaExcluir;if(!turmaId)return;fecharModalExclusao();fetch(`/api/turmas/${turmaId}`,{method:'DELETE',headers:{'Content-Type':'application/json'}}).then(res=>res.json()).then(data=>{if(data.success){alert('✓ Turma removida com sucesso!');document.getElementById(`turma-${turmaId}`)?.remove();carregarTurmasReais();}else{alert('❌ Erro ao remover turma: '+(data.message||'Tente novamente'));}}).catch(err=>console.error('Erro:',err)||alert('❌ Erro ao remover turma!'));}
function openMembro(){document.getElementById('modalMembro').classList.add('open');}
function closeMembro(){document.getElementById('modalMembro').classList.remove('open');}
function openAluno(){document.getElementById('modalAluno').classList.add('open');}
function closeAluno(){document.getElementById('modalAluno').classList.remove('open'); document.getElementById('formAdicionarAluno').reset(); document.getElementById('mensagemAluno').style.display='none';}
function abrirModalLogoutEquipe() {var modal = document.getElementById('modal-logout-equipe'); if(modal) modal.style.display = 'flex';}
function fecharModalLogoutEquipe() {var modal = document.getElementById('modal-logout-equipe'); if(modal) modal.style.display = 'none';}
function confirmarLogoutEquipe() {window.location.href = '/logout';}

// Função para cadastrar turma
function cadastrarTurma() {
  const nomeTurma = document.getElementById('turma-nome')?.value.trim();
  const anoLetivo = '2025'; // Ano letivo automático
  const serie = document.getElementById('turma-serie')?.value;
  const professorId = '1'; // Usar ID fixo por enquanto
  
  if (!nomeTurma || !serie) {
    alert('Por favor, preencha todos os campos obrigatórios');
    return;
  }
  
  fetch('/api/turmas', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({nome: nomeTurma, ano_escolar: serie, professor_id: professorId})
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      alert('✓ Turma cadastrada com sucesso!');
      document.getElementById('turma-nome').value = '';
      document.getElementById('turma-serie').value = '';
      closeModal();
      carregarTurmasReais();
    } else {
      alert('Erro ao cadastrar turma: ' + (data.message || 'Tente novamente'));
    }
  })
  .catch(err => {
    console.error('Erro:', err);
    alert('Erro ao cadastrar turma');
  });
}

// Função para editar turma - abrir modal para cadastrar novo aluno
function editarTurma(turmaId, turmaNome) {
  const modal = document.createElement('div');
  modal.className = 'modal-overlay open';
  modal.id = 'modalCadastrarAluno-' + turmaId;
  modal.innerHTML = `
    <section class="modal">
      <h2>👤 Cadastrar Novo Aluno</h2>
      <p>Cadastre um aluno para: <strong>${turmaNome}</strong></p>
      <div id="mensagemCadastroAluno" style="display:none; margin-bottom:1em; padding:0.8em; border-radius:6px; font-weight:600;"></div>
      <section class="form-group">
        <label>Nome do Aluno</label>
        <input type="text" id="input-nome-aluno-${turmaId}" placeholder="Ex: João Silva" />
      </section>
      <section class="form-group">
        <label>E-mail</label>
        <input type="email" id="input-email-aluno-${turmaId}" placeholder="aluno@email.com" />
      </section>
      <section class="form-group">
        <label>Senha</label>
        <input type="password" id="input-senha-aluno-${turmaId}" placeholder="Crie uma senha" />
      </section>
      <section class="form-group">
        <label>Confirmar Senha</label>
        <input type="password" id="input-confirmar-aluno-${turmaId}" placeholder="Confirme a senha" />
      </section>
      <section class="modal-actions">
        <button class="btn-cancel" onclick="document.getElementById('modalCadastrarAluno-${turmaId}').remove()">Cancelar</button>
        <button class="btn-confirm" onclick="confirmarCadastrarAluno(${turmaId}, '${turmaNome}')">Cadastrar ✓</button>
      </section>
    </section>
  `;
  document.body.appendChild(modal);
}

// Função para confirmar cadastro de novo aluno
function confirmarCadastrarAluno(turmaId, turmaNome) {
  const nome = document.getElementById(`input-nome-aluno-${turmaId}`)?.value?.trim();
  const email = document.getElementById(`input-email-aluno-${turmaId}`)?.value?.trim();
  const senha = document.getElementById(`input-senha-aluno-${turmaId}`)?.value;
  const confirmarSenha = document.getElementById(`input-confirmar-aluno-${turmaId}`)?.value;
  
  if (!nome || !email || !senha || !confirmarSenha) {
    alert('⚠️ Preencha todos os campos!');
    return;
  }
  
  if (senha !== confirmarSenha) {
    alert('⚠️ As senhas não conferem!');
    return;
  }
  
  if (senha.length < 6) {
    alert('⚠️ A senha deve ter no mínimo 6 caracteres!');
    return;
  }
  
  fetch(`/api/instituicoes/criar-aluno-turma`, {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({
      nome,
      email,
      password: senha,
      turma_id: turmaId
    })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success) {
      alert('✓ ' + (data.message || 'Aluno cadastrado com sucesso!'));
      document.getElementById(`modalCadastrarAluno-${turmaId}`)?.remove();
    } else {
      alert('❌ Erro ao cadastrar aluno: ' + (data.message || 'Tente novamente'));
    }
  })
  .catch(err => {
    console.error('Erro:', err);
    alert('❌ Erro ao cadastrar aluno!');
  });
}

// Função para carregar e exibir alunos de uma turma
async function carregarAlunos(turmaId, turmaNome) {
  try {
    const response = await fetch(`/api/turmas/${turmaId}/alunos`);
    const data = await response.json();
    
    if (!data.success) {
      alert('❌ Erro ao carregar alunos: ' + (data.message || 'Tente novamente'));
      return;
    }
    
    const alunos = data.alunos || [];
    
    // Criar modal com lista de alunos
    const modal = document.createElement('div');
    modal.className = 'modal-overlay open';
    modal.id = 'modalAlunosTurma-' + turmaId;
    
    let alunosHtml = '';
    if (alunos.length === 0) {
      alunosHtml = '<p style="text-align:center; color:#888; padding:20px;">Nenhum aluno cadastrado nesta turma</p>';
    } else {
      alunosHtml = '<div style="max-height:400px; overflow-y:auto;">';
      alunos.forEach((aluno, idx) => {
        alunosHtml += `
          <div style="padding:12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
            <div>
              <div style="font-weight:600; color:#333;">${aluno.nome || 'N/A'}</div>
              <div style="font-size:12px; color:#666;">${aluno.email || 'N/A'}</div>
            </div>
          </div>
        `;
      });
      alunosHtml += '</div>';
    }
    
    modal.innerHTML = `
      <section class="modal">
        <h2>👥 Alunos da Turma: ${turmaNome}</h2>
        <p style="color:#666; margin-bottom:1em;">Total de alunos: <strong>${alunos.length}</strong></p>
        ${alunosHtml}
        <section class="modal-actions">
          <button class="btn-cancel" onclick="document.getElementById('modalAlunosTurma-${turmaId}').remove()">Fechar</button>
          <button class="btn-confirm" onclick="editarTurma(${turmaId}, '${turmaNome.replace(/'/g, "\\'")}')">➕ Adicionar Aluno</button>
        </section>
      </section>
    `;
    document.body.appendChild(modal);
  } catch (erro) {
    console.error('Erro ao carregar alunos:', erro);
    alert('❌ Erro ao carregar alunos');
  }
}

