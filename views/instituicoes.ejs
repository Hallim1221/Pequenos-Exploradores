        <section class="info-row"><span class="lbl">Ano Letivo</span><span class="val">2025</span></section>
        <section class="info-row"><span class="lbl">Status</span><span class="dval" style="color:#2d8a4e;">✅ Ativa</span></section>
      </section>
      <section class="card">
        <section class="section-title">📈 Desempenho por Turma</section>
        <section class="chart-bars">
          <section class="bar-col"><section class="bar-val">90%</section><section class="bar" style="height:108px;"></section><section class="bar-label">5ª B</section></section>
          <section class="bar-col"><section class="bar-val">85%</section><section class="bar" style="height:102px;"></section><section class="bar-label">1ª B</section></section>
          <section class="bar-col"><section class="bar-val">75%</section><section class="bar" style="height:90px;"></section><section class="bar-label">4ª B</section></section>
          <section class="bar-col"><section class="bar-val">88%</section><section class="bar" style="height:105px;"></section><section class="bar-label">2ª A</section></section>
          <section class="bar-col"><section class="bar-val">72%</section><section class="bar" style="height:86px;"></section><section class="bar-label">3ª C</section></section>
        </section>
      </section>
