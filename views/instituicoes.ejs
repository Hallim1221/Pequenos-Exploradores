
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Fredoka:wght@400;500;600&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Fredoka',sans-serif;background:#f0faf4;min-height:100vh;margin-top:72px;}

/* PAGES */
.page{display:none;min-height:100vh;flex-direction:column;}
.page.active{display:flex;}

/* NAVBAR */
.navbar{background:linear-gradient(135deg,#2d8a4e,#3aad60);padding:0 40px;height:68px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 16px rgba(45,138,78,0.25);flex-shrink:0;}
.logo{display:flex;align-items:center;gap:10px;font-family:'Fredoka One',cursive;font-size:20px;color:white;cursor:pointer;}
.logo-circle{width:40px;height:40px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;border:2px solid rgba(255,255,255,0.4);}
.nav-links{display:flex;gap:4px;align-items:center;}
.nav-link{color:rgba(255,255,255,0.9);font-size:16px;font-weight:500;padding:7px 16px;border-radius:50px;cursor:pointer;transition:all 0.2s;border:none;background:none;font-family:'Fredoka',sans-serif;}
.nav-link:hover,.nav-link.active{background:rgba(255,255,255,0.25);color:white;}
.btn-sair{background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.5);color:white;font-family:'Fredoka',sans-serif;font-size:15px;font-weight:600;padding:6px 20px;border-radius:50px;cursor:pointer;transition:all 0.2s;}
.btn-sair:hover{background:rgba(255,255,255,0.35);}

/* MAIN */
.main{padding:28px 44px;flex:1;}
.section-title{font-family:'Fredoka One',cursive;font-size:20px;color:#1a4731;margin-bottom:14px;display:flex;align-items:center;gap:8px;}

/* CARDS BASE */
.card{background:white;border-radius:20px;padding:24px;box-shadow:0 4px 16px rgba(0,0,0,0.06);border:2px solid #e8f7ee;}

/* ===================== DASHBOARD ===================== */
#dashboard .top-row{display:grid;grid-template-columns:280px 1fr;gap:20px;margin-bottom:20px;}
.welcome-card{background:linear-gradient(135deg,#2d8a4e,#3aad60);border-radius:20px;padding:20px;color:white;}
.welcome-card h2{font-family:'Fredoka One',cursive;font-size:18px;margin-bottom:4px;}
.welcome-card p{font-size:13px;opacity:0.85;}
.quick-menu{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:16px;}
.qm-btn{background:rgba(255,255,255,0.18);border:2px solid rgba(255,255,255,0.3);border-radius:14px;padding:12px 10px;color:white;font-family:'Fredoka',sans-serif;font-size:13px;font-weight:600;cursor:pointer;text-align:center;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;gap:6px;}
.qm-btn:hover{background:rgba(255,255,255,0.32);transform:translateY(-2px);}
.qm-icon{font-size:22px;}
.banner-card{border-radius:20px;overflow:hidden;background:linear-gradient(135deg,#1a5c36,#2d8a4e);display:flex;align-items:center;justify-content:center;min-height:180px;position:relative;}
.banner-text{font-family:'Fredoka One',cursive;font-size:28px;color:white;text-align:center;text-shadow:2px 2px 0 rgba(0,0,0,0.2);z-index:1;padding:20px;}
.banner-bg{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:120px;opacity:0.08;}

.mid-row{display:grid;grid-template-columns:280px 1fr;gap:20px;margin-bottom:20px;}
.access-card{}
.access-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:4px;}
.access-item{background:#f0faf4;border-radius:14px;padding:16px;text-align:center;border:2px solid #d4f0de;}
.access-icon{font-size:28px;margin-bottom:6px;}
.access-label{font-size:13px;color:#1a4731;font-weight:600;}
.access-pct{font-family:'Fredoka One',cursive;font-size:22px;color:#2d8a4e;}

.desempenho-card{}
.tab-row{display:flex;gap:8px;margin-bottom:16px;}
.tab{padding:6px 18px;border-radius:50px;font-size:14px;font-weight:600;cursor:pointer;border:2px solid #d4f0de;color:#5a9a72;background:white;font-family:'Fredoka',sans-serif;transition:all 0.2s;}
.tab.active{background:#2d8a4e;color:white;border-color:#2d8a4e;}
.turma-row{display:flex;align-items:center;padding:12px 0;border-bottom:1px solid #f0faf4;gap:12px;}
.turma-row:last-child{border-bottom:none;}
.turma-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#b7e4c7,#52b788);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.turma-info{flex:1;}
.turma-nome{font-size:15px;font-weight:600;color:#1a4731;}
.turma-alunos{font-size:12px;color:#5a9a72;}
.desempenho-bar-wrap{flex:1;}
.desempenho-bar{height:8px;background:#e8f7ee;border-radius:50px;overflow:hidden;margin-bottom:4px;}
.desempenho-fill{height:100%;border-radius:50px;background:linear-gradient(90deg,#52b788,#2d8a4e);}
.desempenho-pct{font-size:13px;font-weight:700;color:#2d8a4e;text-align:right;}

/* ===================== CADASTRAR TURMA ===================== */
#cadastrar .back-btn{display:flex;align-items:center;gap:8px;color:#2d8a4e;font-size:16px;font-weight:600;cursor:pointer;margin-bottom:20px;background:none;border:none;font-family:'Fredoka',sans-serif;}
#cadastrar .back-btn:hover{color:#1a5c36;}
#cadastrar .page-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px;}
#cadastrar .page-header h1{font-family:'Fredoka One',cursive;font-size:26px;color:#1a4731;}
#cadastrar .page-header p{font-size:15px;color:#5a9a72;margin-top:2px;}
.btn-primary{background:linear-gradient(135deg,#2d8a4e,#3aad60);color:white;font-family:'Fredoka One',cursive;font-size:16px;padding:11px 22px;border-radius:14px;border:none;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 4px 12px rgba(45,138,78,0.3);transition:all 0.2s;}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(45,138,78,0.4);}
.filters-row{display:flex;gap:14px;margin-bottom:22px;}
.select-wrap{position:relative;flex:1;}
.select-wrap select{width:100%;padding:12px 40px 12px 16px;border-radius:14px;border:2px solid #d4f0de;background:white;font-family:'Fredoka',sans-serif;font-size:15px;color:#1a4731;appearance:none;cursor:pointer;outline:none;}
.select-wrap select:focus{border-color:#2d8a4e;}
.select-wrap::after{content:'▾';position:absolute;right:14px;top:50%;transform:translateY(-50%);color:#5a9a72;font-size:18px;pointer-events:none;}
.turmas-section-title{font-family:'Fredoka One',cursive;font-size:18px;color:#1a4731;padding-bottom:12px;border-bottom:2px solid #e8f7ee;margin-bottom:16px;}
.turmas-list{display:flex;flex-direction:column;gap:10px;}
.turma-item{background:#f8fffe;border-radius:14px;padding:16px 20px;border:2px solid #e8f7ee;display:flex;align-items:center;justify-content:space-between;transition:all 0.2s;}
.turma-item:hover{border-color:#52b788;background:white;}
.turma-item-left{display:flex;align-items:center;gap:14px;}
.turma-item-icon{width:44px;height:44px;border-radius:12px;background:linear-gradient(135deg,#b7e4c7,#52b788);display:flex;align-items:center;justify-content:center;font-size:20px;}
.turma-item-name{font-size:16px;font-weight:600;color:#1a4731;}
.turma-item-meta{font-size:13px;color:#5a9a72;margin-top:2px;}
.turma-item-actions{display:flex;gap:8px;}
.btn-icon{width:36px;height:36px;border-radius:10px;border:2px solid #e8f7ee;background:white;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;transition:all 0.2s;}
.btn-icon:hover{background:#f0faf4;border-color:#52b788;}
.btn-icon.danger:hover{background:#fff0f0;border-color:#f09595;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:100;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:white;border-radius:24px;padding:32px;width:420px;box-shadow:0 20px 60px rgba(0,0,0,0.2);}
.modal h2{font-family:'Fredoka One',cursive;font-size:22px;color:#1a4731;margin-bottom:6px;}
.modal p{font-size:14px;color:#5a9a72;margin-bottom:20px;}
.form-group{margin-bottom:14px;}
.form-group label{display:block;font-size:14px;font-weight:600;color:#1a4731;margin-bottom:6px;}
.form-group input,.form-group select{width:100%;padding:11px 14px;border-radius:12px;border:2px solid #d4f0de;font-family:'Fredoka',sans-serif;font-size:15px;color:#1a4731;outline:none;background:white;}
.form-group input:focus,.form-group select:focus{border-color:#2d8a4e;}
.modal-actions{display:flex;gap:10px;margin-top:20px;}
.btn-cancel{flex:1;padding:11px;border-radius:12px;border:2px solid #d4f0de;background:white;font-family:'Fredoka',sans-serif;font-size:15px;color:#5a9a72;cursor:pointer;font-weight:600;}
.btn-cancel:hover{background:#f0faf4;}
.btn-confirm{flex:1;padding:11px;border-radius:12px;border:none;background:linear-gradient(135deg,#2d8a4e,#3aad60);color:white;font-family:'Fredoka One',cursive;font-size:15px;cursor:pointer;}

/* ===================== PAINEL DA ESCOLA ===================== */
#painel .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.stat-box{background:white;border-radius:18px;padding:20px;text-align:center;border:2px solid #e8f7ee;box-shadow:0 4px 14px rgba(0,0,0,0.05);}
.stat-box .s-icon{font-size:28px;margin-bottom:8px;}
.stat-box .s-num{font-family:'Fredoka One',cursive;font-size:32px;color:#2d8a4e;}
.stat-box .s-label{font-size:13px;color:#5a9a72;font-weight:500;}
.school-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
.info-card{}
.info-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f0faf4;font-size:14px;}
.info-row:last-child{border-bottom:none;}
.info-row .lbl{color:#5a9a72;font-weight:500;}
.info-row .val{color:#1a4731;font-weight:600;}
.chart-bars{display:flex;align-items:flex-end;gap:12px;height:120px;padding:0 8px;}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;}
.bar{width:100%;border-radius:8px 8px 0 0;background:linear-gradient(180deg,#3aad60,#2d8a4e);}
.bar-label{font-size:12px;color:#5a9a72;font-weight:500;}
.bar-val{font-size:12px;font-weight:700;color:#2d8a4e;}

/* ===================== EQUIPE ESCOLAR ===================== */
#equipe .team-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.team-card{background:white;border-radius:18px;padding:20px;text-align:center;border:2px solid #e8f7ee;box-shadow:0 4px 14px rgba(0,0,0,0.05);transition:all 0.2s;}
.team-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(45,138,78,0.12);border-color:#52b788;}
.team-avatar{width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,#b7e4c7,#52b788);display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 12px;border:3px solid white;box-shadow:0 4px 12px rgba(82,183,136,0.3);}
.team-name{font-size:16px;font-weight:700;color:#1a4731;margin-bottom:4px;}
.team-role{font-size:13px;color:#5a9a72;margin-bottom:10px;}
.team-badge{display:inline-block;padding:4px 14px;border-radius:50px;font-size:12px;font-weight:600;}
.badge-coord{background:#d4f0de;color:#1a6f3a;}
.badge-prof{background:#dbeafe;color:#185fa5;}
.badge-support{background:#fef3c7;color:#854f0b;}
.add-member-card{background:#f8fffe;border:2px dashed #b7e4c7;border-radius:18px;padding:20px;text-align:center;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:180px;gap:10px;}
.add-member-card:hover{background:#f0faf4;border-color:#52b788;}
.add-icon{width:50px;height:50px;border-radius:50%;background:#d4f0de;display:flex;align-items:center;justify-content:center;font-size:24px;}
.add-text{font-size:15px;font-weight:600;color:#2d8a4e;}

/* ===================== AJUDE-NOS ===================== */
#ajuda .feedback-card{max-width:680px;margin:0 auto;}
.rating-row{display:flex;gap:12px;margin:16px 0;}
.rating-btn{flex:1;padding:14px;border-radius:14px;border:2px solid #d4f0de;background:white;font-family:'Fredoka',sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;gap:6px;}
.rating-btn:hover,.rating-btn.selected{border-color:#2d8a4e;background:#f0faf4;color:#2d8a4e;}
.rating-emoji{font-size:28px;}
.feedback-textarea{width:100%;padding:14px;border-radius:14px;border:2px solid #d4f0de;font-family:'Fredoka',sans-serif;font-size:15px;color:#1a4731;resize:vertical;min-height:120px;outline:none;margin:14px 0;}
.feedback-textarea:focus{border-color:#2d8a4e;}
.feedback-sent{text-align:center;padding:40px;display:none;}
.feedback-sent .big-emoji{font-size:64px;margin-bottom:16px;}
.feedback-sent h2{font-family:'Fredoka One',cursive;font-size:24px;color:#1a4731;}
.feedback-sent p{color:#5a9a72;margin-top:8px;}

/* NOTIF DOT */
.notif{width:8px;height:8px;background:#f9c74f;border-radius:50%;display:inline-block;margin-left:4px;vertical-align:middle;}
</style>

