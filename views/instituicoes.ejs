<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pequenos Exploradores — Instituições</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Fredoka:wght@400;500;600&display=swap" rel="stylesheet">
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Fredoka:wght@400;500;600&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Fredoka',sans-serif;background:#f0faf4;min-height:100vh;display:flex;flex-direction:column;}

/* NAVBAR */
nav{background:linear-gradient(135deg,#2d8a4e,#3aad60);padding:0 40px;height:68px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 16px rgba(45,138,78,0.25);flex-shrink:0;}
.logo{display:flex;align-items:center;gap:10px;font-family:'Fredoka One',cursive;font-size:20px;color:white;cursor:pointer;}
.logo-circle{width:40px;height:40px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;border:2px solid rgba(255,255,255,0.4);}
.nav-links{display:flex;gap:4px;align-items:center;}
.nav-link{color:rgba(255,255,255,0.9);font-size:16px;font-weight:500;padding:7px 16px;border-radius:50px;cursor:pointer;transition:all 0.2s;border:none;background:none;font-family:'Fredoka',sans-serif;}
.nav-link:hover,.nav-link.active{background:rgba(255,255,255,0.25);color:white;}
.btn-sair{background:rgba(255,255,255,0.2);border:2px solid rgba(255,255,255,0.5);color:white;font-family:'Fredoka',sans-serif;font-size:15px;font-weight:600;padding:6px 20px;border-radius:50px;cursor:pointer;transition:all 0.2s;}
.btn-sair:hover{background:rgba(255,255,255,0.35);}

/* MAIN */
.main{padding:28px 44px;flex:1;}
.section-title{font-family:'Fredoka One',cursive;font-size:20px;color:#1a4731;margin-bottom:14px;display:flex;align-items:center;gap:8px;}

/* BACK BUTTON */
.back-btn{display:flex;align-items:center;gap:8px;color:#2d8a4e;font-size:16px;font-weight:600;cursor:pointer;margin-bottom:20px;background:none;border:none;font-family:'Fredoka',sans-serif;}
.back-btn:hover{color:#1a5c36;}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.stat-box{background:white;border-radius:18px;padding:20px;text-align:center;border:2px solid #e8f7ee;box-shadow:0 4px 14px rgba(0,0,0,0.05);}
.stat-box .s-icon{font-size:28px;margin-bottom:8px;}
.stat-box .s-num{font-family:'Fredoka One',cursive;font-size:32px;color:#2d8a4e;}
.stat-box .s-label{font-size:13px;color:#5a9a72;font-weight:500;}

/* INFO */
.school-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;}
article{background:white;border-radius:20px;padding:24px;box-shadow:0 4px 16px rgba(0,0,0,0.06);border:2px solid #e8f7ee;}
.info-row{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f0faf4;font-size:14px;}
.info-row:last-child{border-bottom:none;}
.info-row .lbl{color:#5a9a72;font-weight:500;}
.info-row .val{color:#1a4731;font-weight:600;}
.chart-bars{display:flex;align-items:flex-end;gap:12px;height:120px;padding:0 8px;}
.bar-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;}
.bar{width:100%;border-radius:8px 8px 0 0;background:linear-gradient(180deg,#52b788,#2d8a4e);}
.bar-label{font-size:12px;color:#5a9a72;font-weight:500;}
.bar-val{font-size:12px;font-weight:700;color:#2d8a4e;}

/* FOOTER */
.footer{background:linear-gradient(135deg,#1a5c36,#2d8a4e);padding:32px 44px;display:flex;justify-content:space-between;align-items:flex-start;gap:32px;flex-shrink:0;}
.footer-brand{font-family:'Fredoka One',cursive;color:white;font-size:20px;margin-bottom:8px;}
.footer-desc{color:rgba(255,255,255,0.75);font-size:14px;max-width:300px;line-height:1.5;}
.footer-contact{text-align:center;color:white;}
.footer-contact h3{font-family:'Fredoka One',cursive;font-size:18px;margin-bottom:6px;}
.footer-email{color:#a7f3d0;font-size:14px;text-decoration:underline;}
.footer-social{width:44px;height:44px;background:rgba(255,255,255,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;margin:10px auto 0;cursor:pointer;border:2px solid rgba(255,255,255,0.3);}

@media (max-width: 768px){
  .stats-grid{grid-template-columns:repeat(2,1fr);}
  .school-info-grid{grid-template-columns:1fr;}
}

@media (max-width: 600px){
  nav{padding:0 20px;}
  .main{padding:20px;padding-top:28px;}
  .stats-grid{grid-template-columns:1fr;}
  .school-info-grid{grid-template-columns:1fr;}
  .nav-links{display:none;}
}
</style>
</head>
<body>
  <nav>
    <section class="logo"><section class="logo-circle">🧭</section>Pequenos Exploradores</section>
    <section class="nav-links">
      <button class="nav-link active">Início</button>
      <button class="nav-link">Sobre</button>
      <button class="nav-link">Contato</button>
    </section>
    <button class="btn-sair">Sair</button>
  </nav>

  <section class="main">
    <button class="back-btn">← Voltar ao Início</button>
    <header class="section-title" style="font-size:24px;margin-bottom:20px;">🏫 Painel das Instituições</header>
    
    <section class="stats-grid">
      <article class="stat-box"><span class="s-icon">🏫</span><p class="s-num">6</p><p class="s-label">Escolas Parceiras</p></article>
      <article class="stat-box"><span class="s-icon">🧒</span><p class="s-num">520</p><p class="s-label">Alunos</p></article>
      <article class="stat-box"><span class="s-icon">👩‍🏫</span><p class="s-num">48</p><p class="s-label">Professores</p></article>
      <article class="stat-box"><span class="s-icon">⭐</span><p class="s-num">87%</p><p class="s-label">Desempenho Geral</p></article>
    </section>

    <section class="school-info-grid">
      <article>
        <header class="section-title">🏛️ Dados das Instituições</header>
        <section class="info-row"><span class="lbl">Total de Escolas</span><span class="val">6 Instituições</span></section>
        <section class="info-row"><span class="lbl">Coordenador</span><span class="val">Everton Lopes da Silva</span></section>
        <section class="info-row"><span class="lbl">Localização</span><span class="val">Região Metropolitana</span></section>
        <section class="info-row"><span class="lbl">Ano de Início</span><span class="val">2023</span></section>
        <section class="info-row"><span class="lbl">Status</span><span class="val" style="color:#2d8a4e;">✅ Ativa</span></section>
      </article>
      <article>
        <header class="section-title">📈 Desempenho por Escola</header>
        <section class="chart-bars">
          <section class="bar-col"><p class="bar-val">90%</p><section class="bar" style="height:108px;"></section><p class="bar-label">Escola A</p></section>
          <section class="bar-col"><p class="bar-val">85%</p><section class="bar" style="height:102px;"></section><p class="bar-label">Escola B</p></section>
          <section class="bar-col"><p class="bar-val">75%</p><section class="bar" style="height:90px;"></section><p class="bar-label">Escola C</p></section>
          <section class="bar-col"><p class="bar-val">88%</p><section class="bar" style="height:105px;"></section><p class="bar-label">Escola D</p></section>
          <section class="bar-col"><p class="bar-val">87%</p><section class="bar" style="height:104px;"></section><p class="bar-label">Escola E</p></section>
        </section>
      </article>
    </section>
  </section>

  <footer class="footer">
    <section><section class="footer-brand">🌱 Pequenos Exploradores</section><section class="footer-desc">Nosso objetivo é ensinar as crianças a cuidar do planeta! Com especialistas em educação ambiental, oferecemos recursos que promovem a consciência ecológica.</section></section>
    <section class="footer-contact"><h3>Contato</h3><section class="footer-email">pequenosexploradores@gmail.com</section><section class="footer-social">📸</section></section>
  </footer>
</body>
</html>