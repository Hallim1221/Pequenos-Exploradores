.rating-btn{flex:1;padding:14px;border-radius:14px;border:2px solid #d4f0de;background:white;font-family:'Fredoka',sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;flex-direction:column;align-items:center;gap:6px;}
