<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Pequenos Exploradores – Ranking</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Baloo+2:wght@700;800&family=Fredoka:wght@400;700&family=Fredoka+One&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --g1:#1b7a30;--g2:#27a844;--g3:#4ecb6a;--g4:#b8f0c8;--g5:#e8faee;
  --orange:#ff6b35;--yellow:#ffe066;--white:#fff;--off:#f4fcf6;
  --text:#12291a;--text2:#2e6640;
  --sh:0 4px 18px rgba(27,122,48,.12);--sh2:0 8px 32px rgba(27,122,48,.18);
  --r:16px;--rl:22px;
}
body{font-family:'Nunito',sans-serif;background:var(--off);color:var(--text);min-height:100vh;}

/* NAVBAR */
.navbar-redesign{background:#61b231;padding:0 40px;height:72px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 16px rgba(97,178,49,.28);position:fixed;top:0;left:0;right:0;width:100%;z-index:9000;}
.logo-redesign{display:flex;align-items:center;gap:16px;margin-left:-32px;font-family:'Baloo 2',cursive;font-size:30px;color:white;text-shadow:2px 2px 0 rgba(0,0,0,.15);}
.logo-redesign img{width:145px;height:94px;object-fit:contain;}
.nav-links-redesign{display:flex;gap:8px;align-items:center;margin-left:130px;}
.nav-link-redesign{color:rgba(255,255,255,.9);font-size:16px;font-weight:600;padding:8px 18px;border-radius:50px;text-decoration:none;transition:all .2s;cursor:pointer;}
.nav-link-redesign:hover,.nav-link-redesign.active{background:rgba(255,255,255,.25);color:white;}
.nav-right-redesign{display:flex;align-items:center;gap:16px;}
.btn-sair-redesign{background:rgba(255,255,255,.2);border:2px solid rgba(255,255,255,.5);color:white;font-family:'Fredoka',sans-serif;font-size:16px;font-weight:600;padding:7px 22px;border-radius:50px;cursor:pointer;transition:all .2s;}
.btn-sair-redesign:hover{background:rgba(255,255,255,.35);}
.bell-btn-redesign{position:relative;background:rgba(255,255,255,.2);border:none;border-radius:50%;width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;transition:all .2s;}
.bell-btn-redesign:hover{background:rgba(255,255,255,.35);}
.bell-badge-redesign{position:absolute;top:4px;right:4px;background:#FFD600;color:#7c5800;font-size:10px;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
body{padding-top:72px;}

/* PAGES */
.page{display:none;animation:fadeUp .3s ease;}
.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* WRAP */
.wrap{max-width:980px;margin:0 auto;padding:32px 24px 52px;}
.wrap-md{max-width:780px;margin:0 auto;padding:32px 24px 52px;}

/* BACK BTN */
.back-btn{display:inline-flex;align-items:center;gap:7px;background:var(--g1);color:var(--white);border:none;border-radius:40px;padding:9px 20px;font-family:'Fredoka One',sans-serif;font-size:14px;cursor:pointer;margin-bottom:24px;box-shadow:var(--sh);transition:all .15s;}
.back-btn:hover{background:var(--g2);transform:translateX(-2px);}

/* BACK BUTTON VOLTAR */
.back-btn-voltar{position:fixed;top:90px;left:20px;z-index:1000;background:#27a844;color:white;border:none;border-radius:50px;padding:10px 18px;font-family:'Fredoka One',sans-serif;font-size:14px;cursor:pointer;display:flex;align-items:center;gap:6px;box-shadow:0 4px 12px rgba(39,168,68,.3);transition:all .2s ease;}
.back-btn-voltar:hover{background:#1b7a30;transform:translateX(-3px);box-shadow:0 6px 16px rgba(39,168,68,.4);}

/* SECTION TITLE */
.sec-title{font-family:'Fredoka One',sans-serif;font-size:20px;color:var(--text);margin-bottom:14px;display:flex;align-items:center;gap:8px;}

/* HERO GRID */
.hero{display:grid;grid-template-columns:260px 1fr;gap:22px;margin-bottom:28px;}

/* LEFT RANK CARD */
.rank-card{background:linear-gradient(160deg,#1b7a30,#0e5220);border-radius:var(--rl);padding:26px 20px;box-shadow:var(--sh2);color:var(--white);text-align:center;}
.rc-label{font-family:'Fredoka One',sans-serif;font-size:15px;color:rgba(255,255,255,.6);margin-bottom:12px;}
.rc-badges{display:flex;gap:8px;margin-bottom:14px;}
.rc-b{flex:1;background:rgba(255,255,255,.13);border-radius:12px;padding:10px 6px;border:1.5px solid rgba(255,255,255,.18);}
.rc-b-n{font-family:'Fredoka One',sans-serif;font-size:19px;display:block;}
.rc-b-l{font-size:10px;opacity:.6;font-weight:700;}
.nivel-pill{display:inline-block;background:var(--orange);border-radius:40px;padding:7px 20px;font-family:'Fredoka One',sans-serif;font-size:14px;color:var(--white);margin-bottom:14px;}
.rc-avatar{width:84px;height:84px;border-radius:50%;background:rgba(255,255,255,.14);margin:0 auto 10px;display:flex;align-items:center;justify-content:center;font-size:42px;border:4px solid rgba(255,255,255,.3);}
.prog-bg{background:rgba(255,255,255,.18);border-radius:40px;height:11px;margin:12px 0 5px;overflow:hidden;}
.prog-fill{height:11px;border-radius:40px;background:linear-gradient(90deg,var(--yellow),var(--orange));width:50%;}
.prog-txt{font-size:11px;opacity:.6;font-weight:700;margin-bottom:12px;}
.pts-row{display:flex;align-items:center;justify-content:center;gap:8px;}
.pts-bubble{background:var(--white);color:var(--g1);font-family:'Fredoka One',sans-serif;font-size:20px;padding:7px 18px;border-radius:40px;}

/* RIGHT */
.right{display:flex;flex-direction:column;gap:16px;}
.trophy-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.trophy-card{background:var(--white);border-radius:var(--r);padding:16px 10px;text-align:center;border:2px solid var(--g4);box-shadow:var(--sh);transition:transform .15s;}
.trophy-card:hover{transform:translateY(-4px);}
.tc-ico{font-size:30px;display:block;margin-bottom:5px;}
.tc-lbl{font-size:11px;font-weight:800;color:var(--text2);}

/* MEDALS */
.medals-box{background:var(--white);border-radius:var(--r);border:2px solid var(--g4);box-shadow:var(--sh);overflow:hidden;}
.medals-hdr{background:linear-gradient(90deg,var(--g1),var(--g2));padding:12px 18px;font-family:'Fredoka One',sans-serif;font-size:15px;color:var(--white);}
.medals-inner{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:14px;}
.ms{text-align:center;background:var(--g5);border-radius:12px;padding:12px 6px;border:2px solid var(--g4);}
.ms.locked .ms-ico{filter:grayscale(1);opacity:.38;}
.ms-ico{font-size:28px;display:block;margin-bottom:5px;}
.ms-name{font-size:10px;font-weight:800;color:var(--text2);}
.ms.locked .ms-name{color:#bbb;}

/* ACTION BTNS */
.actions{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.abtn{border:none;border-radius:var(--r);padding:14px 10px;font-family:'Fredoka One',sans-serif;font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;box-shadow:var(--sh);transition:all .15s;color:var(--white);}
.abtn:hover{transform:translateY(-3px);filter:brightness(1.08);}
.abtn.a1{background:var(--g2);}
.abtn.a2{background:var(--orange);}
.abtn.a3{background:var(--g1);}

/* PODIUM */
.podium{display:grid;grid-template-columns:1fr 1.1fr 1fr;gap:14px;margin-bottom:22px;}
.pod{background:var(--white);border-radius:var(--rl);padding:24px 14px 20px;text-align:center;border:2.5px solid var(--g4);box-shadow:var(--sh);position:relative;overflow:hidden;transition:transform .16s;}
.pod:hover{transform:translateY(-6px);}
.pod::before{content:'';position:absolute;top:0;left:0;right:0;height:5px;}
.pod.gold{border-color:#f5a623;background:linear-gradient(160deg,#fffef0,#fff8df);}
.pod.gold::before{background:linear-gradient(90deg,#f5a623,#ffd600);}
.pod.silver::before{background:linear-gradient(90deg,#9e9e9e,#cfd8dc);}
.pod.bronze::before{background:linear-gradient(90deg,#c47b3e,#e8a96c);}
.pod-medal{font-size:36px;display:block;margin-bottom:7px;}
.pod-av{width:62px;height:62px;border-radius:50%;margin:0 auto 9px;display:flex;align-items:center;justify-content:center;font-size:30px;border:4px solid;}
.pod-av.gold{background:#fff9c4;border-color:#f5a623;}
.pod-av.silver{background:#f5f5f5;border-color:#9e9e9e;}
.pod-av.bronze{background:#fff3e0;border-color:#c47b3e;}
.pod-name{font-family:'Fredoka One',sans-serif;font-size:15px;color:var(--text);margin-bottom:3px;}
.pod-pts{font-family:'Fredoka One',sans-serif;font-size:19px;color:var(--g2);}
.pod.gold .pod-pts{font-size:23px;color:#e08800;}
.pod-miss{font-size:11px;font-weight:700;color:#bbb;margin-top:4px;}
.you{background:var(--yellow);color:var(--g1);font-size:9px;font-weight:900;border-radius:10px;padding:2px 7px;margin-left:4px;vertical-align:middle;}

/* LIST */
.list-box{background:var(--white);border-radius:var(--rl);border:2px solid var(--g4);box-shadow:var(--sh);overflow:hidden;margin-bottom:22px;}
.list-hdr{background:linear-gradient(90deg,var(--g1),var(--g2));padding:13px 20px;font-family:'Fredoka One',sans-serif;font-size:15px;color:var(--white);}
.rrow{display:flex;align-items:center;gap:13px;padding:13px 18px;border-bottom:1.5px solid var(--g5);transition:background .12s;}
.rrow:last-child{border-bottom:none;}
.rrow:hover{background:var(--g5);}
.rrow.me{background:linear-gradient(90deg,#ecfff3,#f3fff7);border-left:4px solid var(--g3);}
.rn{font-family:'Fredoka One',sans-serif;font-size:17px;color:var(--text2);width:30px;text-align:center;flex-shrink:0;}
.rav{width:40px;height:40px;border-radius:50%;flex-shrink:0;background:var(--g5);border:2px solid var(--g4);display:flex;align-items:center;justify-content:center;font-size:19px;}
.ri{flex:1;}
.ri-name{font-size:14px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:5px;}
.ri-sub{font-size:11px;font-weight:600;color:#bbb;}
.rpts{font-family:'Fredoka One',sans-serif;font-size:16px;color:var(--g2);flex-shrink:0;}
.rrow.me .rpts{color:var(--g1);}

/* LEVELS INLINE */
.levels-section{background:var(--white);border-radius:var(--rl);border:2px solid var(--g4);box-shadow:var(--sh);overflow:hidden;margin-bottom:22px;}
.sec-hdr{padding:14px 20px;font-family:'Fredoka One',sans-serif;font-size:16px;color:var(--white);}
.sec-hdr.green{background:linear-gradient(90deg,var(--g1),var(--g2));}
.sec-hdr.orange{background:linear-gradient(90deg,var(--orange),#e5521e);}
.levels-body{padding:20px;}
.lvl-prog-card{background:var(--g5);border-radius:var(--r);padding:18px;margin-bottom:16px;border:1.5px solid var(--g4);}
.lvl-prog-label{font-family:'Fredoka One',sans-serif;font-size:13px;color:var(--text2);text-align:center;margin-bottom:10px;}
.lvl-track{background:#d5eedd;border-radius:40px;height:13px;margin-bottom:10px;}
.lvl-track-fill{height:13px;border-radius:40px;background:linear-gradient(90deg,var(--orange),var(--yellow));width:12%;}
.lvl-dots{display:flex;justify-content:space-between;}
.lvl-dot{text-align:center;}
.lvl-dot-c{width:13px;height:13px;border-radius:50%;margin:0 auto 3px;background:var(--g4);}
.lvl-dot-c.done{background:var(--orange);}
.lvl-dot span{font-size:10px;font-weight:800;color:var(--text2);display:block;}
.lvl-dot small{font-size:9px;color:#aaa;}
.lvl-grid-6{display:grid;grid-template-columns:repeat(6,1fr);gap:10px;}
.lvl-grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.lvl-card{background:var(--g5);border-radius:12px;padding:14px 8px;text-align:center;border:2px solid var(--g4);transition:all .15s;cursor:default;}
.lvl-card.current{background:var(--g2);border-color:var(--g1);}
.lvl-card:hover{transform:translateY(-3px);}
.lc-ico{font-size:26px;display:block;margin-bottom:5px;}
.lc-name{font-family:'Fredoka One',sans-serif;font-size:11px;color:var(--text2);}
.lvl-card.current .lc-name{color:var(--white);}
.lc-pts{font-size:10px;font-weight:700;color:#aaa;}
.lvl-card.current .lc-pts{color:rgba(255,255,255,.7);}

/* lvl-card full (premios page) */
.lvl-card-full{background:var(--g5);border-radius:var(--r);padding:20px 16px;text-align:center;border:2px solid var(--g4);transition:all .15s;cursor:default;}
.lvl-card-full.current{background:linear-gradient(160deg,var(--g2),var(--g1));border-color:var(--g1);}
.lvl-card-full:hover{transform:translateY(-4px);box-shadow:var(--sh2);}
.lvl-card-full .lc-ico{font-size:38px;margin-bottom:8px;}
.lvl-card-full .lc-name{font-family:'Fredoka One',sans-serif;font-size:14px;color:var(--text2);margin-bottom:4px;}
.lvl-card-full.current .lc-name{color:var(--white);}
.lvl-card-full .lc-pts{font-size:12px;font-weight:700;color:#aaa;}
.lvl-card-full.current .lc-pts{color:rgba(255,255,255,.75);}
.lvl-card-full .lc-desc{font-size:11px;color:#999;margin-top:5px;}

/* PREMIOS INLINE */
.premios-section{background:var(--white);border-radius:var(--rl);border:2px solid var(--g4);box-shadow:var(--sh);overflow:hidden;}
.premios-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;padding:20px;}
.pc{background:var(--g5);border-radius:var(--r);padding:20px 14px;text-align:center;border:2px solid var(--g4);transition:transform .15s;}
.pc:hover{transform:translateY(-4px);}
.pc.locked .pc-ico{filter:grayscale(1);opacity:.4;}
.pc-ico{font-size:40px;display:block;margin-bottom:8px;}
.pc-name{font-family:'Fredoka One',sans-serif;font-size:14px;color:var(--text);margin-bottom:6px;}
.pc-req{font-size:11px;font-weight:800;color:var(--white);background:var(--g2);border-radius:40px;padding:3px 12px;display:inline-block;margin-bottom:7px;}
.pc.locked .pc-req{background:#c8c8c8;}
.pc-desc{font-size:11px;font-weight:600;color:#aaa;}

/* VER MAIS BTN inside section */
.ver-mais{display:block;width:100%;border:none;border-radius:0 0 var(--rl) var(--rl);padding:14px;font-family:'Fredoka One',sans-serif;font-size:14px;cursor:pointer;color:var(--white);transition:filter .15s;}
.ver-mais:hover{filter:brightness(1.1);}
.ver-mais.green{background:var(--g2);}
.ver-mais.orange{background:var(--orange);}

/* FULL RANKING PAGE */
.full-list-box{background:var(--white);border-radius:var(--rl);border:2px solid var(--g4);box-shadow:var(--sh);overflow:hidden;}

/* FULL PREMIOS PAGE */
.pc-full{background:var(--g5);border-radius:var(--r);padding:22px 16px;text-align:center;border:2px solid var(--g4);transition:transform .15s;box-shadow:var(--sh);}
.pc-full:hover{transform:translateY(-5px);box-shadow:var(--sh2);}
.pc-full.locked .pc-ico{filter:grayscale(1);opacity:.4;}
.premios-grid-full{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}

@media(max-width:700px){
  .hero{grid-template-columns:1fr;}
  .podium{grid-template-columns:1fr;}
  .lvl-grid-6{grid-template-columns:repeat(3,1fr);}
  .premios-grid,.premios-grid-full{grid-template-columns:1fr 1fr;}
  .lvl-grid-3{grid-template-columns:repeat(2,1fr);}
}
</style>
</head>
<body>

<!-- BOTÃO DE VOLTAR -->
<button class="back-btn-voltar" onclick="history.back()">← Voltar</button>

<nav class="navbar-redesign">
  <section class="logo-redesign">
    <img src="/img/log.png" alt="Logo Pequenos Exploradores">
  </section>
  <section class="nav-links-redesign">
  </section>
  <section class="nav-right-redesign">
    <button class="bell-btn-redesign" id="btn-notificacoes" aria-label="Notificações">
      🔔<span class="bell-badge-redesign" id="notificacao-badge-nav">1</span>
    </button>
    <button class="btn-sair-redesign" onclick="abrirModalLogout()">Sair</button>
  </section>
</nav>

<!-- ══════════════════════════════
     PÁGINA PRINCIPAL
══════════════════════════════ -->
<section class="page active" id="page-home">
<section class="wrap">

  <!-- HERO -->
  <section class="hero">
    <article class="rank-card">
      <div class="rc-label">Ranking</div>
      <div class="rc-badges">
        <span class="rc-b"><span class="rc-b-n">11°</span><span class="rc-b-l">Geral</span></span>
        <span class="rc-b"><span class="rc-b-n">5°</span><span class="rc-b-l">Escola</span></span>
        <span class="rc-b"><span class="rc-b-n">3°</span><span class="rc-b-l">Sala</span></span>
      </div>
      <div class="nivel-pill">🥉 Bronze I</div>
      <span class="rc-avatar">👧</span>
      <div class="prog-bg"><div class="prog-fill"></div></div>
      <p class="prog-txt">50 / 100 para o próximo nível</p>
      <div class="pts-row">
        <span class="pts-bubble">420 pts</span>
        <span style="font-size:22px;">🏆</span>
      </div>
    </article>

    <aside class="right">
      <section class="trophy-row">
        <article class="trophy-card"><span class="tc-ico">🥇</span><div class="tc-lbl">Campeão</div></article>
        <article class="trophy-card"><span class="tc-ico">🥈</span><div class="tc-lbl">Vice</div></article>
        <article class="trophy-card"><span class="tc-ico">🥉</span><div class="tc-lbl">3° Lugar</div></article>
      </section>
      <section class="medals-box">
        <header class="medals-hdr">🏅 Medalhas</header>
        <div class="medals-inner">
          <span class="ms"><span class="ms-ico">🥉</span><div class="ms-name">Bronze I</div></span>
          <span class="ms locked"><span class="ms-ico">🥉</span><div class="ms-name">Bronze II</div></span>
          <span class="ms locked"><span class="ms-ico">🥉</span><div class="ms-name">Bronze III</div></span>
          <span class="ms locked"><span class="ms-ico">🥈</span><div class="ms-name">Prata I</div></span>
        </div>
      </section>
      <section class="actions">
        <button class="abtn a1" onclick="goPage('ranking')">🏆 Ver Ranking Completo</button>
        <button class="abtn a2" onclick="goPage('niveis')">⭐ Ver Níveis</button>
        <button class="abtn a3" onclick="goPage('premios')">🎁 Ver Prêmios</button>
      </section>
    </aside>
  </section>

  <!-- PÓDIO -->
  <h2 class="sec-title">🏆 Ranking da Turma</h2>
  <section class="podium">
    <article class="pod silver">
      <span class="pod-medal">🥈</span>
      <span class="pod-av silver">🧒</span>
      <h3 class="pod-name">Pedro</h3>
      <p class="pod-pts">580 pts</p>
      <p class="pod-miss">🎯 6 missões</p>
    </article>
    <article class="pod gold">
      <span class="pod-medal">🥇</span>
      <span class="pod-av gold">👧</span>
      <h3 class="pod-name">Ana Beatriz</h3>
      <p class="pod-pts">720 pts</p>
      <p class="pod-miss">🎯 8 missões</p>
    </article>
    <article class="pod bronze">
      <span class="pod-medal">🥉</span>
      <span class="pod-av bronze">👧</span>
      <h3 class="pod-name"><%= nomeAluno %> <span class="you">Você</span></h3>
      <p class="pod-pts">420 pts</p>
      <p class="pod-miss">🎯 5 missões</p>
    </article>
  </section>

  <!-- LISTA PRÉVIA (top 5) -->
  <section class="list-box">
    <header class="list-hdr">📋 Classificação</header>
    <div class="rrow">
      <span class="rn">4°</span><span class="rav">🧒</span>
      <article class="ri"><h4 class="ri-name">Lucas</h4><p class="ri-sub">🎯 5 missões</p></article>
      <span class="rpts">390 pts</span>
    </div>
    <div class="rrow">
      <span class="rn">5°</span><span class="rav">👧</span>
      <article class="ri"><h4 class="ri-name">Maria</h4><p class="ri-sub">🎯 4 missões</p></article>
      <span class="rpts">350 pts</span>
    </div>
    <div class="rrow me">
      <span class="rn">3°</span><span class="rav">👧</span>
      <article class="ri"><h4 class="ri-name"><%= nomeAluno %> <span class="you">Você</span></h4><p class="ri-sub">🎯 5 missões</p></article>
      <span class="rpts">420 pts</span>
    </div>
    <button class="ver-mais green" onclick="goPage('ranking')">🏆 Ver Ranking Completo →</button>
  </section>

  <!-- NÍVEIS PREVIEW -->
  <h2 class="sec-title" style="margin-top:6px;">⭐ Níveis</h2>
  <section class="levels-section">
    <header class="sec-hdr green">⭐ Seu Progresso de Níveis</header>
    <section class="levels-body">
      <article class="lvl-prog-card">
        <p class="lvl-prog-label">Progresso atual</p>
