


<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Fredoka:wght@400;500;600&display=swap');
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Fredoka',sans-serif;background:#1e0a3c;min-height:100vh;margin-top:72px;}
.page{display:none;min-height:100vh;flex-direction:column;}
.page.active{display:flex;}

/* MAIN */
.main{padding:24px 36px;flex:1;}

/* ============ HOME PREMIUM ============ */
#home .home-grid{display:grid;grid-template-columns:260px 1fr 260px;gap:18px;}

/* Profile card */
.profile-card{background:linear-gradient(160deg,#2d1260,#4a1fa8);border-radius:22px;padding:22px;border:2px solid rgba(168,85,247,0.4);box-shadow:0 8px 32px rgba(74,31,168,0.4);}
.prof-avatar{width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#a855f7,#6c3fc5);display:flex;align-items:center;justify-content:center;font-size:38px;margin:0 auto 12px;border:3px solid rgba(255,255,255,0.3);box-shadow:0 0 20px rgba(168,85,247,0.4);}
.prof-name{font-family:'Fredoka One',cursive;font-size:17px;color:white;text-align:center;margin-bottom:4px;}
.prof-school{font-size:12px;color:rgba(255,255,255,0.6);text-align:center;margin-bottom:14px;line-height:1.4;}
.prof-turma{background:rgba(255,255,255,0.12);border:1px solid rgba(168,85,247,0.5);border-radius:50px;padding:5px 14px;font-size:13px;color:#d8b4fe;font-weight:600;text-align:center;margin-bottom:14px;}
.xp-section{margin-bottom:14px;}
.xp-label{display:flex;justify-content:space-between;font-size:12px;color:rgba(255,255,255,0.65);margin-bottom:6px;}
.xp-bar{background:rgba(255,255,255,0.12);border-radius:50px;height:10px;overflow:hidden;}
.xp-fill{height:100%;border-radius:50px;background:linear-gradient(90deg,#a855f7,#22c55e);width:42%;}
.stat-pills{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.stat-pill{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:14px;padding:10px;text-align:center;}
.stat-pill .sp-num{font-family:'Fredoka One',cursive;font-size:20px;color:#a855f7;}
.stat-pill .sp-label{font-size:11px;color:rgba(255,255,255,0.6);}
.btn-evoluir{width:100%;margin-top:14px;background:linear-gradient(135deg,#22c55e,#16a34a);color:white;font-family:'Fredoka One',cursive;font-size:17px;padding:12px;border:none;border-radius:14px;cursor:pointer;box-shadow:0 4px 14px rgba(34,197,94,0.4);transition:all 0.2s;}
.btn-evoluir:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(34,197,94,0.5);}

/* CENTER */
.center-col{display:flex;flex-direction:column;gap:16px;}
.greeting-banner{background:linear-gradient(120deg,#4a1fa8,#7c3aed);border-radius:22px;padding:22px 28px;border:2px solid rgba(168,85,247,0.3);position:relative;overflow:hidden;}
.greeting-banner::before{content:'✨🌟💫';position:absolute;right:20px;top:10px;font-size:24px;opacity:0.3;letter-spacing:6px;}
.greeting-banner h1{font-family:'Fredoka One',cursive;color:white;font-size:26px;margin-bottom:4px;}
.greeting-banner p{color:rgba(255,255,255,0.8);font-size:15px;}
.xp-pill-top{background:rgba(255,255,255,0.15);border:2px solid rgba(168,85,247,0.5);border-radius:50px;padding:7px 18px;color:white;font-size:14px;font-weight:600;display:inline-flex;align-items:center;gap:6px;margin-top:12px;}
.cats{display:flex;gap:10px;flex-wrap:wrap;}
.cat-pill{background:rgba(255,255,255,0.08);border:2px solid rgba(168,85,247,0.3);border-radius:50px;padding:8px 16px;font-size:14px;font-weight:600;color:#d8b4fe;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:6px;}
.cat-pill:hover,.cat-pill.active{background:rgba(168,85,247,0.3);border-color:#a855f7;color:white;}
.missions-card{background:linear-gradient(160deg,#2d1260,#3d1a80);border-radius:22px;padding:20px;border:2px solid rgba(168,85,247,0.3);}
.card-title{font-family:'Fredoka One',cursive;font-size:18px;color:white;margin-bottom:14px;display:flex;align-items:center;gap:8px;}
.missions-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.m-card{background:rgba(255,255,255,0.06);border:2px solid rgba(168,85,247,0.2);border-radius:16px;padding:14px 10px;text-align:center;cursor:pointer;transition:all 0.2s;}
.m-card:hover{background:rgba(168,85,247,0.15);border-color:#a855f7;transform:translateY(-3px);}
.m-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto 8px;}
.m-icon.p{background:rgba(168,85,247,0.25);}
.m-icon.g{background:rgba(34,197,94,0.2);}
.m-icon.y{background:rgba(249,199,79,0.2);}
.m-icon.b{background:rgba(59,130,246,0.2);}
.m-name{font-size:13px;font-weight:600;color:white;margin-bottom:5px;}
.m-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:50px;display:inline-block;}
.mb-done{background:rgba(34,197,94,0.2);color:#4ade80;}
.mb-prog{background:rgba(249,199,79,0.2);color:#fbbf24;}
.mb-lock{background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.4);}

/* RIGHT — MASCOTE PREVIEW */
.mascot-side{background:linear-gradient(160deg,#2d1260,#4a1fa8);border-radius:22px;padding:22px;border:2px solid rgba(168,85,247,0.4);display:flex;flex-direction:column;align-items:center;gap:14px;}
.mascot-title{font-family:'Fredoka One',cursive;color:white;font-size:16px;text-align:center;}
.egg-main{width:110px;height:110px;border-radius:50% 50% 50% 50% / 60% 60% 40% 40%;background:linear-gradient(160deg,#e879f9,#a855f7);display:flex;align-items:center;justify-content:center;font-size:52px;box-shadow:0 0 30px rgba(168,85,247,0.5);animation:float 3s ease-in-out infinite;cursor:pointer;border:3px solid rgba(255,255,255,0.3);}
@keyframes float{0%,100%{transform:translateY(0);}50%{transform:translateY(-8px);}}
.egg-level{background:linear-gradient(90deg,#a855f7,#22c55e);color:white;font-size:12px;font-weight:700;padding:4px 14px;border-radius:50px;}
.egg-progress-wrap{width:100%;}
.egg-prog-label{display:flex;justify-content:space-between;font-size:12px;color:rgba(255,255,255,0.6);margin-bottom:5px;}
.egg-prog-bar{background:rgba(255,255,255,0.1);border-radius:50px;height:8px;overflow:hidden;}
.egg-prog-fill{height:100%;border-radius:50px;background:linear-gradient(90deg,#a855f7,#22c55e);width:42%;}
.btn-gallery{width:100%;background:rgba(168,85,247,0.2);border:2px solid rgba(168,85,247,0.5);color:#d8b4fe;font-family:'Fredoka One',cursive;font-size:15px;padding:10px;border-radius:14px;cursor:pointer;transition:all 0.2s;}
.btn-gallery:hover{background:rgba(168,85,247,0.35);color:white;}
.mini-eggs{display:flex;gap:8px;justify-content:center;}
.mini-egg{width:36px;height:36px;border-radius:50% 50% 50% 50%/60% 60% 40% 40%;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;border:2px solid rgba(255,255,255,0.15);transition:all 0.2s;}
.mini-egg:hover{transform:scale(1.15);}
.mini-egg.locked{filter:grayscale(1);opacity:0.4;}

/* ============ GALERIA ============ */
#galeria .gal-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
#galeria .gal-header h1{font-family:'Fredoka One',cursive;font-size:26px;color:white;}
.gal-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.egg-card{background:linear-gradient(160deg,#2d1260,#3d1a80);border-radius:22px;padding:22px 16px;text-align:center;border:2px solid rgba(168,85,247,0.25);transition:all 0.25s;cursor:pointer;}
.egg-card:hover:not(.locked-card){transform:translateY(-5px);border-color:#a855f7;box-shadow:0 12px 32px rgba(168,85,247,0.3);}
.egg-card.locked-card{opacity:0.5;filter:grayscale(0.6);}
.egg-visual{width:90px;height:90px;border-radius:50% 50% 50% 50%/60% 60% 40% 40%;display:flex;align-items:center;justify-content:center;font-size:46px;margin:0 auto 12px;box-shadow:0 0 20px rgba(168,85,247,0.3);}
.ev0{background:linear-gradient(160deg,#d4d4d4,#a3a3a3);}
.ev1{background:linear-gradient(160deg,#86efac,#22c55e);animation:float 3s ease-in-out infinite;}
.ev2{background:linear-gradient(160deg,#93c5fd,#3b82f6);animation:float 3.5s ease-in-out infinite;}
.ev3{background:linear-gradient(160deg,#f9a8d4,#ec4899);animation:float 2.8s ease-in-out infinite;}
.ev4{background:linear-gradient(160deg,#fcd34d,#f59e0b);animation:float 4s ease-in-out infinite;}
.ev5{background:linear-gradient(160deg,#c4b5fd,#8b5cf6);animation:float 3.2s ease-in-out infinite;}
.ev6{background:linear-gradient(160deg,#fed7aa,#f97316);animation:float 2.5s ease-in-out infinite;}
.ev7{background:linear-gradient(160deg,#99f6e4,#14b8a6);animation:float 3.8s ease-in-out infinite;}
.egg-name{font-family:'Fredoka One',cursive;font-size:16px;color:white;margin-bottom:5px;}
.egg-pts{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:10px;}
.egg-status-bar{height:6px;background:rgba(255,255,255,0.1);border-radius:50px;overflow:hidden;margin-bottom:8px;}
.egg-status-fill{height:100%;border-radius:50px;background:linear-gradient(90deg,#a855f7,#22c55e);}
.egg-status-label{font-size:11px;font-weight:600;padding:4px 12px;border-radius:50px;display:inline-block;}
.sl-done{background:rgba(34,197,94,0.2);color:#4ade80;}
.sl-prog{background:rgba(168,85,247,0.2);color:#c4b5fd;}
.sl-lock{background:rgba(255,255,255,0.07);color:rgba(255,255,255,0.35);}
.lock-icon{font-size:28px;margin-bottom:8px;}
.pts-needed{font-size:12px;color:rgba(255,255,255,0.5);}

/* ============ RANKING + CHAT (old) ============ */
#ranking .rank-layout{display:grid;grid-template-columns:1fr 320px;gap:18px;height:calc(100vh - 160px);}
.rank-card{background:linear-gradient(160deg,#2d1260,#3d1a80);border-radius:22px;padding:22px;border:2px solid rgba(168,85,247,0.3);overflow-y:auto;}
.rank-tabs{display:flex;gap:8px;margin-bottom:18px;}
.rank-tab{padding:7px 18px;border-radius:50px;font-size:14px;font-weight:600;cursor:pointer;border:2px solid rgba(168,85,247,0.3);color:#c4b5fd;background:none;font-family:'Fredoka',sans-serif;transition:all 0.2s;}
.rank-tab.active{background:rgba(168,85,247,0.3);border-color:#a855f7;color:white;}
.rank-top3{display:grid;grid-template-columns:1fr 1.2fr 1fr;gap:12px;margin-bottom:22px;align-items:flex-end;}
.top-item{background:rgba(255,255,255,0.06);border-radius:18px;padding:16px 12px;text-align:center;border:2px solid rgba(168,85,247,0.2);}
.top-item.gold{background:linear-gradient(160deg,rgba(249,199,79,0.15),rgba(245,158,11,0.1));border-color:rgba(249,199,79,0.5);transform:scale(1.05);}
.top-item.silver{background:linear-gradient(160deg,rgba(200,200,200,0.1),rgba(160,160,160,0.05));border-color:rgba(200,200,200,0.3);}
.top-item.bronze{background:linear-gradient(160deg,rgba(205,127,50,0.1),rgba(160,100,30,0.05));border-color:rgba(205,127,50,0.3);}
.top-avatar{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 8px;}
.top-item.gold .top-avatar{background:linear-gradient(135deg,#fcd34d,#f59e0b);box-shadow:0 0 16px rgba(249,199,79,0.5);}
.top-item.silver .top-avatar{background:linear-gradient(135deg,#d1d5db,#9ca3af);}
.top-item.bronze .top-avatar{background:linear-gradient(135deg,#d97706,#92400e);}
.top-medal{font-size:22px;margin-bottom:6px;}
.top-name{font-size:13px;font-weight:600;color:white;margin-bottom:4px;}
.top-pts{font-family:'Fredoka One',cursive;font-size:18px;color:#a855f7;}
.top-item.gold .top-pts{color:#fcd34d;}
.rank-list{display:flex;flex-direction:column;gap:8px;}
.rank-row{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,0.05);border-radius:14px;padding:12px 16px;border:1px solid rgba(168,85,247,0.15);transition:all 0.2s;}
.rank-row:hover{background:rgba(168,85,247,0.1);border-color:rgba(168,85,247,0.3);}
.rank-row.me{background:rgba(168,85,247,0.15);border-color:rgba(168,85,247,0.5);}
.rank-pos{font-family:'Fredoka One',cursive;font-size:16px;color:rgba(255,255,255,0.4);width:24px;text-align:center;}
.rank-av{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#a855f7,#6c3fc5);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.rank-info{flex:1;}
.rank-name{font-size:14px;font-weight:600;color:white;}
.rank-sub{font-size:12px;color:rgba(255,255,255,0.5);}
.rank-pts-val{font-family:'Fredoka One',cursive;font-size:16px;color:#a855f7;}
.rank-row.me .rank-pts-val{color:#4ade80;}
.you-badge{background:rgba(34,197,94,0.2);color:#4ade80;font-size:10px;font-weight:700;padding:2px 8px;border-radius:50px;margin-left:6px;}

/* ============ CHAT PAGE — COMPLETO ============ */
#chat .chat-main-layout{
  display:grid;
  grid-template-columns:280px 1fr 300px;
  gap:0;
  height:calc(100vh - 160px);
  background:linear-gradient(160deg,#2d1260,#1e0a3c);
  border-radius:24px;
  overflow:hidden;
  border:2px solid rgba(168,85,247,0.35);
  box-shadow:0 16px 60px rgba(74,31,168,0.5);
}

/* ---- LEFT SIDEBAR: lista de alunos ---- */
.chat-sidebar{
  background:linear-gradient(180deg,#2a1158,#1e0a3c);
  border-right:1px solid rgba(168,85,247,0.2);
  display:flex;
  flex-direction:column;
  overflow:hidden;
}
.sidebar-top{
  padding:18px 16px 12px;
  flex-shrink:0;
}
.sidebar-top-title{
  font-family:'Fredoka One',cursive;
  font-size:17px;color:white;
  display:flex;align-items:center;gap:8px;
  margin-bottom:12px;
}
.sidebar-search{
  position:relative;
  margin-bottom:12px;
}
.sidebar-search input{
  width:100%;
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(168,85,247,0.3);
  border-radius:50px;
  padding:8px 14px 8px 36px;
  color:white;
  font-family:'Fredoka',sans-serif;
  font-size:13px;
  outline:none;
  transition:border 0.2s;
}
.sidebar-search input:focus{border-color:#a855f7;}
.sidebar-search input::placeholder{color:rgba(255,255,255,0.35);}
.sidebar-search .search-ico{
  position:absolute;left:12px;top:50%;transform:translateY(-50%);
  font-size:14px;opacity:0.5;
}

/* Filtros status */
.status-filters{
  display:flex;gap:6px;flex-wrap:wrap;
  padding:0 16px 12px;
  flex-shrink:0;
  border-bottom:1px solid rgba(168,85,247,0.15);
}
.sf-btn{
  padding:5px 12px;border-radius:50px;font-size:12px;font-weight:600;
  cursor:pointer;border:1.5px solid rgba(168,85,247,0.3);
  color:#c4b5fd;background:none;
  font-family:'Fredoka',sans-serif;transition:all 0.2s;
}
.sf-btn.active,.sf-btn:hover{background:rgba(168,85,247,0.25);border-color:#a855f7;color:white;}
.sf-btn.online{border-color:rgba(34,197,94,0.4);color:#4ade80;}
.sf-btn.online.active,.sf-btn.online:hover{background:rgba(34,197,94,0.15);border-color:#4ade80;}

/* Lista de alunos */
.students-list{
  flex:1;overflow-y:auto;
  padding:10px 10px;
  display:flex;flex-direction:column;gap:4px;
}
.students-list::-webkit-scrollbar{width:4px;}
.students-list::-webkit-scrollbar-thumb{background:rgba(168,85,247,0.3);border-radius:4px;}
.student-item{
  display:flex;align-items:center;gap:10px;
  padding:10px 12px;border-radius:14px;
  cursor:pointer;transition:all 0.2s;
  border:1.5px solid transparent;
}
.student-item:hover{background:rgba(168,85,247,0.1);border-color:rgba(168,85,247,0.25);}
.student-item.active-chat{background:rgba(168,85,247,0.2);border-color:rgba(168,85,247,0.5);}
.student-item.active-chat .si-name{color:#e9d5ff;}
.si-av-wrap{position:relative;flex-shrink:0;}
.si-av{
  width:40px;height:40px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:20px;flex-shrink:0;
  border:2px solid rgba(255,255,255,0.15);
}
.si-status-dot{
  position:absolute;bottom:1px;right:1px;
  width:11px;height:11px;border-radius:50%;
  border:2px solid #1e0a3c;
}
.dot-online{background:#22c55e;}
.dot-playing{background:#f9c74f;}
.dot-studying{background:#3b82f6;}
.dot-offline{background:#6b7280;}
.si-info{flex:1;min-width:0;}
.si-name{font-size:14px;font-weight:600;color:white;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.si-meta{font-size:11px;color:rgba(255,255,255,0.45);display:flex;align-items:center;gap:4px;}
.si-pts{font-family:'Fredoka One',cursive;font-size:13px;color:#a855f7;flex-shrink:0;}
.turma-header{
  font-size:10px;font-weight:700;letter-spacing:1px;
  color:rgba(255,255,255,0.3);
  text-transform:uppercase;
  padding:8px 12px 4px;
}

/* ---- CENTER: janela de chat ---- */
.chat-window{
  display:flex;flex-direction:column;
  background:linear-gradient(180deg,#1e0a3c,#180838);
  position:relative;
}

/* fundo decorativo */
.chat-bg-deco{
  position:absolute;inset:0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(168,85,247,0.05) 0%,transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(34,197,94,0.04) 0%,transparent 40%);
  pointer-events:none;
}

/* Header do chat */
.chat-win-header{
  flex-shrink:0;
  display:flex;align-items:center;gap:12px;
  padding:16px 22px;
  border-bottom:1px solid rgba(168,85,247,0.2);
  background:rgba(45,18,96,0.6);
  backdrop-filter:blur(10px);
  position:relative;z-index:2;
}
.cwh-left{display:flex;align-items:center;gap:12px;flex:1;}
.cwh-av{
  width:46px;height:46px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;
  border:2px solid rgba(255,255,255,0.2);
  box-shadow:0 0 12px rgba(168,85,247,0.3);
  flex-shrink:0;
  position:relative;
}
.cwh-av .cwh-status{
  position:absolute;bottom:1px;right:1px;
  width:12px;height:12px;border-radius:50%;border:2px solid #1e0a3c;
}
.cwh-title{font-family:'Fredoka One',cursive;font-size:17px;color:white;}
.cwh-sub{font-size:12px;color:rgba(255,255,255,0.5);}
.cwh-actions{display:flex;gap:8px;}
.cwh-btn{
  width:36px;height:36px;border-radius:50%;
  background:rgba(255,255,255,0.08);
  border:1.5px solid rgba(168,85,247,0.3);
  color:rgba(255,255,255,0.7);font-size:16px;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all 0.2s;
}
.cwh-btn:hover{background:rgba(168,85,247,0.2);color:white;}

/* Messages area */
.chat-messages-area{
  flex:1;overflow-y:auto;
  padding:20px 22px;
  display:flex;flex-direction:column;gap:14px;
  position:relative;z-index:1;
}
.chat-messages-area::-webkit-scrollbar{width:5px;}
.chat-messages-area::-webkit-scrollbar-thumb{background:rgba(168,85,247,0.25);border-radius:4px;}

/* Separador de data */
.date-sep{
  display:flex;align-items:center;gap:10px;
  margin:6px 0;
}
.date-sep span{
  font-size:11px;color:rgba(255,255,255,0.35);
  background:rgba(255,255,255,0.06);
  border-radius:50px;padding:4px 12px;
  white-space:nowrap;
}
.date-sep::before,.date-sep::after{
  content:'';flex:1;height:1px;
  background:rgba(168,85,247,0.15);
}

/* Mensagens */
.msg-row{display:flex;gap:10px;align-items:flex-end;}
.msg-row.me{flex-direction:row-reverse;}
.msg-row-av{
  width:34px;height:34px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;flex-shrink:0;
  border:2px solid rgba(255,255,255,0.12);
}
.msg-row.me .msg-row-av{background:linear-gradient(135deg,#22c55e,#16a34a);}
.msg-body{display:flex;flex-direction:column;gap:3px;max-width:65%;}
.msg-row.me .msg-body{align-items:flex-end;}
.msg-sender{font-size:11px;color:rgba(255,255,255,0.45);margin-bottom:1px;display:flex;align-items:center;gap:5px;}
.sender-rank{background:rgba(168,85,247,0.25);color:#c4b5fd;font-size:10px;font-weight:700;padding:2px 6px;border-radius:50px;}
.msg-bubble-new{
  padding:11px 15px;border-radius:18px;
  font-size:14px;line-height:1.5;color:white;
  position:relative;
}
.msg-row:not(.me) .msg-bubble-new{
  background:rgba(255,255,255,0.09);
  border:1px solid rgba(168,85,247,0.2);
  border-bottom-left-radius:4px;
}
.msg-row.me .msg-bubble-new{
  background:linear-gradient(135deg,#6d28d9,#a855f7);
  border:1px solid rgba(168,85,247,0.4);
  border-bottom-right-radius:4px;
  box-shadow:0 4px 14px rgba(168,85,247,0.25);
}
.msg-time{font-size:10px;color:rgba(255,255,255,0.3);margin-top:2px;}
.msg-row.me .msg-time{text-align:right;}

/* Card especial de pontos */
.pts-share-card{
  background:linear-gradient(135deg,rgba(168,85,247,0.2),rgba(34,197,94,0.1));
  border:1.5px solid rgba(168,85,247,0.4);
  border-radius:16px;padding:12px 16px;
  display:flex;align-items:center;gap:12px;
  max-width:220px;
}
.pts-share-card .psc-icon{font-size:28px;}
.psc-info .psc-label{font-size:11px;color:rgba(255,255,255,0.5);}
.psc-info .psc-val{font-family:'Fredoka One',cursive;font-size:20px;color:#a855f7;}
.psc-info .psc-sub{font-size:11px;color:rgba(255,255,255,0.45);}

/* Mascote conquistado card */
.mascot-share-card{
  background:linear-gradient(135deg,rgba(249,199,79,0.15),rgba(168,85,247,0.1));
  border:1.5px solid rgba(249,199,79,0.4);
  border-radius:16px;padding:12px 16px;
  display:flex;align-items:center;gap:12px;
  max-width:240px;
}
.mascot-share-card .msc-egg{
  width:48px;height:48px;border-radius:50% 50% 50% 50%/60% 60% 40% 40%;
  display:flex;align-items:center;justify-content:center;font-size:24px;
  flex-shrink:0;
}
.msc-info .msc-label{font-size:10px;color:#fbbf24;font-weight:700;letter-spacing:.5px;text-transform:uppercase;}
.msc-info .msc-name{font-family:'Fredoka One',cursive;font-size:15px;color:white;}
.msc-info .msc-pts{font-size:12px;color:rgba(255,255,255,0.5);}

/* Reações */
.msg-reactions{display:flex;gap:4px;margin-top:4px;}
.reaction-pill{
  background:rgba(255,255,255,0.07);
  border:1px solid rgba(168,85,247,0.2);
  border-radius:50px;padding:3px 9px;font-size:12px;
  cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:3px;
}
.reaction-pill:hover,.reaction-pill.active{background:rgba(168,85,247,0.2);border-color:#a855f7;}
.reaction-pill span{font-size:10px;color:rgba(255,255,255,0.5);}

/* Digitando... */
.typing-indicator{
  display:flex;align-items:center;gap:8px;
  padding:8px 14px;background:rgba(255,255,255,0.06);
  border:1px solid rgba(168,85,247,0.15);
  border-radius:16px;border-bottom-left-radius:4px;
  width:fit-content;
}
.typing-dots{display:flex;gap:4px;align-items:center;}
.typing-dots span{
  width:7px;height:7px;border-radius:50%;
  background:#a855f7;opacity:0.4;
  animation:typing-bounce 1.2s ease-in-out infinite;
}
.typing-dots span:nth-child(2){animation-delay:.2s;}
.typing-dots span:nth-child(3){animation-delay:.4s;}
@keyframes typing-bounce{0%,80%,100%{transform:scale(1);opacity:0.4;}40%{transform:scale(1.3);opacity:1;}}
.typing-name{font-size:12px;color:rgba(255,255,255,0.4);}

/* Emoji Picker mini */
.emoji-bar{
  display:flex;gap:6px;
  padding:8px 22px;
  border-top:1px solid rgba(168,85,247,0.1);
  background:rgba(30,10,60,0.5);
  flex-shrink:0;
}
.emoji-quick{
  width:32px;height:32px;border-radius:50%;
  background:rgba(255,255,255,0.07);
  border:1.5px solid rgba(168,85,247,0.2);
  cursor:pointer;font-size:16px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;
}
.emoji-quick:hover{background:rgba(168,85,247,0.2);transform:scale(1.15);}

/* Input area */
.chat-input-area{
  flex-shrink:0;
  padding:14px 22px 18px;
  background:rgba(30,10,60,0.7);
  backdrop-filter:blur(10px);
  border-top:1px solid rgba(168,85,247,0.15);
}
.chat-input-bar{
  display:flex;align-items:center;gap:10px;
  background:rgba(255,255,255,0.07);
  border:1.5px solid rgba(168,85,247,0.3);
  border-radius:50px;padding:8px 8px 8px 18px;
  transition:border 0.2s;
}
.chat-input-bar:focus-within{border-color:#a855f7;box-shadow:0 0 0 3px rgba(168,85,247,0.12);}
.chat-input-bar input{
  flex:1;background:none;border:none;outline:none;
  color:white;font-family:'Fredoka',sans-serif;font-size:15px;
}
.chat-input-bar input::placeholder{color:rgba(255,255,255,0.3);}
.chat-tool-btn{
  width:34px;height:34px;border-radius:50%;
  background:none;border:none;
  color:rgba(255,255,255,0.5);font-size:18px;
  cursor:pointer;transition:all 0.2s;
  display:flex;align-items:center;justify-content:center;
}
.chat-tool-btn:hover{color:white;background:rgba(255,255,255,0.08);}
.chat-send-btn{
  width:40px;height:40px;border-radius:50%;
  background:linear-gradient(135deg,#7c3aed,#a855f7);
  border:none;color:white;font-size:18px;
  cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 12px rgba(168,85,247,0.4);
  transition:all 0.2s;flex-shrink:0;
}
.chat-send-btn:hover{transform:scale(1.08);box-shadow:0 6px 18px rgba(168,85,247,0.5);}

/* ---- RIGHT SIDEBAR: info do aluno ---- */
.chat-info-panel{
  background:linear-gradient(180deg,#2a1158,#1e0a3c);
  border-left:1px solid rgba(168,85,247,0.2);
  display:flex;flex-direction:column;
  overflow-y:auto;
  padding:20px 16px;
  gap:16px;
}
.chat-info-panel::-webkit-scrollbar{width:4px;}
.chat-info-panel::-webkit-scrollbar-thumb{background:rgba(168,85,247,0.25);border-radius:4px;}

.info-profile{
  text-align:center;
  padding-bottom:16px;
  border-bottom:1px solid rgba(168,85,247,0.15);
}
.info-av{
  width:72px;height:72px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:36px;margin:0 auto 10px;
  border:3px solid rgba(168,85,247,0.5);
  box-shadow:0 0 20px rgba(168,85,247,0.3);
}
.info-name{font-family:'Fredoka One',cursive;font-size:16px;color:white;margin-bottom:3px;}
.info-turma{font-size:12px;color:rgba(255,255,255,0.5);margin-bottom:8px;}
.info-status-pill{
  display:inline-flex;align-items:center;gap:5px;
  padding:4px 12px;border-radius:50px;font-size:12px;font-weight:600;
}
.isp-online{background:rgba(34,197,94,0.15);color:#4ade80;border:1px solid rgba(34,197,94,0.3);}
.isp-playing{background:rgba(249,199,79,0.15);color:#fbbf24;border:1px solid rgba(249,199,79,0.3);}
.isp-studying{background:rgba(59,130,246,0.15);color:#93c5fd;border:1px solid rgba(59,130,246,0.3);}
.isp-offline{background:rgba(107,114,128,0.15);color:#9ca3af;border:1px solid rgba(107,114,128,0.3);}
.status-dot-sm{width:7px;height:7px;border-radius:50%;}
.sd-online{background:#22c55e;}
.sd-playing{background:#f9c74f;}
.sd-studying{background:#3b82f6;}
.sd-offline{background:#6b7280;}

.info-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.info-stat{
  background:rgba(255,255,255,0.06);border-radius:12px;
  padding:10px 8px;text-align:center;
  border:1px solid rgba(168,85,247,0.15);
}
.info-stat-num{font-family:'Fredoka One',cursive;font-size:18px;color:#a855f7;}
.info-stat-label{font-size:10px;color:rgba(255,255,255,0.45);}

.info-section-title{
  font-family:'Fredoka One',cursive;font-size:14px;color:rgba(255,255,255,0.7);
  display:flex;align-items:center;gap:6px;margin-bottom:8px;
}

/* mascote do aluno */
.info-mascot{
  background:rgba(168,85,247,0.08);
  border:1.5px solid rgba(168,85,247,0.25);
  border-radius:16px;padding:14px;text-align:center;
}
.info-mascot-egg{
  width:60px;height:60px;
  border-radius:50% 50% 50% 50%/60% 60% 40% 40%;
  display:flex;align-items:center;justify-content:center;
  font-size:30px;margin:0 auto 8px;
  animation:float 3s ease-in-out infinite;
}
.info-mascot-name{font-family:'Fredoka One',cursive;font-size:14px;color:white;margin-bottom:4px;}
.info-mascot-level{font-size:11px;color:#c4b5fd;}

/* Missões recentes */
.info-missions{display:flex;flex-direction:column;gap:6px;}
.info-mission-item{
  display:flex;align-items:center;gap:8px;
  background:rgba(255,255,255,0.05);border-radius:10px;
  padding:8px 10px;border:1px solid rgba(168,85,247,0.12);
}
.im-ico{font-size:16px;width:28px;text-align:center;}
.im-name{font-size:12px;color:white;flex:1;}
.im-pts{font-family:'Fredoka One',cursive;font-size:12px;color:#a855f7;}

/* Convidar / turma buttons */
.info-actions{display:flex;flex-direction:column;gap:8px;}
.ia-btn{
  display:flex;align-items:center;justify-content:center;gap:6px;
  padding:10px 14px;border-radius:12px;
  font-family:'Fredoka',sans-serif;font-size:13px;font-weight:600;
  cursor:pointer;transition:all 0.2s;border:none;
}
.ia-btn-primary{background:linear-gradient(135deg,#a855f7,#7c3aed);color:white;box-shadow:0 4px 12px rgba(168,85,247,0.3);}
.ia-btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(168,85,247,0.4);}
.ia-btn-ghost{background:rgba(255,255,255,0.06);border:1.5px solid rgba(168,85,247,0.25);color:#c4b5fd;}
.ia-btn-ghost:hover{background:rgba(168,85,247,0.15);color:white;}

/* FOOTER */
.footer{background:linear-gradient(135deg,#1e0a3c,#2d1260);padding:28px 36px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;border-top:1px solid rgba(168,85,247,0.2);}
.footer-brand{font-family:'Fredoka One',cursive;color:white;font-size:18px;margin-bottom:4px;}
.footer-desc{color:rgba(255,255,255,0.5);font-size:13px;}
.footer-contact{text-align:center;color:rgba(255,255,255,0.7);}
.footer-contact h3{font-family:'Fredoka One',cursive;font-size:16px;color:white;margin-bottom:4px;}
.footer-email{color:#c4b5fd;font-size:13px;}
.footer-social{width:38px;height:38px;background:rgba(255,255,255,0.08);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;margin:8px auto 0;cursor:pointer;border:1px solid rgba(168,85,247,0.3);}

/* MODAL EGG DETAIL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:100;align-items:center;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal{background:linear-gradient(160deg,#2d1260,#4a1fa8);border-radius:24px;padding:32px;width:360px;border:2px solid rgba(168,85,247,0.5);text-align:center;}
.modal h2{font-family:'Fredoka One',cursive;font-size:22px;color:white;margin-bottom:8px;}
.modal p{font-size:14px;color:rgba(255,255,255,0.7);margin-bottom:20px;}
.modal-egg{width:100px;height:100px;border-radius:50% 50% 50% 50%/60% 60% 40% 40%;display:flex;align-items:center;justify-content:center;font-size:52px;margin:0 auto 16px;animation:float 2s ease-in-out infinite;}
.modal-pts{font-family:'Fredoka One',cursive;font-size:28px;color:#a855f7;margin-bottom:6px;}
.modal-pts-label{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:20px;}
.modal-bar-wrap{width:100%;margin-bottom:20px;}
.modal-bar-label{display:flex;justify-content:space-between;font-size:12px;color:rgba(255,255,255,0.6);margin-bottom:6px;}
.modal-bar{height:10px;background:rgba(255,255,255,0.1);border-radius:50px;overflow:hidden;}
.modal-bar-fill{height:100%;border-radius:50px;background:linear-gradient(90deg,#a855f7,#22c55e);}
.btn-modal-close{background:rgba(255,255,255,0.1);border:2px solid rgba(168,85,247,0.4);color:white;font-family:'Fredoka',sans-serif;font-size:15px;font-weight:600;padding:10px 28px;border-radius:14px;cursor:pointer;width:100%;}

/* Notification toast */
.toast{
  position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(20px);
  background:linear-gradient(135deg,#22c55e,#16a34a);
  color:white;font-family:'Fredoka One',cursive;font-size:15px;
  padding:12px 24px;border-radius:50px;
  box-shadow:0 8px 24px rgba(34,197,94,0.4);
  z-index:200;opacity:0;transition:all 0.3s;pointer-events:none;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* FOOTER STYLES */
.footer-section {
  background: linear-gradient(135deg, #4a1fa8, #6c3fc5);
  border-top: 2px solid rgba(168, 85, 247, 0.3);
  color: rgba(255, 255, 255, 0.9);
  padding: 48px 0 48px 0;
  margin-top: 80px;
  position: relative;
  z-index: 2;
  width: 100%;
  left: 0;
  right: 0;
  box-shadow: 0 -4px 16px rgba(106, 63, 197, 0.28);
}

.footer-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.footer-content {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 32px;
  margin-bottom: 32px;
}

.footer-col h3 {
  font-family: 'Fredoka', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.footer-col nav {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer-col a {
  color: rgba(255, 255, 255, 0.85);
  text-decoration: none;
  font-size: 13px;
  font-family: 'Fredoka', sans-serif;
  transition: color 0.25s ease;
  font-weight: 500;
}

.footer-col a:hover {
  color: #fff;
}

.social-links {
  display: flex;
  gap: 16px;
}

.footer-bottom {
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  padding-top: 20px;
  text-align: center;
}

.footer-bottom p {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.75);
  font-family: 'Fredoka', sans-serif;
}

@media (max-width: 768px) {
  .footer-section {
    padding: 32px 0 32px 0;
    margin-top: 60px;
  }

  .footer-container {
    padding: 0 16px;
  }

  .footer-content {
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 24px;
    margin-bottom: 24px;
  }

  .footer-col h3 {
    font-size: 12px;
  }

  .footer-col a {
    font-size: 12px;
  }

  .social-links {
    flex-direction: column;
    gap: 10px;
  }

  .footer-bottom p {
    font-size: 11px;
  }
}
