<script>
// ---- NAVEGAÇÃO ----
// ---- LOGOUT ----
function abrirModalLogout(){
  document.getElementById('logoutModal').style.display='flex';
}

// ---- NAVEGAÇÃO ----
function goTo(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

// ---- MODAL EGG ----
function openEggModal(name, emoji, cls, pts, total){
  const pct = Math.round((pts/total)*100);
  document.getElementById('modalEggName').textContent = name;
  document.getElementById('modalEggVis').textContent = emoji;
  document.getElementById('modalEggVis').className = 'modal-egg ' + cls;
  document.getElementById('modalEggPts').textContent = pts + ' pts';
  document.getElementById('modalEggPtsLabel').textContent = 'de ' + total + ' pts para evoluir';
  document.getElementById('modalPct').textContent = pct + '%';
  document.getElementById('modalBarFill').style.width = pct + '%';
  document.getElementById('eggModal').classList.add('open');
}
function closeEggModal(){document.getElementById('eggModal').classList.remove('open');}
document.getElementById('eggModal').addEventListener('click',function(e){if(e.target===this)closeEggModal();});

// ---- TOAST ----
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2500);
}

// ---- MENSAGENS PRONTAS ----
const presetTexts = {
  mission:   '🗺️ Vamos fazer uma missão juntos?',
  mascot:    '🥚 Olha meu mascote! Ele evoluiu!',
  challenge: '🏆 Te desafio a completar mais missões do que eu hoje!',
  help:      '💡 Alguém pode me dar uma dica nessa missão?',
  cheer:     '🎉 Parabéns turma! Estamos arrasando hoje!',
  invite:    '🌿 Vem jogar comigo agora!',
  rank:      '🏅 Você viu minha posição no ranking?',
};

function sendPreset(type){
  const text = presetTexts[type];
  if(!text) return;
  const msgs = document.getElementById('chatMsgsMain');
  const typing = document.getElementById('typingIndicator');
  if(typing) msgs.removeChild(typing);

  const now = new Date();
  const time = now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');

  const div = document.createElement('div');
  div.className = 'msg-row me';
  div.innerHTML = `
    <section class="msg-row-av" style="background:linear-gradient(135deg,#22c55e,#16a34a);">🧒</section>
    <section class="msg-body">
      <section class="msg-sender">Você</section>
      <section class="msg-bubble-new">${text}</section>
      <section class="msg-time">${time}</section>
    </section>`;
  msgs.appendChild(div);
  if(typing) msgs.appendChild(typing);
  msgs.scrollTop = msgs.scrollHeight;
  showToast('✅ Mensagem enviada!');

  // simula resposta
  setTimeout(()=>{
    const t2 = document.getElementById('typingIndicator');
    if(t2) t2.style.display='flex';
    msgs.scrollTop = msgs.scrollHeight;
    setTimeout(()=>{
      if(t2) t2.style.display='none';
      const responses = [
        {av:'👧',bg:'#fcd34d,#f59e0b',name:'Ana Beatriz',text:'Boa! Vamos juntos! 🌟'},
        {av:'🧒',bg:'#93c5fd,#3b82f6',name:'Pedro',text:'Conta comigo! 🔥'},
        {av:'👧',bg:'#f9a8d4,#ec4899',name:'Maria',text:'Que demais! 💜'},
        {av:'🧒',bg:'#86efac,#22c55e',name:'Lucas',text:'Mandou bem! 🌿'},
      ];
      const r = responses[Math.floor(Math.random()*responses.length)];
      const t3 = new Date();
      const rt = t3.getHours().toString().padStart(2,'0')+':'+t3.getMinutes().toString().padStart(2,'0');
      const rdiv = document.createElement('div');
      rdiv.className='msg-row';
      rdiv.innerHTML=`
        <section class="msg-row-av" style="background:linear-gradient(135deg,${r.bg});">${r.av}</section>
        <section class="msg-body">
          <section class="msg-sender">${r.name}</section>
          <section class="msg-bubble-new">${r.text}</section>
          <section class="msg-time">${rt}</section>
        </section>`;
      msgs.appendChild(rdiv);
      msgs.scrollTop = msgs.scrollHeight;
    },1800);
  },600);
}

// ---- CHAT RANKING ----
function sendMsgRanking(type){
  const msgs = document.getElementById('chatMessagesRanking');
  const presetTexts = {
    mission:   '🗺️ Vamos fazer uma missão juntos?',
    points:    '⭐ Quer ver meus pontos?',
    challenge: '🏆 Te desafio hoje!',
    cheer:     '🎉 Parabéns turma!',
    invite:    '🌿 Vem jogar comigo agora!',
  };
  const text = presetTexts[type];
  if(!text) return;
  const now = new Date();
  const time = now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');
  const div = document.createElement('div');
  div.style.cssText='display:flex;gap:8px;align-items:flex-end;flex-direction:row-reverse;';
  div.innerHTML = `<section style="width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,#22c55e,#16a34a);display:flex;align-items:center;justify-content:center;font-size:14px;">🧒</section><section style="text-align:right"><section style="font-size:10px;color:rgba(255,255,255,0.45);margin-bottom:2px;">Você • ${time}</section><section style="max-width:200px;padding:9px 13px;border-radius:16px;font-size:13px;line-height:1.4;background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;border-bottom-right-radius:4px;">${text}</section></section>`;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  showToast('✅ Mensagem enviada!');
}

// ---- ABRIR CHAT COM ALUNO ----
const studentData = {
  turma: {name:'Chat Geral', sub:'5° Ano D • Turma inteira', av:'💬', avBg:'linear-gradient(135deg,#a855f7,#22c55e)', status:'isp-online', statusTxt:'8 online', statusDot:'sd-online'},
  ana: {name:'Ana Beatriz', sub:'5° Ano D • 720 pts', av:'👧', avBg:'linear-gradient(135deg,#fcd34d,#f59e0b)', status:'isp-online', statusTxt:'Online', statusDot:'sd-online'},
  pedro: {name:'Pedro', sub:'5° Ano D • 580 pts', av:'🧒', avBg:'linear-gradient(135deg,#93c5fd,#3b82f6)', status:'isp-online', statusTxt:'Online', statusDot:'sd-online'},
  lucas: {name:'Lucas', sub:'5° Ano D • 390 pts', av:'🧒', avBg:'linear-gradient(135deg,#86efac,#22c55e)', status:'isp-studying', statusTxt:'Estudando', statusDot:'sd-studying'},
  maria: {name:'Maria', sub:'5° Ano D • 350 pts', av:'👧', avBg:'linear-gradient(135deg,#f9a8d4,#ec4899)', status:'isp-online', statusTxt:'Online', statusDot:'sd-online'},
  rafael: {name:'Rafael', sub:'5° Ano D • 310 pts', av:'🧒', avBg:'linear-gradient(135deg,#fed7aa,#f97316)', status:'isp-playing', statusTxt:'Jogando', statusDot:'sd-playing'},
  isabela: {name:'Isabela', sub:'5° Ano D • 280 pts', av:'👧', avBg:'linear-gradient(135deg,#c4b5fd,#8b5cf6)', status:'isp-online', statusTxt:'Online', statusDot:'sd-online'},
  carla: {name:'Carla', sub:'5° Ano D • 260 pts', av:'👧', avBg:'linear-gradient(135deg,#99f6e4,#14b8a6)', status:'isp-studying', statusTxt:'Estudando', statusDot:'sd-studying'},
  gustavo: {name:'Gustavo', sub:'5° Ano D • 220 pts', av:'🧒', avBg:'linear-gradient(135deg,#6b7280,#4b5563)', status:'isp-offline', statusTxt:'Offline', statusDot:'sd-offline'},
  vitoria: {name:'Vitória', sub:'5° Ano D • 195 pts', av:'👧', avBg:'linear-gradient(135deg,#fde68a,#fbbf24)', status:'isp-playing', statusTxt:'Jogando', statusDot:'sd-playing'},
  henrique: {name:'Henrique', sub:'5° Ano D • 150 pts', av:'🧒', avBg:'linear-gradient(135deg,#6b7280,#4b5563)', status:'isp-offline', statusTxt:'Offline', statusDot:'sd-offline'},
};

function openChat(id){
  // highlight sidebar
  document.querySelectorAll('.student-item').forEach(el=>el.classList.remove('active-chat'));
  event.currentTarget.classList.add('active-chat');

  const d = studentData[id];
  if(!d) return;

  // atualiza header
  document.getElementById('cwh-av-el').innerHTML = d.av + `<section class="cwh-status ${d.statusDot}" style="position:absolute;bottom:1px;right:1px;width:12px;height:12px;border-radius:50%;border:2px solid #1e0a3c;"></section>`;
  document.getElementById('cwh-av-el').style.background = d.avBg;
  document.getElementById('cwh-title').textContent = id==='turma' ? 'Chat Geral — 5° Ano D' : d.name;
  document.getElementById('cwh-sub').textContent = d.sub;

  // atualiza painel info
  document.getElementById('info-av').textContent = d.av;
  document.getElementById('info-av').style.background = d.avBg;
  document.getElementById('info-name').textContent = d.name;
  document.getElementById('info-sub').textContent = d.sub;
  const sp = document.getElementById('info-status');
  sp.className = 'info-status-pill '+d.status;
  sp.innerHTML = `<section class="status-dot-sm ${d.statusDot}"></section> ${d.statusTxt}`;

  if(id !== 'turma'){
    document.getElementById('info-stats').innerHTML = `
      <section class="info-stat"><section class="info-stat-num">${Math.floor(Math.random()*15)+1}</section><section class="info-stat-label">Msgs hoje</section></section>
      <section class="info-stat"><section class="info-stat-num">${Math.floor(Math.random()*8)+2}</section><section class="info-stat-label">Missões</section></section>
      <section class="info-stat"><section class="info-stat-num">${Math.floor(Math.random()*5)+1}</section><section class="info-stat-label">Mascotes</section></section>
      <section class="info-stat"><section class="info-stat-num">${Math.floor(Math.random()*10)+1}</section><section class="info-stat-label">Ranking</section></section>`;
  }

  // limpa mensagens ao trocar de chat
  const msgs = document.getElementById('chatMsgsMain');
  const typing = document.getElementById('typingIndicator');
  msgs.innerHTML = '';
  if(typing) msgs.appendChild(typing);
}

// ---- REAÇÕES ----
function toggleReaction(el){
  const isActive = el.classList.contains('active');
  const num = el.querySelector('span');
  const count = parseInt(num.textContent);
  if(isActive){el.classList.remove('active');num.textContent=count-1;}
  else{el.classList.add('active');num.textContent=count+1;}
}

// ---- COMPARTILHAR PONTOS ----
function sharePoints(){
  const msgs = document.getElementById('chatMsgsMain');
  const typing = document.getElementById('typingIndicator');
  if(typing) msgs.removeChild(typing);
  const now = new Date();
  const time = now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');
  const div = document.createElement('div');
  div.className='msg-row me';
  div.innerHTML=`
    <section class="msg-row-av" style="background:linear-gradient(135deg,#22c55e,#16a34a);">🧒</section>
    <section class="msg-body">
      <section class="msg-sender">Você</section>
      <section class="pts-share-card">
        <section class="psc-icon">⭐</section>
        <section class="psc-info">
          <section class="psc-label">Meus pontos</section>
          <section class="psc-val">420 pts</section>
          <section class="psc-sub">🥉 3° lugar no ranking</section>
        </section>
      </section>
      <section class="msg-time">${time}</section>
    </section>`;
  msgs.appendChild(div);
  if(typing) msgs.appendChild(typing);
  msgs.scrollTop = msgs.scrollHeight;
  showToast('⭐ Pontos compartilhados!');
}

// ---- FILTROS ----
function filterByStatus(status, btn){
  document.querySelectorAll('.sf-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.student-item[data-status]').forEach(el=>{
    const s = el.getAttribute('data-status');
    el.style.display = (status==='todos'||s===status) ? 'flex' : 'none';
  });
  // sempre mostra chat da turma
  const turmaItem = document.querySelector('[data-status="turma"]');
  if(turmaItem && status !== 'todos') turmaItem.style.display='flex';
}

function filterStudents(query){
  const q = query.toLowerCase().trim();
  document.querySelectorAll('.student-item[data-name]').forEach(el=>{
    const name = el.getAttribute('data-name')||'';
    el.style.display = (!q || name.includes(q)) ? 'flex' : 'none';
  });
}

// Scroll inicial
setTimeout(()=>{
  const m = document.getElementById('chatMsgsMain');
  if(m) m.scrollTop = m.scrollHeight;
},100);
</script>







