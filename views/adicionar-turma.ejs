<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Adicionar Turma</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@700;800&family=Fredoka:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/aluno-redesign.css">
  <link rel="stylesheet" href="/css/btn-voltar.css">
  <link rel="stylesheet" href="/css/aluno.css">
  <link rel="stylesheet" href="/css/premium-aluno.css">
  <link rel="stylesheet" href="/css/index.css">
  <link rel="stylesheet" href="/css/adicionar-turma.css">
  <meta property="og:title" content="Pequenos Exploradores - Grandes descobertas começam aqui!" />
  <meta property="og:description" content="Ensine crianças a proteger o meio ambiente com desafios e aventuras educativas divertidas." />
  <meta property="og:image" content="https://pequenos-exploradores.onrender.com/img/capas.jpg" />
  <meta property="og:url" content="https://pequenos-exploradores.onrender.com/" />
  <meta property="og:type" content="website" />
</head>
<body>
  <style>
    .nav-links-redesign {
      margin-left: 0px !important;
    }
  </style>
  <script>
    if (localStorage.getItem('premiumAluno') === 'true') {
      document.body.classList.add('premium-aluno');
    }
  </script>

  <!-- NAVBAR -->
  <nav class="navbar-redesign">
    <section class="logo-redesign">
      <img src="/img/log.png" alt="Logo Pequenos Exploradores">
    </section>
    <section class="nav-links-redesign">
      <a class="nav-link-redesign" href="/">Início</a>
      <a class="nav-link-redesign" href="/sobre">Sobre</a>
      <a class="nav-link-redesign" href="https://www.instagram.com/pequenos_.exploradores_?igsh=MWthZnZ6eG1xeDlxdw==" target="_blank" rel="noopener">Contato</a>
    </section>
    <section class="nav-right-redesign">
      <button class="btn-sair-redesign" onclick="abrirModalLogout()">Sair</button>
    </section>
  </nav>

  <section id="modal-overlay-turma" onclick="fecharModalTurma(event)">
    <section id="modal-turma" onclick="event.stopPropagation()">
      <button class="modal-turma-close" onclick="fecharModalTurma(event)">&times;</button>
      <section id="modal-turma-titulo">Participar da turma:</section>
      <section class="modal-turma-bloco">
        <label for="senha-turma">Senha de acesso:</label>
        <small>Peça para seu professor a senha da turma e digite-o aqui.</small>
        <input type="password" id="senha-turma" class="modal-turma-input" placeholder="Digite a senha" autocomplete="off">
        <button class="modal-turma-btn">Participar</button>
      </section>
    </section>
  </section>

  <main class="container-turma">
    <section class="turma-ilustracao" aria-label="Ilustração de turma">
     
      <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="14" width="48" height="30" rx="5" fill="#bdbdbd"/>
        <rect x="16" y="22" width="32" height="14" rx="2" fill="#fff"/>
        <rect x="24" y="48" width="16" height="6" rx="2" fill="#bdbdbd"/>
        <rect x="28" y="54" width="8" height="2" rx="1" fill="#bdbdbd"/>
      </svg>
    </section>
    <section class="turma-texto">
      Adicione uma turma para começar
    </section>
    <button class="turma-btn" onclick="abrirModalTurma()">Participar da turma</button>
  </main>
</body>
  <%- include('partials/footer') %>
</main>
<script>
  function abrirModalTurma() {
    document.getElementById('modal-overlay-turma').style.display = 'flex';
  }
  function fecharModalTurma(e) {
    document.getElementById('modal-overlay-turma').style.display = 'none';
  }
  // Redireciona ao clicar em Participar
  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.querySelector('.modal-turma-btn');
    if(btn) {
      btn.onclick = function() {
        window.location.href = '/turma';
      };
    }
  });
</script>
</html>
