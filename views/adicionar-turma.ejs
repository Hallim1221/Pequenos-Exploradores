<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PlanetaR - Plataforma Educacional</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Baloo+2:wght@700;800&family=Fredoka:wght@400;700&family=Fredoka+One&display=swap" rel="stylesheet">
<style>
  :root {
    --green-dark: #2d7a2d;
    --green-main: #4caf50;
    --green-light: #81c784;
    --green-pale: #e8f5e9;
    --green-mid: #66bb6a;
    --yellow: #ffc107;
    --yellow-light: #fff9c4;
    --orange: #ff9800;
    --blue: #29b6f6;
    --blue-light: #e1f5fe;
    --red: #ef5350;
    --white: #ffffff;
    --gray-light: #f5f5f5;
    --gray: #9e9e9e;
    --text-dark: #1b2e1b;
    --text-mid: #4a4a4a;
    --radius-xl: 24px;
    --radius-lg: 16px;
    --radius-md: 12px;
    --radius-full: 999px;
    --shadow: 0 4px 20px rgba(0,0,0,0.1);
    --shadow-hover: 0 8px 32px rgba(76,175,80,0.25);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--gray-light);
    color: var(--text-dark);
    min-height: 100vh;
  }

  /* ── PAGES ─────────────────────────────── */
  .page { display: none; min-height: 100vh; flex-direction: column; }
  .page.active { display: flex; }

  /* ── NAVBAR REDESIGN ─────────────────────────────── */
  .navbar-redesign{background:#61b231;padding:0 40px;height:72px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 16px rgba(97,178,49,.28);position:fixed;top:0;left:0;right:0;width:100%;z-index:9000;}
  .logo-redesign{display:flex;align-items:center;gap:16px;margin-left:-32px;font-family:'Baloo 2',cursive;font-size:30px;color:white;text-shadow:2px 2px 0 rgba(0,0,0,.15);}
  .logo-redesign img{width:145px;height:94px;object-fit:contain;}
  .nav-links-redesign{display:flex;gap:8px;align-items:center;margin-left:130px;}
  .nav-link-redesign{color:rgba(255,255,255,.9);font-size:16px;font-weight:600;padding:8px 18px;border-radius:50px;text-decoration:none;transition:all .2s;cursor:pointer;}
  .nav-link-redesign:hover,.nav-link-redesign.active{background:rgba(255,255,255,.25);color:white;}
  .nav-right-redesign{display:flex;align-items:center;gap:16px;}
  .btn-sair-redesign{background:rgba(255,255,255,.2);border:2px solid rgba(255,255,255,.5);color:white;font-family:'Fredoka',sans-serif;font-size:16px;font-weight:600;padding:7px 22px;border-radius:50px;cursor:pointer;transition:all .2s;}
  .btn-sair-redesign:hover{background:rgba(255,255,255,.35);}
  .bell-btn-redesign{position:relative;background:rgba(255,255,255,.2);border:none;border-radius:50%;width:44px;height:44px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:20px;transition:all .2s;}
  .bell-btn-redesign:hover{background:rgba(255,255,255,.35);}
  .bell-badge-redesign{position:absolute;top:4px;right:4px;background:#FFD600;color:#7c5800;font-size:10px;font-weight:700;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;}
  body{padding-top:72px;}

  /* ── HERO BANNER ─────────────────────── */
  .hero {
    background: linear-gradient(135deg, var(--green-main) 0%, var(--green-dark) 100%);
    margin: 24px; border-radius: var(--radius-xl);
    padding: 28px 36px;
    display: flex; justify-content: space-between; align-items: center;
    box-shadow: var(--shadow-hover);
  }
  .hero h1 { font-size: 1.9rem; color: white; font-weight: 900; }
  .hero p { color: rgba(255,255,255,0.85); font-size: 1rem; margin-top: 4px; }
  .xp-badge {
    background: rgba(255,255,255,0.15); border: 2px solid rgba(255,255,255,0.3);
    border-radius: var(--radius-full); padding: 10px 22px;
    color: white; font-weight: 800; font-size: 1rem;
    display: flex; align-items: center; gap: 8px; white-space: nowrap;
  }

  /* ── TAB BAR ─────────────────────────── */
  .tab-bar {
    display: flex; gap: 10px; padding: 0 24px 16px;
    overflow-x: auto;
  }
  .tab {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 22px; border-radius: var(--radius-full);
    font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 0.95rem;
    cursor: pointer; border: 2.5px solid transparent;
    background: white; color: var(--text-mid);
    transition: all .2s; white-space: nowrap;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  }
  .tab.active {
    background: var(--green-main); color: white;
    border-color: var(--green-dark);
    box-shadow: 0 4px 14px rgba(76,175,80,0.35);
  }
  .tab:hover:not(.active) { border-color: var(--green-light); color: var(--green-dark); }

  /* ── MAIN CONTENT ─────────────────────── */
  main { padding: 0 24px 40px; flex: 1; }

  /* ── CARD GRID ─────────────────────────── */
  .card-grid {
    display: grid; grid-template-columns: 280px 1fr;
    gap: 20px;
  }

  /* ── PROFILE CARD ─────────────────────── */
  .profile-card {
    background: white; border-radius: var(--radius-xl);
    padding: 28px 20px; text-align: center;
    box-shadow: var(--shadow);
  }
  .avatar-ring {
    width: 100px; height: 100px; border-radius: 50%;
    border: 4px solid var(--green-main);
    display: grid; place-items: center;
    margin: 0 auto 14px; font-size: 3rem;
    background: var(--green-pale); position: relative;
  }
  .avatar-edit {
    position: absolute; bottom: 0; right: 0;
    width: 28px; height: 28px; background: var(--green-main);
    border-radius: 50%; display: grid; place-items: center;
    font-size: 0.75rem; color: white; cursor: pointer;
  }
  .profile-name { font-weight: 800; font-size: 1rem; }
  .profile-label { font-size: 0.72rem; color: var(--green-main); font-weight: 700; letter-spacing: .05em; margin-top: 12px; }
  .profile-school { font-size: 0.88rem; color: var(--text-mid); font-weight: 600; }
  .profile-divider { height: 1px; background: var(--gray-light); margin: 14px 0; }
  .profile-stat {
    display: flex; justify-content: space-between;
    font-size: 0.88rem; padding: 4px 0;
    color: var(--text-mid);
  }
  .profile-stat strong { color: var(--text-dark); }

  /* ── MISSIONS CARD ─────────────────────── */
  .missions-card {
    background: white; border-radius: var(--radius-xl);
    padding: 28px; box-shadow: var(--shadow);
  }
  .section-title {
    font-family: 'Fredoka One', cursive;
    font-size: 1.4rem; color: var(--text-dark);
    display: flex; align-items: center; gap: 10px;
    margin-bottom: 20px;
  }
  .missions-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
  }
  .mission-item {
    border-radius: var(--radius-lg); padding: 20px 14px;
    text-align: center; cursor: pointer;
    transition: transform .2s, box-shadow .2s;
    border: 2px solid transparent;
  }
  .mission-item:hover { transform: translateY(-3px); box-shadow: var(--shadow-hover); }
  .mission-item.done { background: #f0fff0; border-color: var(--green-light); }
  .mission-item.ongoing { background: #fff8e1; border-color: var(--yellow); }
  .mission-item.new { background: #e1f5fe; border-color: var(--blue); }
  .mission-item.locked { background: #f5f5f5; border-color: #ddd; opacity: 0.7; cursor: not-allowed; }
  .mission-icon { font-size: 2.2rem; margin-bottom: 10px; }
  .mission-name { font-weight: 800; font-size: 0.9rem; }
  .mission-tag {
    margin-top: 8px; padding: 4px 10px; border-radius: var(--radius-full);
    font-size: 0.72rem; font-weight: 700; display: inline-block;
  }
  .tag-done { background: var(--green-main); color: white; }
  .tag-ongoing { background: var(--orange); color: white; }
  .tag-new { background: var(--blue); color: white; }
  .tag-locked { background: var(--gray); color: white; }

  /* ─────────────────────────────────────── */
  /* PAGE: TURMAS */
  /* ─────────────────────────────────────── */
  .page-header {
    background: linear-gradient(135deg, var(--green-main), var(--green-dark));
    margin: 24px; border-radius: var(--radius-xl);
    padding: 24px 32px; color: white;
    box-shadow: var(--shadow-hover);
  }
  .page-header h2 { font-family: 'Fredoka One', cursive; font-size: 1.8rem; }
  .page-header p { opacity: .85; margin-top: 4px; font-size: 0.95rem; }

  .turmas-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px; padding: 0 24px;
  }

  .turma-card {
    background: white; border-radius: var(--radius-xl);
    overflow: hidden; cursor: pointer;
    box-shadow: var(--shadow); transition: all .25s;
    border: 2.5px solid transparent;
  }
  .turma-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-hover);
    border-color: var(--green-main);
  }
  .turma-card-top {
    background: linear-gradient(135deg, var(--green-main), var(--green-dark));
    padding: 28px 22px; color: white; position: relative; overflow: hidden;
  }
  .turma-card-top::before {
    content: '🌿'; position: absolute; right: -8px; top: -8px;
    font-size: 5rem; opacity: .18;
  }
  .turma-card-name { font-family: 'Fredoka One', cursive; font-size: 1.25rem; }
  .turma-card-sub { font-size: 0.82rem; opacity: .85; margin-top: 4px; }
  .turma-card-bottom { padding: 16px 22px; }
  .turma-info-row {
    display: flex; align-items: center; gap: 8px;
    font-size: 0.85rem; color: var(--text-mid); margin-bottom: 8px;
  }
  .turma-info-row span { font-size: 1rem; }
  .turma-activities {
    display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px;
  }
  .activity-chip {
    padding: 3px 10px; border-radius: var(--radius-full);
    font-size: 0.72rem; font-weight: 700;
    background: var(--green-pale); color: var(--green-dark);
  }
  .add-turma-card {
    background: white; border-radius: var(--radius-xl);
    border: 2.5px dashed var(--green-light);
    min-height: 180px; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: 12px;
    cursor: pointer; transition: all .2s; color: var(--green-main);
  }
  .add-turma-card:hover {
    background: var(--green-pale); border-color: var(--green-main);
    transform: translateY(-4px);
  }
  .add-icon {
    width: 56px; height: 56px; background: var(--green-pale);
    border-radius: 50%; display: grid; place-items: center;
    font-size: 1.6rem; transition: all .2s;
  }
  .add-turma-card:hover .add-icon { background: var(--green-main); color: white; }
  .add-turma-card p { font-weight: 800; font-size: 0.95rem; }

  /* ─────────────────────────────────────── */
  /* PAGE: TURMA DETALHE */
  /* ─────────────────────────────────────── */
  .turma-detail-header {
    background: linear-gradient(135deg, var(--green-main), var(--green-dark));
    margin: 24px; border-radius: var(--radius-xl);
    padding: 28px 32px; color: white;
    box-shadow: var(--shadow-hover);
    display: flex; justify-content: space-between; align-items: flex-start;
  }
  .turma-detail-header h2 { font-family: 'Fredoka One', cursive; font-size: 2rem; }
  .turma-detail-header p { opacity: .85; margin-top: 6px; }
  .turma-code-badge {
    background: rgba(255,255,255,0.2); border: 2px solid rgba(255,255,255,0.4);
    border-radius: var(--radius-lg); padding: 10px 18px; text-align: center;
  }
  .turma-code-badge .label { font-size: 0.72rem; opacity: .8; text-transform: uppercase; letter-spacing: .08em; }
  .turma-code-badge .code { font-family: 'Fredoka One', cursive; font-size: 1.8rem; letter-spacing: .15em; }

  .sub-tabs {
    display: flex; gap: 4px; padding: 0 24px 20px;
    border-bottom: 1px solid #e0e0e0; margin: 0 24px 20px;
  }
  .sub-tab {
    padding: 9px 22px; border-radius: var(--radius-full);
    font-family: 'Nunito', sans-serif; font-weight: 700;
    cursor: pointer; border: none; background: transparent;
    color: var(--gray); font-size: 0.95rem; transition: all .2s;
    border-bottom: 3px solid transparent;
  }
  .sub-tab.active { color: var(--green-main); border-bottom-color: var(--green-main); }
  .sub-tab:hover:not(.active) { color: var(--text-dark); }

  .pessoas-section { padding: 0 24px; }
  .pessoas-label {
    font-family: 'Fredoka One', cursive; color: var(--green-main);
    font-size: 1.1rem; margin-bottom: 14px;
  }
  .pessoa-card {
    display: flex; align-items: center; gap: 14px;
    background: white; border-radius: var(--radius-lg);
    padding: 14px 18px; margin-bottom: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    transition: box-shadow .2s;
  }
  .pessoa-card:hover { box-shadow: var(--shadow-hover); }
  .pessoa-avatar {
    width: 46px; height: 46px; border-radius: 50%;
    background: var(--green-pale); display: grid; place-items: center;
    font-size: 1.5rem; flex-shrink: 0;
  }
  .pessoa-name { font-weight: 800; font-size: 0.95rem; }
  .pessoa-meta { font-size: 0.8rem; color: var(--gray); }
  .pessoa-xp {
    margin-left: auto; display: flex; align-items: center; gap: 8px;
  }
  .xp-mini {
    background: var(--yellow-light); color: var(--text-dark);
    padding: 4px 12px; border-radius: var(--radius-full);
    font-size: 0.8rem; font-weight: 700;
  }
  .progress-mini {
    width: 80px; height: 8px; background: #e0e0e0; border-radius: 4px; overflow: hidden;
  }
  .progress-fill { height: 100%; background: var(--green-main); border-radius: 4px; }

  /* ─────────────────────────────────────── */
  /* MODAL: ENTRAR NA TURMA */
  /* ─────────────────────────────────────── */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.5);
    display: none; place-items: center; z-index: 200;
    backdrop-filter: blur(4px);
  }
  .modal-overlay.open { display: grid; }
  .modal {
    background: white; border-radius: var(--radius-xl);
    width: 90%; max-width: 440px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    overflow: hidden;
    animation: popIn .3s ease;
  }
  @keyframes popIn {
    from { transform: scale(.85); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
  .modal-header {
    background: linear-gradient(135deg, var(--green-main), var(--green-dark));
    padding: 24px 28px; color: white;
    display: flex; justify-content: space-between; align-items: center;
  }
  .modal-header h3 { font-family: 'Fredoka One', cursive; font-size: 1.4rem; }
  .modal-close {
    background: rgba(255,255,255,0.2); border: none; color: white;
    width: 32px; height: 32px; border-radius: 50%; cursor: pointer;
    font-size: 1.1rem; display: grid; place-items: center;
  }
  .modal-body { padding: 28px; }
  .modal-body p { font-size: 0.9rem; color: var(--text-mid); margin-bottom: 16px; }
  .code-inputs {
    display: flex; gap: 10px; justify-content: center; margin: 20px 0;
  }
  .code-input {
    width: 52px; height: 60px; border: 2.5px solid #e0e0e0;
    border-radius: var(--radius-md); text-align: center;
    font-family: 'Fredoka One', cursive; font-size: 1.8rem;
    color: var(--green-dark); outline: none;
    transition: border-color .2s, box-shadow .2s;
    background: var(--green-pale);
    text-transform: uppercase;
  }
  .code-input:focus { border-color: var(--green-main); box-shadow: 0 0 0 3px rgba(76,175,80,0.2); }
  .code-hint {
    background: var(--green-pale); border-radius: var(--radius-md);
    padding: 12px 16px; font-size: 0.85rem; color: var(--green-dark);
    display: flex; align-items: center; gap: 8px; margin-bottom: 20px;
  }
  .btn-participar {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, var(--green-main), var(--green-dark));
    color: white; border: none; border-radius: var(--radius-full);
    font-family: 'Nunito', sans-serif; font-weight: 800; font-size: 1rem;
    cursor: pointer; transition: all .2s;
    box-shadow: 0 4px 14px rgba(76,175,80,0.4);
  }
  .btn-participar:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(76,175,80,0.5); }

  /* ─────────────────────────────────────── */
  /* PAGE: ATIVIDADES */
  /* ─────────────────────────────────────── */
  .atividades-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px; padding: 0 24px;
  }
  .atividade-card {
    background: white; border-radius: var(--radius-xl);
    overflow: hidden; box-shadow: var(--shadow);
    cursor: pointer; transition: all .25s; border: 2.5px solid transparent;
  }
  .atividade-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); border-color: var(--green-main); }
  .atividade-top {
    padding: 24px; display: flex; align-items: center; gap: 14px;
  }
  .atividade-emoji { font-size: 2.5rem; }
  .atividade-title { font-family: 'Fredoka One', cursive; font-size: 1.1rem; color: var(--green-dark); }
  .atividade-desc { font-size: 0.82rem; color: var(--text-mid); margin-top: 4px; }
  .atividade-bottom {
    padding: 14px 24px; border-top: 1px solid var(--gray-light);
    display: flex; justify-content: space-between; align-items: center;
  }
  .btn-jogar {
    background: linear-gradient(135deg, var(--yellow), var(--orange));
    color: white; border: none; border-radius: var(--radius-full);
    padding: 8px 22px; font-family: 'Nunito', sans-serif;
    font-weight: 800; font-size: 0.88rem; cursor: pointer;
    transition: all .2s; box-shadow: 0 3px 10px rgba(255,152,0,0.3);
  }
  .btn-jogar:hover { transform: scale(1.05); }
  .difficulty {
    font-size: 0.78rem; color: var(--gray); font-weight: 700;
  }
  .stars { color: var(--yellow); font-size: 0.85rem; }

  /* ─────────────────────────────────────── */
  /* PAGE: RANKING */
  /* ─────────────────────────────────────── */
  .ranking-container { padding: 0 24px; }
  .ranking-podium {
    display: flex; justify-content: center; align-items: flex-end;
    gap: 12px; margin-bottom: 28px;
  }
  .podium-item {
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    background: white; border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    padding: 16px 20px 0; box-shadow: var(--shadow);
    position: relative;
  }
  .podium-item.first { height: 160px; }
  .podium-item.second { height: 130px; }
  .podium-item.third { height: 110px; }
  .podium-emoji { font-size: 2rem; }
  .podium-name { font-weight: 800; font-size: 0.85rem; text-align: center; }
  .podium-xp { font-size: 0.78rem; color: var(--green-main); font-weight: 700; }
  .podium-medal { position: absolute; top: -16px; font-size: 1.6rem; }
  .ranking-list { display: flex; flex-direction: column; gap: 10px; }
  .ranking-row {
    display: flex; align-items: center; gap: 14px;
    background: white; border-radius: var(--radius-lg);
    padding: 14px 18px; box-shadow: 0 2px 8px rgba(0,0,0,0.07);
  }
  .ranking-pos {
    width: 30px; height: 30px; border-radius: 50%;
    background: var(--green-pale); color: var(--green-dark);
    font-weight: 900; font-size: 0.9rem; display: grid; place-items: center;
    flex-shrink: 0;
  }
  .ranking-row.me { background: var(--green-pale); border: 2px solid var(--green-main); }
  .ranking-row.me .ranking-pos { background: var(--green-main); color: white; }

  /* ─────────────────────────────────────── */
  /* TOAST ─────────────────────────────── */
  .toast {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(100px);
    background: var(--green-dark); color: white; padding: 14px 28px;
    border-radius: var(--radius-full); font-weight: 700; font-size: 0.95rem;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2); z-index: 300;
    transition: transform .35s cubic-bezier(.34,1.56,.64,1);
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ─────────────────────────────────────── */
  /* EMPTY STATE ─────────────────────────── */
  .empty-state {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 16px; padding: 60px 20px;
    color: var(--gray); text-align: center;
  }
  .empty-icon { font-size: 4rem; opacity: .5; }
  .empty-state p { font-weight: 700; font-size: 1rem; }

  /* responsive */
  @media (max-width: 700px) {
    .card-grid { grid-template-columns: 1fr; }
    .missions-grid { grid-template-columns: repeat(2, 1fr); }
    .hero { flex-direction: column; gap: 16px; }
    nav { padding: 0 16px; }
    .turmas-grid { grid-template-columns: 1fr; }
  }

  /* BACK BUTTON */
  .back-btn-voltar {
    position: fixed;
    top: 90px;
    left: 20px;
    z-index: 1000;
    background: #27a844;
    color: white;
    border: none;
    border-radius: 50px;
    padding: 10px 18px;
    font-family: 'Fredoka One', sans-serif;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 4px 12px rgba(39, 168, 68, 0.3);
    transition: all 0.2s ease;
  }
  .back-btn-voltar:hover {
    background: #1b7a30;
    transform: translateX(-3px);
