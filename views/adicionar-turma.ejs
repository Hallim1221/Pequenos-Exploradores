    </header>
    <section class="modal-body">
      <section class="code-hint">
        📋 Peça o <strong>código de 4 letras</strong> para a sua professora e digite abaixo!
      </section>
      <fieldset class="code-inputs">
        <input class="code-input" maxlength="1" id="c1" oninput="nextCode(this,'c2')" onkeydown="prevCode(event,null,'c1')">
        <input class="code-input" maxlength="1" id="c2" oninput="nextCode(this,'c3')" onkeydown="prevCode(event,'c1','c2')">
        <input class="code-input" maxlength="1" id="c3" oninput="nextCode(this,'c4')" onkeydown="prevCode(event,'c2','c3')">
        <input class="code-input" maxlength="1" id="c4" oninput="nextCode(this,null)" onkeydown="prevCode(event,'c3','c4')">
      </fieldset>
      <button class="btn-participar" onclick="participar()">🚀 Participar da turma!</button>
    </section>
  </article>
</section>

<!-- TOAST -->
<output class="toast" id="toast"></output>

<script>
  function goto(pageId) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    const target = document.getElementById(pageId);
    if (target) { target.classList.add('active'); window.scrollTo(0,0); }
  }

  function openModal() { document.getElementById('modal-turma').classList.add('open'); document.getElementById('c1').focus(); }
  function closeModal() { document.getElementById('modal-turma').classList.remove('open'); ['c1','c2','c3','c4'].forEach(id => document.getElementById(id).value = ''); }

  function nextCode(el, nextId) {
    if (el.value && nextId) document.getElementById(nextId).focus();
  }
  function prevCode(e, prevId, curId) {
    if (e.key === 'Backspace' && !document.getElementById(curId).value && prevId)
      document.getElementById(prevId).focus();
  }

  function participar() {
    const code = ['c1','c2','c3','c4'].map(id => document.getElementById(id).value.toUpperCase()).join('');
    if (code.length < 4) { showToast('⚠️ Digite o código completo de 4 letras!'); return; }
    if (code === 'A3K7') {
      closeModal();
      showToast('🎉 Você entrou na turma Séries – 5º Ano D!');
      setTimeout(() => goto('page-turma-detalhe'), 800);
    } else {
      showToast('❌ Código inválido! Verifique com sua professora.');
    }
  }

  function switchSubTab(tab) {
    document.querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById('sub-mural').style.display = 'none';
    document.getElementById('sub-atividades-turma').style.display = 'none';
    document.getElementById('sub-pessoas').style.display = 'none';
    if (tab === 'mural') document.getElementById('sub-mural').style.display = 'block';
    if (tab === 'atividades-turma') document.getElementById('sub-atividades-turma').style.display = 'grid';
    if (tab === 'pessoas') document.getElementById('sub-pessoas').style.display = 'block';
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  function showHomeTab(tab) {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    event.target.classList.add('active');
  }

  // Allow closing modal on overlay click
  document.getElementById('modal-turma').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
</script>

<!-- FOOTER -->
<%- include('./partials/footer.ejs') %>

</body>
</html>
