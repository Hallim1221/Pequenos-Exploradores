    .test-card { padding: 16px; }
    .test-stars { font-size: 12px; }
    .test-text { font-size: 12px; margin-bottom: 10px; }
    .test-name { font-size: 12px; }
    .test-role { font-size: 10px; }
    .partners { padding: 16px 20px; gap: 16px; margin-top: 120px; }
    .partners p { font-size: 10px; }
    .partner-logo { font-size: 12px; }
    .cloud-1 { width: 70px; height: 28px; top: 15%; left: -90px; }
    .cloud-1::before { width: 45px; height: 45px; top: -22px; left: 8px; }
    .cloud-1::after { width: 35px; height: 35px; top: -15px; left: 30px; }
    .cloud-2 { width: 100px; height: 36px; top: 25%; left: -120px; }
    .cloud-2::before { width: 52px; height: 52px; top: -30px; left: 15px; }
    .cloud-2::after { width: 40px; height: 40px; top: -22px; left: 45px; }
    .cloud-3 { width: 60px; height: 25px; top: 12%; left: -80px; }
    .cloud-3::before { width: 38px; height: 38px; top: -20px; left: 5px; }
    .cloud-3::after { width: 30px; height: 30px; top: -14px; left: 28px; }
    .cloud-4 { width: 80px; height: 32px; top: 32%; left: -100px; }
    .cloud-4::before { width: 48px; height: 48px; top: -26px; left: 12px; }
    .cloud-4::after { width: 37px; height: 37px; top: -16px; left: 34px; }
    .cloud-5 { width: 65px; height: 28px; top: 20%; left: -85px; }
    .cloud-5::before { width: 40px; height: 40px; top: -22px; left: 8px; }
    .cloud-5::after { width: 31px; height: 31px; top: -15px; left: 28px; }
    .cloud-6 { width: 95px; height: 35px; top: 38%; left: -115px; }
    .cloud-6::before { width: 52px; height: 52px; top: -28px; left: 18px; }
    .cloud-6::after { width: 42px; height: 42px; top: -22px; left: 48px; }
    .cloud-7 { width: 65px; height: 26px; top: 45%; left: -80px; display: block; }
    .cloud-7::before { width: 38px; height: 38px; top: -20px; left: 7px; }
    .cloud-7::after { width: 30px; height: 30px; top: -13px; left: 23px; }
    .cloud-8 { width: 85px; height: 30px; top: 55%; left: -105px; display: block; }
    .cloud-8::before { width: 48px; height: 48px; top: -24px; left: 11px; }
    .cloud-8::after { width: 36px; height: 36px; top: -15px; left: 31px; }
    .cloud-9 { width: 70px; height: 28px; top: 50%; left: -85px; display: block; }
    .cloud-9::before { width: 42px; height: 42px; top: -22px; left: 9px; }
    .cloud-9::after { width: 33px; height: 33px; top: -15px; left: 27px; }
