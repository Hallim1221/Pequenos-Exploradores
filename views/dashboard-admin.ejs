function filterTable(input, tableId) {
  const q = input.value.toLowerCase().trim();
  if (!q) {
    // Se o filtro está vazio, mostrar todas as linhas
    document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
      row.style.display = '';
    });
    return;
  }
  
  document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
    // Procurar em <td> que contêm <p> ou <span>, mas não em <select>
    let matches = false;
    const cells = row.querySelectorAll('td');
    
    for (let cell of cells) {
      // Pega apenas o texto dos <p> e <span>, não dos <select>
      const cellText = Array.from(cell.querySelectorAll('p, span, a'))
        .map(el => el.textContent)
        .join(' ')
        .toLowerCase();
      
      if (cellText.includes(q)) {
        matches = true;
        break;
      }
      
      // Se não achou em <p> ou <span>, tenta no texto direto da célula (mas evita <select>)
      if (!cell.querySelector('select') && cell.textContent.toLowerCase().includes(q)) {
        matches = true;
        break;
      }
    }
    
    row.style.display = matches ? '' : 'none';
  });
}

function filterByPlan(select) {
  const val = select.value.toLowerCase();
  const tableId = 'tbl-inst';
  
  // Aplicar filtro de plano
  document.querySelectorAll('#' + tableId + ' tbody tr').forEach(row => {
    const planSelect = row.querySelector('.plan-select');
    const planValue = planSelect ? planSelect.value.toLowerCase() : '';
    
    // Se val está vazio ou o plano bate, mostrar
    const planMatches = !val || planValue === val;
    
    // Também verificar se o filtro de busca ainda está ativo
    const searchInput = document.querySelector('input[placeholder="Buscar instituição..."]');
    let searchMatches = true;
    
    if (searchInput && searchInput.value.trim()) {
      const searchQ = searchInput.value.toLowerCase().trim();
      const cells = row.querySelectorAll('td');
      searchMatches = false;
      
      for (let cell of cells) {
        const cellText = Array.from(cell.querySelectorAll('p, span, a'))
          .map(el => el.textContent)
          .join(' ')
          .toLowerCase();
        
        if (cellText.includes(searchQ)) {
          searchMatches = true;
          break;
        }
      }
    }
    
    row.style.display = (planMatches && searchMatches) ? '' : 'none';
  });
}

