// Atualizar badge de notificações dinamicamente
async function atualizarBadgeNotificacoes() {
  try {
    const resposta = await fetch('/api/parcerias/notificacoes/count');
    const dados = await resposta.json();
    const count = dados.count || 0;
    
    // Procurar o item de navegação de mensagens
    const navItemMensagens = Array.from(document.querySelectorAll('.nav-item')).find(el => 
      el.textContent.includes('Mensagens')
    );
    
    if (!navItemMensagens) return; // Se não encontrar, sair silenciosamente
    
    let badge = navItemMensagens.querySelector('.nav-badge');
    
    if (count > 0) {
      if (!badge) {
        // Criar badge se não existir
        badge = document.createElement('span');
        badge.className = 'nav-badge';
        badge.style.marginLeft = 'auto';
        navItemMensagens.appendChild(badge);
      }
      // Atualizar conteúdo
      badge.classList.remove('removing');
      badge.textContent = count;
      badge.style.display = 'inline-flex';
    } else {
      // Remover ou ocultar badge se count = 0
      if (badge) {
        badge.classList.add('removing');
        setTimeout(() => {
          const badgeAtual = navItemMensagens.querySelector('.nav-badge');
          if (badgeAtual) {
            badgeAtual.style.display = 'none';
          }
        }, 300);
      }
    }
  } catch (erro) {
    console.error('Erro ao atualizar badge:', erro);
  }
}

