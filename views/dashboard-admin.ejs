              </section>
            </section>
            <footer class="chat-input-row">
              <input type="text" class="chat-input" id="chat-input-field" placeholder="Digitar mensagem..." onkeypress="sendOnEnterAdmin(event)">
              <button class="chat-send" onclick="sendMessageAdmin()" id="send-btn" disabled>enviar</button>
            </footer>
          </section>
        </section>
      </article>

