// ===== DETALHES DOS CARDS =====
function abrirDetalheCrescimento() {
  alert('📈 Crescimento de Usuários\n\nÚltimos 30 dias\n\nEsta seção mostra o crescimento de novos usuários (alunos + professores) cadastrados na plataforma nos últimos 30 dias.');
}

function abrirDetalheAtivacao() {
  alert('🎯 Taxa de Ativação\n\nConversão Trial → Premium\n\nEsta métrica representa a porcentagem de instituições que converteram de trial (teste) para plano premium (pago).');
}

// Handler para mudanças de plano (definido uma única vez, fora da função)
function handlePlanoChange(event) {
  if (event.target.classList.contains('plan-select')) {
    const instId = event.target.getAttribute('data-inst-id');
    const novoPlano = event.target.value;
    console.log(`Select disparado: instId=${instId}, novoPlano=${novoPlano}`);
    atualizarPlano(instId, novoPlano);
  }
}

// ===== USUÁRIOS =====
async function carregarUsuarios() {
  try {
    const resposta = await fetch('/api/usuarios');
    const dados = await resposta.json();
    
    if (!dados.success) {
      console.error('Erro ao carregar usuários');
      return;
    }
    
    const tbody = document.querySelector('#tbl-users tbody');
    tbody.innerHTML = '';
    
    if (!dados.usuarios || dados.usuarios.length === 0) {
      tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; color: var(--text-mute); padding: 20px;">Nenhum usuário encontrado</td></tr>';
      return;
    }
    
    dados.usuarios.forEach(usuario => {
      const row = document.createElement('tr');
      
      // Determinar status badge
      const statusBadge = usuario.status === 'ativo' 
        ? '<span class="badge badge-green">Ativo</span>'
        : '<span class="badge badge-amber">Pendente</span>';
      
      // Determinar tipo de usuário
      const tipoLabel = usuario.tipo === 'professor' ? 'Professor' : 'Aluno';
      
      row.innerHTML = `
        <td><p class="cell-main">${usuario.nome}</p><p class="cell-sub">${tipoLabel}</p></td>
        <td>${usuario.email}</td>
        <td>${usuario.instituicao || 'N/A'}</td>
        <td>${statusBadge}</td>
        <td style="text-align:right">
          ${usuario.status !== 'ativo' 
            ? `<button class="btn btn-sm btn-primary" onclick="approveUser(this)">✓ Aprovar</button>`
            : `<button class="btn btn-sm" onclick="abrirConfirmacaoExclusaoUsuario('${usuario.id}', '${usuario.nome}')" title="Excluir usuário">🗑️</button>`
          }
        </td>
      `;
      
      tbody.appendChild(row);
    });
  } catch (erro) {
    console.error('Erro ao carregar usuários:', erro);
    const tbody = document.querySelector('#tbl-users tbody');
    tbody.innerHTML = '<tr><td colspan="5" style="text-align: center; color: var(--text-mute); padding: 20px;">Erro ao carregar usuários</td></tr>';
  }
}

// ===== INSTITUIÇÕES =====
async function carregarInstituicoes() {
  try {
    const resposta = await fetch('/api/instituicoes');
    const dados = await resposta.json();
    
    if (!dados.sucesso) {
      console.error('Erro ao carregar instituições');
      return;
    }
    
    const tbody = document.getElementById('instituicoes-tbody');
    
    // Remover listener antigo antes de limpar o tbody
    tbody.removeEventListener('change', handlePlanoChange);
    tbody.removeEventListener('click', handleRowClick);
    
    tbody.innerHTML = '';
    
    dados.instituicoes.forEach(inst => {
      const row = document.createElement('tr');
      row.style.cursor = 'pointer';
      
      const planClass = inst.plano === 'premium' ? 'plan-premium' : inst.plano === 'comum' ? 'plan-comum' : 'plan-em-andamento';
      const planLabel = inst.plano === 'premium' ? 'Premium ⭐' : inst.plano === 'comum' ? 'Comum' : 'Em Andamento';
      
      row.innerHTML = `
        <td><p class="cell-main">${inst.nome}</p><p class="cell-sub">${inst.email}</p></td>
        <td>
          <select class="plan-select" data-inst-id="${inst.id}" onclick="event.stopPropagation()">
            <option value="em-andamento" ${inst.plano === 'em-andamento' ? 'selected' : ''}>Em Andamento</option>
            <option value="comum" ${inst.plano === 'comum' ? 'selected' : ''}>Comum</option>
            <option value="premium" ${inst.plano === 'premium' ? 'selected' : ''}>Premium ⭐</option>
          </select>
        </td>
        <td><p class="cell-main">${inst.cidade}</p></td>
        <td><p class="cell-main">${inst.professor}</p></td>
        <td><span class="badge badge-green">${inst.status === 'ativo' ? 'Ativo' : 'Inativo'}</span></td>
        <td style="text-align:right">
          <article class="row-actions" onclick="event.stopPropagation()">
            <button class="btn btn-sm" onclick="editarInstituicao(${inst.id}, '${inst.nome}')">✏️</button>
            <button class="btn btn-sm btn-danger" onclick="openBlockModal('${inst.nome}', false)">🚫</button>
          </article>
        </td>
      `;
      
      row.dataset.instId = inst.id;
      row.dataset.instName = inst.nome;
      tbody.appendChild(row);
    });
    
    // Adicionar listeners
    tbody.addEventListener('change', handlePlanoChange);
    tbody.addEventListener('click', handleRowClick);
  } catch (erro) {
    console.error('Erro ao carregar instituições:', erro);
  }
}

// Handler para click nas linhas de instituição
function handleRowClick(event) {
  const row = event.target.closest('tr');
  if (row && row.dataset.instId) {
    abrirAlunosInstituicao(row.dataset.instId, row.dataset.instName);
  }
}

async function atualizarPlano(instId, novoPlano) {
  try {
    const resposta = await fetch(`/api/instituicoes/${instId}/plano`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ plano: novoPlano })
    });
    
    const dados = await resposta.json();
    if (dados.sucesso) {
      showToast(`Plano atualizado para ${novoPlano}!`);
    }
  } catch (erro) {
    console.error('Erro ao atualizar plano:', erro);
    showToast('Erro ao atualizar plano', 3000);
  }
}

// Abrir modal com alunos da instituição
async function abrirAlunosInstituicao(instId, instName) {
  try {
    // Atualizar título do modal
    document.getElementById('alunos-title').textContent = `👥 Alunos de ${instName}`;
    
    // Carregar alunos da API
    const resposta = await fetch(`/api/instituicoes/${instId}/alunos`);
    const dados = await resposta.json();
    
    const conteudo = document.getElementById('alunos-content');
    conteudo.innerHTML = '';
    
    if (!dados.success || dados.total_alunos === 0) {
      conteudo.innerHTML = '<p style="color: var(--text-mute); text-align: center; padding: 20px;">Nenhum aluno cadastrado nesta instituição</p>';
    } else {
      // Criar tabela de alunos
      let html = `
        <table style="width: 100%; border-collapse: collapse;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border); background: var(--g50);">
              <th style="padding: 12px; text-align: left; font-weight: 600; color: var(--text); font-size: 13px;">Nome</th>
              <th style="padding: 12px; text-align: left; font-weight: 600; color: var(--text); font-size: 13px;">Email</th>
              <th style="padding: 12px; text-align: center; font-weight: 600; color: var(--text); font-size: 13px;">Saldo</th>
              <th style="padding: 12px; text-align: right; font-weight: 600; color: var(--text); font-size: 13px;">Ação</th>
            </tr>
          </thead>
          <tbody>
      `;
      
      dados.alunos.forEach(aluno => {
        html += `
          <tr style="border-bottom: 1px solid var(--border-sm);">
            <td style="padding: 12px; color: var(--text);">${aluno.nome}</td>
            <td style="padding: 12px; color: var(--text-sub); font-size: 13px;">${aluno.email}</td>
            <td style="padding: 12px; text-align: center; color: var(--g700); font-weight: 600;">⭐ ${aluno.saldo}</td>
            <td style="padding: 12px; text-align: right;">
              <button class="btn btn-sm" onclick="abrirConfirmacaoExclusaoAluno('${aluno.id}', '${aluno.nome.replace(/'/g, "\\'")}')" title="Deletar aluno" style="background: #ff6b6b; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 14px;">🗑️</button>
            </td>
          </tr>
        `;
      });
      
      html += `
          </tbody>
        </table>
      `;
      
