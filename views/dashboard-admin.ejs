<!-- Toast -->
<section class="toast" id="toast">✅ <span id="toast-msg">Ação realizada com sucesso</span></section>

<script>
const pageNames = {
  dashboard: 'Dashboard',
  instituicoes: 'Instituições',
  usuarios: 'Usuários',
  chat: 'Mensagens',
  atividades: 'Atividades',
  publicacoes: 'Publicações',
  relatorios: 'Relatórios'
};

function navigate(id, el) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.getElementById('topbar-title').textContent = pageNames[id];
  document.getElementById('topbar-breadcrumb').textContent = pageNames[id];
  if (el) el.classList.add('active');
  
  // Parar polling de chat se sair da página de chat
  if (id !== 'chat' && window.pollingChat) {
    clearInterval(window.pollingChat);
    window.pollingChat = null;
  }
  
  // Carregar dados específicos de cada página
  if (id === 'instituicoes') {
    carregarInstituicoes();
  } else if (id === 'dashboard') {
    carregarDashboard();
    carregarRanking();
  } else if (id === 'usuarios') {
    carregarUsuarios();
  } else if (id === 'chat') {
    // Atualizar badge ao abrir página de chat
    atualizarBadgeNotificacoes();
  } else if (id === 'relatorios') {
    carregarRelatorios();
  }
}

async function carregarRelatorios() {
  try {
    const resposta = await fetch('/api/relatorios');
    const dados = await resposta.json();
    
    if (!dados.success) {
      console.error('Erro ao carregar relatórios');
      return;
    }
    
    const relatorios = dados.relatorios;
    
    // Atualizar Crescimento Mensal
    const cardCrescimento = document.querySelector('[data-rel-id="crescimento"]');
    if (cardCrescimento) {
      cardCrescimento.querySelector('.stat-value').textContent = relatorios.crescimento_mensal.valor;
      const trendClass = relatorios.crescimento_mensal.tendencia === 'acelerado' ? 'trend-up' : 'trend-neutral';
      cardCrescimento.querySelector('.stat-trend').textContent = `↑ ${relatorios.crescimento_mensal.tendencia.charAt(0).toUpperCase() + relatorios.crescimento_mensal.tendencia.slice(1)}`;
      cardCrescimento.querySelector('.stat-trend').className = `stat-trend ${trendClass}`;
    }
    
    // Atualizar Tempo Médio
    const cardTempo = document.querySelector('[data-rel-id="tempo"]');
    if (cardTempo) {
      cardTempo.querySelector('.stat-value').textContent = relatorios.tempo_medio.valor;
    }
    
    // Atualizar Satisfação
    const cardSatisfacao = document.querySelector('[data-rel-id="satisfacao"]');
    if (cardSatisfacao) {
      cardSatisfacao.querySelector('.stat-value').textContent = relatorios.satisfacao.valor;
    }
    
    // Atualizar Retenção
    const cardRetencao = document.querySelector('[data-rel-id="retencao"]');
    if (cardRetencao) {
      cardRetencao.querySelector('.stat-value').textContent = relatorios.retencao.valor;
      const trendClass = relatorios.retencao.tendencia === 'estavel' ? 'trend-up' : 'trend-down';
      cardRetencao.querySelector('.stat-sub').innerHTML = `<span class="stat-trend ${trendClass}">↑ ${relatorios.retencao.subtexto}</span>`;
    }
  } catch (erro) {
    console.error('Erro ao carregar relatórios:', erro);
  }
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function saveAndClose(id) {
  closeModal(id);
  showToast('Salvo com sucesso!');
}

function showToast(msg, duration = 2800) {
  const toast = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), duration);
}

function confirmDelete(type) {
  document.getElementById('delete-msg').textContent = `Tem certeza que deseja excluir este(a) ${type}? Esta ação não pode ser desfeita.`;
}

let blockingInst = '';
let isUnblocking = false;

// ===== DASHBOARD DADOS REAIS =====
async function carregarDashboard() {
  try {
    const resposta = await fetch('/api/dashboard/resumo');
    const dados = await resposta.json();
    
    if (!dados.success) {
      console.error('Erro ao carregar resumo do dashboard');
      return;
    }
    
    const resumo = dados.resumo;
    
    // ===== ATUALIZAR STAT-CARDS COM DADOS REAIS =====
    
    // 1. INSTITUIÇÕES (total de parcerias)
    const totalInst = resumo.total_instituicoes;
    document.getElementById('stat-instituicoes').textContent = totalInst;
    document.getElementById('stat-inst-trend').textContent = `Total: ${totalInst} ativa(s)`;
    
    // 2. USUÁRIOS (Alunos + Professores)
    const totalUsuarios = resumo.total_alunos + resumo.total_professores;
    document.getElementById('stat-usuarios').textContent = totalUsuarios;
    document.getElementById('stat-user-trend').textContent = `${resumo.total_alunos} alunos + ${resumo.total_professores} prof.`;
    
    // 3. ALUNOS (total de alunos)
    const totalAlunos = resumo.total_alunos;
    document.getElementById('stat-alunos').textContent = totalAlunos;
    document.getElementById('stat-alunos-trend').textContent = `Total de alunos cadastrados`;
    
    // 4. RECEITA (Saldo total de todos os alunos)
    // Precisamos buscar os dados de instituições para calcular o saldo total
    const respostaInst = await fetch('/api/instituicoes');
    const dadosInst = await respostaInst.json();
    
    let saldoTotal = 0;
    if (dadosInst.success && dadosInst.instituicoes) {
      saldoTotal = dadosInst.instituicoes.reduce((sum, inst) => sum + (inst.saldo_total || 0), 0);
    }
    
    const instPremium = resumo.planos.premium || 0;
    document.getElementById('stat-receita').textContent = `⭐ ${saldoTotal} pts`;
    document.getElementById('stat-receita-trend').textContent = `Saldo total (${instPremium} plano(s) premium)`;
    
    // ===== ATUALIZAR BADGES DE PLANO =====
    const planoBadges = document.querySelector('.plan-badges');
    if (planoBadges) {
      let html = '<p style="font-size: 13px; font-weight: 600; margin-bottom: 8px; color: var(--text);">📊 Planos:</p>';
      if (resumo.planos.premium > 0) {
        html += `<span class="badge badge-gold">⭐ Premium: ${resumo.planos.premium}</span>`;
      }
      if (resumo.planos.comum > 0) {
        html += `<span class="badge badge-slate">📚 Comum: ${resumo.planos.comum}</span>`;
      }
      planoBadges.innerHTML = html;
    }
    
    // ===== ATUALIZAR ÚLTIMAS ATIVIDADES =====
    const ultimasAtiv = document.querySelector('.ultimas-atividades');
    if (ultimasAtiv && resumo.ultimas_atividades) {
      let html = '';
      resumo.ultimas_atividades.forEach(ativ => {
        html += `
          <article style="padding: 10px; border-bottom: 1px solid var(--border-sm); font-size: 13px;">
            <p style="color: var(--text); font-weight: 500;">👤 ${ativ.aluno_nome || 'Usuário'}</p>
            <p style="color: var(--text-sub); font-size: 12px;">📍 ${ativ.nome_escola || 'Instituição'}</p>
            <p style="color: var(--text-mute); font-size: 12px;">🕐 ${new Date(ativ.data).toLocaleDateString('pt-BR')}</p>
          </article>
        `;
      });
      ultimasAtiv.innerHTML = html || '<p style="color: var(--text-mute); padding: 10px; text-align: center;">Nenhuma atividade ainda</p>';
    }
  } catch (erro) {
    console.error('Erro ao carregar dashboard:', erro);
  }
}

async function carregarRanking() {
  try {
    const resposta = await fetch('/api/dashboard/ranking?limite=5');
    const dados = await resposta.json();
    
    if (!dados.success) {
      console.error('Erro ao carregar ranking');
      return;
    }
    
    const ranking = document.querySelector('.ranking-alunos');
    if (ranking && dados.ranking) {
      let html = '';
      dados.ranking.forEach((aluno, idx) => {
        const medalha = idx === 0 ? '🥇' : idx === 1 ? '🥈' : idx === 2 ? '🥉' : '📍';
        html += `
          <article style="display: flex; align-items: center; gap: 12px; padding: 10px; border-bottom: 1px solid var(--border-sm);">
            <span style="font-size: 18px;">${medalha}</span>
            <article style="flex: 1;">
              <p style="color: var(--text); font-weight: 500; font-size: 13px;">${aluno.nome}</p>
              <p style="color: var(--text-mute); font-size: 12px;">${aluno.instituicao}</p>
            </article>
            <p style="color: var(--g700); font-weight: 700; font-size: 14px;">⭐ ${aluno.pontos}</p>
          </article>
        `;
      });
      ranking.innerHTML = html || '<p style="color: var(--text-mute); padding: 10px; text-align: center;">Sem dados</p>';
    }
  } catch (erro) {
    console.error('Erro ao carregar ranking:', erro);
  }
}

// ===== CRESCIMENTO DE USUÁRIOS =====
async function carregarCrescimento() {
  try {
    const resposta = await fetch('/api/dashboard/crescimento');
    const dados = await resposta.json();
    
    if (!dados.sucesso) {
      console.error('Erro ao carregar crescimento');
      return;
    }
    
    // Atualizar barra de progresso
    const progress = document.getElementById('crescimento-progress');
    const valor = document.getElementById('crescimento-valor');
    const desc = document.getElementById('crescimento-desc');
    
    if (progress && valor && desc) {
      const percentual = Math.min(dados.barraPercentual, 100);
      progress.value = percentual;
      progress.querySelector('.progress-fill').style.width = percentual + '%';
      valor.textContent = percentual + '%';
      desc.textContent = `+${dados.crescimento} usuários (${dados.percentual}% crescimento)`;
    }
  } catch (erro) {
    console.error('Erro ao carregar crescimento:', erro);
  }
}

