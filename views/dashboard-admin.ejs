      <!-- PARCERIAS PAGE -->
      <article class="page" id="page-parcerias">
        <header class="page-header">
          <section>
            <h2 class="page-title">Parcerias com Escolas</h2>
            <p class="page-subtitle">Gerencie solicitações de parceria de escolas</p>
          </section>
        </header>

        <section class="search-row">
          <article class="search-input-wrap">
            <span class="search-icon">🔍</span>
            <input type="text" class="search-input" placeholder="Buscar por escola, email ou contato..." onkeyup="filterTable(this, 'tbl-parcerias')">
          </article>
          <select class="filter-select" id="filtro-status" onchange="filterByStatus(this)">
            <option value="">Todos os status</option>
            <option value="pendente">Pendente</option>
            <option value="em_andamento">Em Andamento</option>
            <option value="concluido">Concluído</option>
          </select>
        </section>

        <article class="card">
          <article class="table-wrap">
            <table id="tbl-parcerias">
              <thead>
                <tr>
                  <th>Escola</th>
                  <th>Contato</th>
                  <th>Email</th>
                  <th>Tipo</th>
                  <th>Status</th>
                  <th>Data</th>
                  <th>Ações</th>
                </tr>
              </thead>
              <tbody>
                <% if (parcerias && parcerias.length > 0) { %>
                  <% parcerias.forEach(parceria => { %>
                    <tr>
                      <td><strong><%= parceria.nome_escola %></strong></td>
                      <td><%= parceria.nome_contato %></td>
                      <td><a href="mailto:<%= parceria.email %>" style="color:#0066cc;text-decoration:none;"><%= parceria.email %></a></td>
                      <td><span style="font-size:12px;color:#666;"><%= parceria.tipo_escola %></span></td>
                      <td>
                        <% if (parceria.status === 'pendente') { %>
                          <span style="background:#FEF3DC;color:#C07A10;padding:4px 8px;border-radius:4px;font-size:12px;font-weight:600;">⏳ Pendente</span>
                        <% } else if (parceria.status === 'em_andamento') { %>
                          <span style="background:#E5F0FB;color:#1B5FA0;padding:4px 8px;border-radius:4px;font-size:12px;font-weight:600;">🔵 Em Andamento</span>
                        <% } else if (parceria.status === 'concluido') { %>
                          <span style="background:#E8F5D6;color:#2E6010;padding:4px 8px;border-radius:4px;font-size:12px;font-weight:600;">✅ Concluído</span>
                        <% } %>
                      </td>
                      <td style="font-size:12px;color:#666;"><%= new Date(parceria.data_solicitacao).toLocaleDateString('pt-BR') %></td>
                      <td style="text-align:right;">
                        <article class="row-actions">
                          <button class="btn btn-sm" onclick="viewParceria(<%= parceria.id %>)" title="Visualizar">👁️</button>
                          <button class="btn btn-sm" onclick="editParceria(<%= parceria.id %>)" title="Editar">✏️</button>
                          <button class="btn btn-sm" onclick="abrirChatParceria(<%= parceria.id %>, '<%= parceria.nome_escola %>')" title="Chat">💬</button>
                        </article>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="7" style="text-align:center;padding:24px;color:#666;">Nenhuma solicitação de parceria encontrada</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </article>
        </article>
      </article>

      <!-- USUÁRIOS PAGE -->
