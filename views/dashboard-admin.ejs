async function selectChatParceria(id, nomeParceria, el) {
  parceriaAtualChat = id;
  parceriaNomeSelecionada = nomeParceria;
  
  document.querySelectorAll('.chat-item').forEach(i => i.classList.remove('active'));
  el.classList.add('active');
  
  // Marcar mensagens como visualizadas quando abrir o chat
  try {
    await fetch(`/api/parcerias/${id}/mensagens/visualizar`, { method: 'PUT' });
    // Atualizar badge após marcar como visto
    atualizarBadgeNotificacoes();
  } catch (erro) {
    console.error('Erro ao marcar mensagens como visualizadas:', erro);
  }
  
  // Extrair iniciais do nome
  const initials = nomeParceria.substring(0, 2).toUpperCase();
  document.getElementById('chat-win-avatar').textContent = initials;
  document.getElementById('chat-win-name').textContent = nomeParceria;
  
  // Buscar email da parceria
  const parceria = <%-JSON.stringify(parcerias) %>;
  const parData = parceria.find(p => p.id === id);
  if (parData) {
    document.getElementById('chat-win-email').textContent = parData.email || 'Contato via email';
  }
  
  // Habilitar botão de envio
  document.getElementById('send-btn').disabled = false;
  
  // Carregar mensagens
  await carregarMensagensParcerias(id);
  
  // Iniciar polling para atualizar mensagens em tempo real a cada 2 segundos
  if (window.pollingChat) clearInterval(window.pollingChat);
  window.pollingChat = setInterval(() => {
    if (parceriaAtualChat) {
      carregarMensagensParcerias(parceriaAtualChat);
      // Atualizar badge também durante polling
      atualizarBadgeNotificacoes();
    }
  }, 2000);
}

async function carregarMensagensParcerias(id) {
  try {
    const resposta = await fetch(`/api/parcerias/${id}/mensagens`);
    const dados = await resposta.json();
    
    const container = document.getElementById('chat-messages-usuarios');
    container.innerHTML = '';
    
    if (dados.sucesso && dados.mensagens && dados.mensagens.length > 0) {
      dados.mensagens.forEach(msg => {
        const msgDiv = document.createElement('section');
        msgDiv.className = 'msg ' + (msg.remetente === 'admin' ? 'msg-out' : 'msg-in');
        
        const horaMsg = new Date(msg.data_mensagem);
        const hora = horaMsg.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        
        msgDiv.innerHTML = `
          <span class="msg-avatar">${msg.remetente === 'admin' ? 'AD' : extrairIniciais(parceriaNomeSelecionada)}</span>
          <article>
            <article class="msg-bubble">${msg.conteudo}</article>
            <p class="msg-time">${hora}${msg.remetente === 'admin' ? ' ✓✓' : ''}</p>
          </article>
        `;
        container.appendChild(msgDiv);
      });
    } else {
      const emptyDiv = document.createElement('section');
      emptyDiv.style.cssText = 'text-align: center; padding: 40px 16px; color: var(--text-mute);';
      emptyDiv.innerHTML = '<p style="font-size: 13px;">Nenhuma mensagem ainda. Envie uma para iniciar.</p>';
      container.appendChild(emptyDiv);
    }
    
    container.scrollTop = container.scrollHeight;
    
    // 🔔 Atualizar badge após carregar mensagens
    atualizarBadgeNotificacoes();
  } catch (erro) {
    console.error('Erro ao carregar mensagens:', erro);
  }
}

