// Carregar e exibir notificacoes
async function carregarNotificacoes() {
  try {
    const resposta = await fetch('/api/notificacoes');
    const dados = await resposta.json();
    
    if (!dados.sucesso) {
      console.error('Erro ao carregar notificações');
      return;
    }
    
    const itemsContainer = document.getElementById('notif-items');
    itemsContainer.innerHTML = '';
    
    // Atualizar visibilidade da marquinha
    const notifDot = document.querySelector('.notif-dot');
    if (dados.total > 0) {
      notifDot?.classList.add('visible');
    } else {
      notifDot?.classList.remove('visible');
    }
    
    // Se nao houver notificacoes
    if (dados.total === 0) {
      itemsContainer.innerHTML = `
        <div class="notif-empty">
          <div class="notif-empty-icon">🔔</div>
          <p>Nenhuma notificacao no momento</p>
        </div>
      `;
      return;
    }
    
    // Exibir solicitacoes de instituicoes pendentes
    if (dados.parceriasPendentes && dados.parceriasPendentes.length > 0) {
      for (const parceria of dados.parceriasPendentes) {
        const data = new Date(parceria.data).toLocaleDateString('pt-BR');
        itemsContainer.innerHTML += `
          <div class="notif-item">
            <div class="notif-item-header">
              <div class="notif-item-type">📋</div>
              <div>
                <div class="notif-item-title">Nova solicitacao de instituicao</div>
                <div class="notif-item-subtitle">${parceria.nome}</div>
              </div>
            </div>
            <div class="notif-item-content">
              Contato: ${parceria.contato}<br>
              Email: ${parceria.email}<br>
              Cidade: ${parceria.cidade}
            </div>
            <div class="notif-item-time">${data}</div>
          </div>
        `;
      }
    }
    
    // Exibir mensagens nao lidas
    if (dados.mensagensNaoLidas && dados.mensagensNaoLidas.length > 0) {
      for (const msg of dados.mensagensNaoLidas) {
        const data = new Date(msg.data).toLocaleDateString('pt-BR');
        itemsContainer.innerHTML += `
          <div class="notif-item" onclick="abrirMensagemNotificacao(${msg.id}, ${msg.parceriaId}, '${msg.nomeEscola.replace(/'/g, "\\'")}')">
            <div class="notif-item-header">
              <div class="notif-item-type">💬</div>
              <div>
                <div class="notif-item-title">Nova mensagem</div>
                <div class="notif-item-subtitle">${msg.nomeEscola}</div>
              </div>
            </div>
            <div class="notif-item-content">
              ${msg.conteudo.substring(0, 100)}${msg.conteudo.length > 100 ? '...' : ''}
            </div>
            <div class="notif-item-time">${data}</div>
          </div>
        `;
      }
    }
  } catch (erro) {
    console.error('Erro ao carregar notificações:', erro);
  }
}

// Abrir mensagem da notificacao e marcar como lida
async function abrirMensagemNotificacao(mensagemId, parceriaId, nomeEscola) {
  try {
    // Marcar mensagem como lida
    await fetch('/api/notificacoes/marcar-como-lido', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ mensagemId })
    });
    
    // Fechar sidebar de notificacoes
    fecharNotificacoes();
    
    // Navegar para aba de Parcerias/Mensagens
    document.querySelectorAll('[onclick*="chat"]')[0]?.click();
    
    // Selecionar a conversa
    setTimeout(() => {
      const chatItem = document.querySelector(`.chat-item[data-parceria-id="${parceriaId}"]`);
      if (chatItem) {
        selectChatParceria(parceriaId, nomeEscola, chatItem);
      }
    }, 100);
    
    // Atualizar badge
    atualizarBadgeNotificacoes();
  } catch (erro) {
    console.error('Erro ao abrir mensagem:', erro);
  }
}

