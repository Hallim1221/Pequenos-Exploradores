      <!-- CHAT PAGE -->
      <article class="page" id="page-chat">
        <header class="page-header">
          <section>
            <h2 class="page-title">Mensagens</h2>
            <p class="page-subtitle">Suporte com as escolas em parceria</p>
          </section>
        </header>

        <section class="chat-layout">
          <section class="chat-list">
            <header class="chat-list-header">
              <h3 class="chat-list-title">Conversas</h3>
            </header>
            <article class="chat-list-items" id="chat-list-container">
              <% if (parcerias && parcerias.length > 0) { %>
                <% parcerias.forEach((parceria, index) => { %>
                  <section class="chat-item <%= index === 0 ? 'active' : '' %>" data-parceria-id="<%= parceria.id %>" onclick="selectChatParceria(<%= parceria.id %>, '<%= parceria.nome_escola %>', this)">
                    <span class="chat-avatar" style="background: var(--g400); color: white; font-weight: bold;">
                      <%= parceria.nome_escola.substring(0, 2).toUpperCase() %>
                    </span>
                    <article class="chat-item-info">
                      <p class="chat-item-name"><%= parceria.nome_escola %></p>
                      <p class="chat-item-preview"><%= parceria.tipo_escola %> • <%= parceria.email %></p>
                    </article>
                    <article class="chat-item-meta">
                      <p class="chat-item-time" id="chat-time-<%= parceria.id %>">--:--</p>
                    </article>
                  </section>
                <% }); %>
              <% } else { %>
                <article style="text-align: center; padding: 32px 16px; color: var(--text-mute);">
                  <p style="font-size: 13px;">Nenhuma parceria cadastrada</p>
                </article>
              <% } %>
            </article>
          </section>

          <section class="chat-window">
            <header class="chat-win-header">
              <span class="chat-win-avatar" id="chat-win-avatar">--</span>
              <article>
                <p class="chat-win-name" id="chat-win-name">Selecione uma conversa</p>
